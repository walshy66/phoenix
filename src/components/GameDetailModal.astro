---
/**
 * T7.1: Game Detail Modal Component
 *
 * Renders a modal overlay with full game details.
 * Opens when a fixture game row is clicked, closes on Escape or close button.
 *
 * Features:
 * - Fixed positioning (no layout shift when opening/closing)
 * - Backdrop with opacity (click to close, optional)
 * - Game details display (opponent, time, venue, home/away, final score)
 * - Close button with aria-label and visible focus indicator
 * - Keyboard accessible: Escape to close, focus management
 * - Smooth fade-in/fade-out animation (200ms)
 * - Full height on mobile, centered on desktop
 *
 * Accessibility (WCAG 2.1 AA):
 * - role="dialog", aria-label, aria-modal
 * - Escape key dismissal (NFR-006)
 * - Focus management: focus to close button on open, returns on close
 * - Semantic HTML with visible close button
 *
 * Traceability: AC-1.2 (opens), AC-1.4 (closes, focus), NFR-001 (keyboard),
 *              NFR-006 (dismissible), NFR-019 (no layout shift)
 */

interface Props {
  isOpen?: boolean;
  game?: {
    id: string;
    opponent: string;
    date: string; // ISO date string
    time: string; // Local time string (e.g., "7:00 PM") or null
    venue: string;
    homeOrAway: 'home' | 'away';
    status: 'upcoming' | 'completed' | 'cancelled';
    homeScore: number | null;
    awayScore: number | null;
  };
  onClose?: () => void;
}

const { isOpen = false, game, onClose } = Astro.props;

// Use placeholder game if none provided
const displayGame = game || ({
  id: 'placeholder',
  opponent: 'Loading...',
  date: '',
  time: null,
  venue: '',
  homeOrAway: 'home',
  status: 'upcoming',
  homeScore: null,
  awayScore: null,
});

// Format date function
const formatDate = (dateString: string) => {
  if (!dateString) return 'TBC';
  return new Date(dateString).toLocaleDateString('en-AU', {
    weekday: 'short',
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
};

// Format time function
const formatTime = (timeString: string | null) => {
  if (!timeString || timeString.trim() === '') {
    return 'TBC';
  }
  return timeString;
};

// Format score function
const formatScore = (homeScore: number | null, awayScore: number | null) => {
  if (homeScore === null || awayScore === null) {
    return 'TBC';
  }
  return `${homeScore} – ${awayScore}`;
};

// Determine result text and styling
const getResultInfo = () => {
  if (displayGame.status !== 'completed' || displayGame.homeScore === null || displayGame.awayScore === null) {
    return {
      text: 'Upcoming',
      class: 'bg-brand-gold text-white px-3 py-1 rounded-full text-xs font-bold'
    };
  }

  const isPhoenixHome = displayGame.homeOrAway === 'home';
  const phoenixScore = isPhoenixHome ? displayGame.homeScore : displayGame.awayScore;
  const opponentScore = isPhoenixHome ? displayGame.awayScore : displayGame.homeScore;

  if (phoenixScore > opponentScore) {
    return {
      text: 'Win',
      class: 'bg-brand-gold text-white px-3 py-1 rounded-full text-xs font-bold'
    };
  } else if (phoenixScore < opponentScore) {
    return {
      text: 'Loss',
      class: 'bg-gray-600 text-white px-3 py-1 rounded-full text-xs font-bold'
    };
  } else {
    return {
      text: 'Draw',
      class: 'bg-gray-400 text-white px-3 py-1 rounded-full text-xs font-bold'
    };
  }
};

const resultInfo = getResultInfo();

///

<!-- Backdrop -->
<div
  class="fixed inset-0 z-40 bg-black bg-opacity-50 transition-opacity duration-200 hidden"
  data-modal-backdrop
  role="presentation"
  aria-hidden="true"
/>

<!-- Modal Dialog -->
<div
  id="game-detail-modal"
  class="fixed inset-0 z-50 flex items-center justify-center overflow-y-auto p-4 duration-200 hidden"
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-label={`${displayGame.opponent} Game Details`}
>
  <div class="relative w-full max-w-md max-h-[90vh] overflow-y-auto rounded-lg bg-white shadow-lg">
    <!-- Close Button -->
    <button
      type="button"
      data-close-button
      class="absolute top-3 right-3 md:top-4 md:right-4 inline-flex items-center justify-center rounded-lg p-2 min-h-11 min-w-11 text-gray-400 hover:bg-gray-100 hover:text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-200"
      aria-label="Close game details"
    >
      <span class="sr-only">Close</span>
      <svg
        class="h-6 w-6"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Modal Content -->
    <div class="p-4 md:p-6">
      <!-- Modal Heading -->
      <h2 class="mb-4 text-xl md:text-2xl font-bold text-gray-900" data-modal-title>
        Game Details
      </h2>

      <!-- Game Info -->
      <div class="space-y-4">
        <div class="text-sm font-medium text-gray-500 mb-1">
          Opponent
        </div>
        <p class="text-2xl font-bold text-gray-900">
          {displayGame.opponent}
        </p>

        <div class="text-sm font-medium text-gray-500 mb-1">
          Date & Time
        </div>
        <p class="text-lg text-gray-700">
          {formatDate(displayGame.date)} • {formatTime(displayGame.time)}
        </p>

        <div class="text-sm font-medium text-gray-500 mb-1">
          Venue
        </div>
        <p class="text-lg text-gray-700">
          {displayGame.venue}
        </p>

        <div class="text-sm font-medium text-gray-500 mb-1">
          Home/Away
        </div>
        <p class="text-lg text-gray-700">
          {displayGame.homeOrAway === 'home' ? 'Home' : 'Away'}
        </p>

        <div class="text-sm font-medium text-gray-500 mb-1">
          Result
        </div>
        <p class="{resultInfo.class} text-lg font-bold">
          {resultInfo.text}
        </p>

        {#if displayGame.status === 'completed' && displayGame.homeScore !== null && displayGame.awayScore !== null#}
          <div class="mt-4 pt-3 border-t border-gray-200">
            <div class="text-sm font-medium text-gray-500 mb-1">
              Score Details
            </div>
            <div class="text-lg text-gray-700">
              Phoenix: {displayGame.homeOrAway === 'home' ? displayGame.homeScore : displayGame.awayScore} <br/>
              Opponent: {displayGame.homeOrAway === 'away' ? displayGame.homeScore : displayGame.awayScore}
            </div>
          </div>
        {/if}
      </div>
    </div>
  </div>
</div>

<style>
  /* Modal visibility states */
  #game-detail-modal {
    transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
    opacity: 0;
    visibility: hidden;
  }

  #game-detail-modal.hidden {
    opacity: 0;
    visibility: hidden;
  }

  #game-detail-modal[data-open="true"] {
    opacity: 1;
    visibility: visible;
  }

  #game-detail-modal[data-open="true"] > div {
    animation: fadeIn 200ms ease-in-out;
  }

  /* Backdrop visibility */
  [data-modal-backdrop] {
    transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
    opacity: 0;
    visibility: hidden;
  }

  [data-modal-backdrop].hidden {
    opacity: 0;
    visibility: hidden;
  }

  #game-detail-modal[data-open="true"] ~ [data-modal-backdrop],
  [data-modal-backdrop][data-open="true"] {
    opacity: 1;
    visibility: visible;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  // Get modal elements
  const modal = document.getElementById('game-detail-modal');
  const backdrop = document.querySelector('[data-modal-backdrop]');
  const closeButton = modal?.querySelector('[data-close-button]');
  
  // Initialize modal state from props
  const isOpen = JSON.parse('${String(isOpen)}');
  
  // Open/close modal based on isOpen prop
  function updateModalState() {
    if (isOpen) {
      modal.classList.remove('hidden');
      modal.setAttribute('data-open', 'true');
      backdrop.classList.remove('hidden');
      backdrop.setAttribute('data-open', 'true');
      
      // Focus on close button when modal opens
      requestAnimationFrame(() => {
        closeButton?.focus();
      });
    } else {
      modal.classList.add('hidden');
      modal.setAttribute('data-open', 'false');
      backdrop.classList.add('hidden');
      backdrop.setAttribute('data-open', 'false');
    }
  }
  
  // Initialize modal state
  updateModalState();
  
  // Close modal when clicking close button or backdrop
  closeButton?.addEventListener('click', () => {
    if (onClose) {
      onClose();
    }
  });
  
  backdrop?.addEventListener('click', () => {
    if (onClose) {
      onClose();
    }
  });
  
  // Close modal on Escape key
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
      if (onClose) {
        onClose();
      }
    }
  });
  
  // Trap focus inside modal
  const trapFocus = (element) => {
    const focusableElements = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
    const focusableEls = element.querySelectorAll(focusableElements);
    const firstFocusableEl = focusableEls[0];
    const lastFocusableEl = focusableEls[focusableEls.length - 1];
    
    element.addEventListener('keydown', function(e) {
      if (e.key === 'Tab') {
        if (e.shiftKey) { // shift + tab
          if (document.activeElement === firstFocusableEl) {
            e.preventDefault();
            lastFocusableEl.focus();
          }
        } else { // tab
          if (document.activeElement === lastFocusableEl) {
            e.preventDefault();
            firstFocusableEl.focus();
          }
        }
      }
      
      // Close on Escape (already handled above, but keeping for completeness)
      if (e.key === 'Escape') {
        if (onClose) {
          onClose();
        }
      }
    });
  };
  
  // Apply focus trapping when modal opens
  if (isOpen) {
    trapFocus(modal);
  }
</script>
</style>