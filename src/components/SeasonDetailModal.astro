---
/**
 * T008: SeasonDetailModal Component
 *
 * Renders a modal overlay with season registration costs and key dates.
 * Opens when a SeasonTile is clicked, closes on Escape or close button.
 *
 * Features:
 * - Fixed positioning (no layout shift when opening/closing)
 * - Backdrop with opacity (click to close, optional)
 * - RegistrationCostsCard rendered above KeyDatesSection
 * - Close button with aria-label and visible focus indicator
 * - Keyboard accessible: Escape to close, focus management
 * - Smooth fade-in/fade-out animation (300ms)
 * - Centered on desktop (max-w-2xl), full-width on mobile
 *
 * Accessibility (WCAG 2.1 AA):
 * - role="dialog", aria-label, aria-modal
 * - Escape key dismissal (NFR-006)
 * - Focus management: focus to close button on open, returns on close
 * - Semantic HTML with visible close button
 *
 * Traceability: AC-1.2 (opens), AC-1.4 (closes, focus), NFR-001 (keyboard),
 *              NFR-006 (dismissible), NFR-019 (no layout shift)
 */

import type { Season, KeyDate, RegistrationCost } from '../lib/seasons/types';
import RegistrationCostsCard from './RegistrationCostsCard.astro';
import KeyDatesSection from './KeyDatesSection.astro';

interface Props {
  isOpen?: boolean;
  season?: Season;
  onClose?: () => void;
  registrationCosts?: RegistrationCost[];
  keyDates?: KeyDate[];
}

const { isOpen = false, season, onClose, registrationCosts = [], keyDates = [] } = Astro.props;

// Use placeholder season if none provided
const displaySeason = season || ({
  id: 'placeholder',
  name: 'Loading...',
  role: 'current' as const,
  status: 'active' as const,
  startDate: '',
  endDate: '',
});

const modalAriaLabel = `${displaySeason.name} season details`;
---

<!-- Backdrop -->
<div
  class="fixed inset-0 z-40 bg-black bg-opacity-50 transition-opacity duration-300 hidden"
  data-modal-backdrop
  role="presentation"
  aria-hidden="true"
/>

<!-- Modal Dialog -->
<!-- Always rendered, but hidden/shown via CSS and data attributes -->
<div
  id="season-detail-modal"
  class="fixed inset-0 z-50 flex items-center justify-center overflow-y-auto p-4 duration-300 hidden"
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-label={modalAriaLabel}
>
  <div class="relative w-full max-w-lg md:max-w-2xl rounded-lg bg-white shadow-lg">
    <!-- Close Button -->
    <button
      type="button"
      data-close-button
      class="absolute top-3 right-3 md:top-4 md:right-4 inline-flex items-center justify-center rounded-lg p-2 min-h-11 min-w-11 text-gray-400 hover:bg-gray-100 hover:text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-200"
      aria-label="Close season details"
    >
      <span class="sr-only">Close</span>
      <svg
        class="h-6 w-6"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Modal Content -->
    <div class="p-4 md:p-8">
      <!-- Modal Heading -->
      <h2 class="mb-6 text-xl md:text-2xl font-bold text-gray-900" data-modal-title>
        {displaySeason.name} Details
      </h2>

      <!-- Registration Costs Card (rendered first) -->
      <div class="mb-6" data-modal-costs>
        {season && <RegistrationCostsCard season={season} registrationCosts={registrationCosts} />}
      </div>

      <!-- Key Dates Section (rendered below) -->
      <div class="mb-6" data-modal-dates>
        {season && <KeyDatesSection keyDates={keyDates} season={season} />}
      </div>
    </div>
  </div>
</div>

<style>
  /* Modal visibility states */
  #season-detail-modal {
    transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    opacity: 0;
    visibility: hidden;
  }

  #season-detail-modal.hidden {
    opacity: 0;
    visibility: hidden;
  }

  #season-detail-modal[data-open="true"] {
    opacity: 1;
    visibility: visible;
  }

  #season-detail-modal[data-open="true"] > div {
    animation: fadeIn 300ms ease-in-out;
  }

  /* Backdrop visibility */
  [data-modal-backdrop] {
    transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
    opacity: 0;
    visibility: hidden;
  }

  [data-modal-backdrop].hidden {
    opacity: 0;
    visibility: hidden;
  }

  #season-detail-modal[data-open="true"] ~ [data-modal-backdrop],
  [data-modal-backdrop][data-open="true"] {
    opacity: 1;
    visibility: visible;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
