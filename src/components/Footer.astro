---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-purple text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <div class="mb-4">
          <img
            src="/images/logos/phoenix-logo.png"
            alt="Phoenix United Basketball"
            class="h-16 w-auto"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
          />
          <div class="hidden w-16 h-16 rounded-full bg-brand-gold flex items-center justify-center flex-shrink-0 text-white font-bold text-lg leading-none">
            PU
          </div>
        </div>
        <p class="text-purple-200 text-sm leading-relaxed">
          Where Community Meets Competition. Proudly serving basketball in Bendigo.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-brand-gold font-bold text-sm uppercase tracking-wider mb-4">Contact Us</h3>
        <address class="not-italic space-y-2 text-sm text-purple-200">
          <p class="flex items-start gap-2">
            <span class="mt-0.5">📍</span>
            <span>
              C/- Bendigo Stadium<br />
              Inglis Street<br />
              West Bendigo VIC 3550
            </span>
          </p>
          <p class="flex items-center gap-2">
            <span>✉️</span>
            <a
              href="mailto:hello@bendigophoenix.org.au"
              class="hover:text-brand-gold transition-colors duration-150"
            >
              hello@bendigophoenix.org.au
            </a>
          </p>
        </address>
      </div>

      <!-- Follow Us -->
      <div>
        <h3 class="text-brand-gold font-bold text-sm uppercase tracking-wider mb-4">Follow Us</h3>
        <div class="space-y-2">
          <a
            href="https://facebook.com/phoenixunitedbasketball"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-purple-200 hover:text-brand-gold transition-colors duration-150"
          >
            <span>📘</span> Facebook
          </a>
          <a
            href="https://instagram.com/bendigophoenix"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-purple-200 hover:text-brand-gold transition-colors duration-150"
          >
            <span>📷</span> Instagram
          </a>
        </div>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-brand-gold font-bold text-sm uppercase tracking-wider mb-4">Newsletter</h3>
        <div id="eo-form-11c550ac-11dc-11f1-a2e0-ef681a07d4a5"></div>
        <div id="eo-fallback-newsletter" class="hidden">
          <p class="text-sm text-purple-200">
            Form unavailable. <a href="mailto:hello@bendigophoenix.org.au" class="underline hover:no-underline text-brand-gold">Email us to subscribe</a>
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-purple-700 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-purple-300 text-xs">
        &copy; Phoenix United Basketball Development Club Inc. 2003 - {currentYear} All rights reserved.
      </p>
      <p class="text-purple-400 text-xs">
        <a
          href="https://bendigobasketball.com.au/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-brand-gold transition-colors"
        >
          compete in the Bendigo Basketball Association
        </a>
      </p>
    </div>
  </div>

  <!-- Email Octopus Script -->
  <script async src="https://eomail5.com/form/11c550ac-11dc-11f1-a2e0-ef681a07d4a5.js" data-form="11c550ac-11dc-11f1-a2e0-ef681a07d4a5"></script>

  <!-- Fallback Detection: Show fallback if Email Octopus fails to load -->
  <script is:inline>
    (function() {
      const TIMEOUT_MS = 3000;
      const formContainer = document.getElementById('eo-form-11c550ac-11dc-11f1-a2e0-ef681a07d4a5');
      const fallbackDiv = document.getElementById('eo-fallback-newsletter');

      if (!formContainer || !fallbackDiv) return;

      setTimeout(() => {
        if (formContainer.children.length === 0 && !window.EmailOctopusAPI) {
          fallbackDiv.classList.remove('hidden');
          console.warn('Email Octopus form failed to load. Showing fallback.');
        }
      }, TIMEOUT_MS);
    })();
  </script>
</footer>
