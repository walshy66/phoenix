---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Seasons', href: '/seasons' },
  { label: 'Team', href: '/team' },
  { label: 'About', href: '/about' },
  { label: 'Get Involved', href: '/get-involved' },
  { label: 'Scores', href: '/scores' },
  { label: 'Contact', href: '/contact' },
];

const resourceLinks = [
  { label: 'Coaching Resources', href: '/coaching-resources' },
  { label: 'Player Resources', href: '/player-resources' },
];

const currentPath = Astro.url.pathname;
---

<nav class="bg-brand-purple shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-10 h-10 rounded-full bg-brand-gold flex items-center justify-center flex-shrink-0">
          <span class="text-white font-bold text-lg leading-none">P</span>
        </div>
        <div class="leading-tight">
          <span class="text-white font-bold text-sm tracking-widest uppercase block">BENDIGO</span>
          <span class="font-bold text-sm tracking-widest uppercase block" style="color: #8B7536;">PHOENIX</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 rounded text-sm font-medium transition-colors duration-150 ${
              currentPath === link.href
                ? 'text-brand-gold border-b-2 border-brand-gold'
                : 'text-white hover:text-brand-gold'
            }`}
          >
            {link.label}
          </a>
        ))}

        <!-- Resources dropdown -->
        <div class="relative">
          <button
            id="resources-btn"
            class={`px-3 py-2 rounded text-sm font-medium transition-colors duration-150 flex items-center gap-1 ${
              currentPath.includes('resources')
                ? 'text-brand-gold border-b-2 border-brand-gold'
                : 'text-white hover:text-brand-gold'
            }`}
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="resources-menu"
          >
            Resources
            <svg id="resources-chevron" class="w-4 h-4 transition-transform duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="resources-menu" class="absolute right-0 top-full mt-1 w-52 bg-white rounded shadow-lg py-1 hidden z-50">
            {resourceLinks.map(link => (
              <a
                href={link.href}
                class="block px-4 py-2 text-sm text-brand-black hover:bg-brand-offwhite hover:text-brand-purple transition-colors"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="hamburger"
        class="lg:hidden text-white p-2 rounded focus:outline-none focus:ring-2 focus:ring-brand-gold"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden bg-brand-purple border-t border-purple-700">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-3 py-2 rounded text-sm font-medium transition-colors duration-150 ${
            currentPath === link.href
              ? 'text-brand-gold font-bold'
              : 'text-white hover:text-brand-gold hover:bg-purple-800'
          }`}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-1 pb-1">
        <p class="px-3 py-1 text-xs text-purple-300 uppercase tracking-wider font-medium">Resources</p>
        {resourceLinks.map(link => (
          <a
            href={link.href}
            class="block px-3 py-2 rounded text-sm font-medium text-white hover:text-brand-gold hover:bg-purple-800 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  // Resources dropdown
  const resourcesBtn = document.getElementById('resources-btn');
  const resourcesMenu = document.getElementById('resources-menu');
  const resourcesChevron = document.getElementById('resources-chevron');

  resourcesBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !resourcesMenu?.classList.contains('hidden');
    resourcesMenu?.classList.toggle('hidden', isOpen);
    resourcesChevron?.classList.toggle('rotate-180', !isOpen);
    resourcesBtn.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!resourcesBtn?.contains(e.target as Node)) {
      resourcesMenu?.classList.add('hidden');
      resourcesChevron?.classList.remove('rotate-180');
      resourcesBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      mobileMenu?.classList.remove('open');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      hamburger.setAttribute('aria-expanded', 'false');
    } else {
      mobileMenu?.classList.add('open');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      hamburger.setAttribute('aria-expanded', 'true');
    }
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!hamburger?.contains(e.target as Node) && !mobileMenu?.contains(e.target as Node)) {
      mobileMenu?.classList.remove('open');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      hamburger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
