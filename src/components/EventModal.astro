---
// EventModal is rendered once on the page as a hidden container.
// It gets populated and shown/hidden via client-side JS.
---

<div id="event-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="relative mx-4">
    <!-- Close button (overlay) -->
    <button
      id="modal-close"
      class="absolute -top-10 right-0 rounded-full p-2 text-white hover:text-gray-300 transition-colors duration-200 z-10"
      aria-label="Close modal"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Image at 75% size for readability -->
    <img
      id="modal-image"
      src=""
      alt=""
      class="max-w-2xl max-h-[85vh] object-contain"
      onerror="this.onerror=null; this.src='/images/placeholder-event.jpg';"
    >
  </div>

  <!-- Hidden metadata for accessibility -->
  <h2 id="modal-title" class="sr-only"></h2>
  <div id="modal-metadata" class="sr-only">
    <span id="modal-date"></span>
    <span id="modal-category"></span>
    <span id="modal-time"></span>
    <span id="modal-location"></span>
    <span id="modal-description"></span>
  </div>
</div>

<script>
  const modal = document.getElementById('event-modal')!;
  const closeBtn = document.getElementById('modal-close')!;

  function openModal(event: Record<string, string>) {
    const formattedDate = new Date(event.date).toLocaleDateString('en-AU', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });

    // Set image and alt text
    const img = document.getElementById('modal-image') as HTMLImageElement;
    img.src = event.image;
    img.alt = event.alt || `${event.title} — ${formattedDate}`;

    // Update hidden metadata for accessibility
    document.getElementById('modal-title')!.textContent = event.title;
    document.getElementById('modal-date')!.textContent = formattedDate;
    document.getElementById('modal-category')!.textContent = event.category || '';
    document.getElementById('modal-time')!.textContent = event.time || '';
    document.getElementById('modal-location')!.textContent = event.location || '';
    document.getElementById('modal-description')!.textContent = event.description || '';

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // Close button
  closeBtn.addEventListener('click', closeModal);

  // Click backdrop to close
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });

  // Event tile clicks
  document.querySelectorAll('.event-tile[data-event]').forEach(tile => {
    tile.addEventListener('click', () => {
      const data = JSON.parse(tile.getAttribute('data-event')!);
      openModal(data);
    });
    tile.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        const data = JSON.parse(tile.getAttribute('data-event')!);
        openModal(data);
      }
    });
  });
</script>
