---
// EventModal is rendered once on the page as a hidden container.
// It gets populated and shown/hidden via client-side JS.
---

<div id="event-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="relative w-full max-w-2xl mx-4 max-h-[90vh]">
    <!-- Modal Content -->
    <div class="bg-white rounded-xl shadow-2xl max-h-[90vh] overflow-y-auto">
      <!-- Header -->
      <div class="flex items-center justify-between p-6 border-b border-gray-100">
        <div class="flex-1">
          <h2 id="modal-title" class="text-2xl font-bold text-brand-black"></h2>
          <span id="modal-category" class="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-offwhite text-brand-purple hidden"></span>
        </div>
        <button
          id="modal-close"
          class="rounded-full p-2 text-gray-400 hover:text-gray-600 transition-colors duration-200"
          aria-label="Close modal"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Image -->
      <div class="relative h-48">
        <img
          id="modal-image"
          src=""
          alt=""
          class="w-full h-full object-cover"
          onerror="this.onerror=null; this.src='/images/placeholder-event.jpg';"
        >
      </div>

      <!-- Details -->
      <div class="p-6 space-y-4">
        <div class="space-y-2">
          <p class="text-gray-600 text-sm">
            <span class="font-medium text-brand-black">Date:</span> <span id="modal-date"></span>
            <span id="modal-time-wrap" class="ml-4 hidden">• <span class="font-medium text-brand-black">Time:</span> <span id="modal-time"></span></span>
          </p>
          <p id="modal-location-wrap" class="text-gray-600 text-sm hidden">
            <span class="font-medium text-brand-black">Location:</span> <span id="modal-location"></span>
          </p>
        </div>

        <div id="modal-desc-wrap" class="space-y-2 hidden">
          <p class="font-medium text-brand-black mb-2">Description</p>
          <p id="modal-description" class="text-gray-700 leading-relaxed"></p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('event-modal')!;
  const closeBtn = document.getElementById('modal-close')!;

  function openModal(event: Record<string, string>) {
    const formattedDate = new Date(event.date).toLocaleDateString('en-AU', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });

    document.getElementById('modal-title')!.textContent = event.title;
    const img = document.getElementById('modal-image') as HTMLImageElement;
    img.src = event.image;
    img.alt = event.alt || `${event.title} — ${formattedDate}`;
    document.getElementById('modal-date')!.textContent = formattedDate;

    const catEl = document.getElementById('modal-category')!;
    if (event.category) { catEl.textContent = event.category; catEl.classList.remove('hidden'); }
    else { catEl.classList.add('hidden'); }

    const timeWrap = document.getElementById('modal-time-wrap')!;
    if (event.time) { document.getElementById('modal-time')!.textContent = event.time; timeWrap.classList.remove('hidden'); }
    else { timeWrap.classList.add('hidden'); }

    const locWrap = document.getElementById('modal-location-wrap')!;
    if (event.location) { document.getElementById('modal-location')!.textContent = event.location; locWrap.classList.remove('hidden'); }
    else { locWrap.classList.add('hidden'); }

    const descWrap = document.getElementById('modal-desc-wrap')!;
    if (event.description) { document.getElementById('modal-description')!.textContent = event.description; descWrap.classList.remove('hidden'); }
    else { descWrap.classList.add('hidden'); }

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // Close button
  closeBtn.addEventListener('click', closeModal);

  // Click backdrop to close
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });

  // Event tile clicks
  document.querySelectorAll('.event-tile[data-event]').forEach(tile => {
    tile.addEventListener('click', () => {
      const data = JSON.parse(tile.getAttribute('data-event')!);
      openModal(data);
    });
    tile.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        const data = JSON.parse(tile.getAttribute('data-event')!);
        openModal(data);
      }
    });
  });
</script>
