---
import { renderHomeGamesStateHtml } from '../lib/playhq/renderers';

interface HomeGameItem {
  gameId: string;
  homeTeam: string;
  awayTeam: string;
  homeScore: number | null;
  awayScore: number | null;
  status: string;
  kickoffDate: string | null;
  kickoffTime?: string | null;
  kickoffDisplay: string;
  competition: string | null;
  venue?: string | null;
  court?: string | null;
}

interface HomeGamesArtifact {
  status: 'success' | 'stale' | 'error';
  staleBanner?: string | null;
  error?: { code?: string; message?: string } | null;
  generatedAt?: string;
  games: HomeGameItem[];
}

interface Props {
  artifact: HomeGamesArtifact;
  autoAdvanceMs?: number;
  resumeDelayMs?: number;
  liveRefreshMs?: number;
  liveDataUrl?: string;
}

const {
  artifact,
  autoAdvanceMs = 7000,
  resumeDelayMs = 10000,
  liveRefreshMs = 300000,
  liveDataUrl = '/live-data/home-games.json',
} = Astro.props;
---

<section class="py-8 bg-brand-black" aria-label="Latest Results">
  <div class="max-w-7xl mx-auto px-4 mb-4 flex items-center justify-between gap-3">
    <h2 class="text-white text-sm font-bold uppercase tracking-widest flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-brand-gold inline-block animate-pulse"></span>
      Latest Results
    </h2>
    <a href="/scores" class="text-brand-gold text-xs font-bold hover:underline focus-visible:outline-2 focus-visible:outline-brand-gold">
      View All Scores →
    </a>
  </div>

  <div
    class="home-scores-root"
    data-home-scores-root
    data-live-data-url={liveDataUrl}
    data-auto-advance-ms={autoAdvanceMs}
    data-resume-delay-ms={resumeDelayMs}
    data-live-refresh-ms={liveRefreshMs}
    data-stale-threshold-minutes="15"
    set:html={renderHomeGamesStateHtml(artifact)}
  ></div>
</section>

<style>
</style>

<script>
  import { getInitialCarouselIndex, getMaxCarouselIndex, getNextIndex, getPrevIndex, getSlidesPerView } from '../lib/home-scores/carousel';
  import { validateLiveHomeGamesPayload } from '../lib/playhq/contracts';
  import { isLiveDataStale } from '../lib/playhq/live-data';
  import { renderHomeGamesStateHtml } from '../lib/playhq/renderers';

  const carouselState = new WeakMap();

  function bootstrapCarousel(root) {
    const existing = carouselState.get(root);
    if (existing) {
      if (existing.autoTimer) clearInterval(existing.autoTimer);
      if (existing.resumeTimer) clearTimeout(existing.resumeTimer);
      if (existing.resizeHandler) window.removeEventListener('resize', existing.resizeHandler);
    }

    const track = root.querySelector('.home-scores-track');
    const prevBtn = root.querySelector('.hs-prev');
    const nextBtn = root.querySelector('.hs-next');
    const carousel = root.querySelector('.home-scores-carousel');

    const count = Number(carousel?.getAttribute('data-count') ?? '0');
    if (!track || count <= 0) {
      carouselState.set(root, { autoTimer: null, resumeTimer: null, resizeHandler: null });
      return;
    }

    const autoAdvanceMs = Number(root.getAttribute('data-auto-advance-ms') ?? '7000');
    const resumeDelayMs = Number(root.getAttribute('data-resume-delay-ms') ?? '10000');

    const state = {
      index: 0,
      autoTimer: null,
      resumeTimer: null,
      resizeHandler: null,
    };

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const slideDates = Array.from(root.querySelectorAll('.home-slide')).map((slide) => slide.getAttribute('data-kickoff-date'));

    const getViewportState = () => {
      const slidesPerView = getSlidesPerView(window.innerWidth);
      const maxIndex = getMaxCarouselIndex(count, slidesPerView);
      return { slidesPerView, maxIndex };
    };

    const updateNavButtons = () => {
      const { maxIndex } = getViewportState();
      const disabled = maxIndex === 0;
      if (prevBtn) {
        prevBtn.disabled = disabled;
        prevBtn.setAttribute('aria-disabled', String(disabled));
      }
      if (nextBtn) {
        nextBtn.disabled = disabled;
        nextBtn.setAttribute('aria-disabled', String(disabled));
      }
    };

    const render = () => {
      const { slidesPerView, maxIndex } = getViewportState();
      state.index = Math.min(state.index, maxIndex);
      const shiftPercent = slidesPerView > 0 ? 100 / slidesPerView : 100;
      track.style.transform = `translateX(-${state.index * shiftPercent}%)`;
      updateNavButtons();
    };

    const stopAuto = () => {
      if (state.autoTimer) {
        clearInterval(state.autoTimer);
        state.autoTimer = null;
      }
    };

    const startAuto = () => {
      const { maxIndex, slidesPerView } = getViewportState();
      if (reducedMotion || maxIndex === 0) return;
      stopAuto();
      state.autoTimer = setInterval(() => {
        state.index = getNextIndex(state.index, count, slidesPerView);
        render();
      }, autoAdvanceMs);
    };

    const pauseThenResume = () => {
      stopAuto();
      if (state.resumeTimer) clearTimeout(state.resumeTimer);
      state.resumeTimer = setTimeout(() => startAuto(), resumeDelayMs);
    };

    prevBtn?.addEventListener('click', () => {
      const { slidesPerView } = getViewportState();
      state.index = getPrevIndex(state.index, count, slidesPerView);
      render();
      pauseThenResume();
    });

    nextBtn?.addEventListener('click', () => {
      const { slidesPerView } = getViewportState();
      state.index = getNextIndex(state.index, count, slidesPerView);
      render();
      pauseThenResume();
    });

    if (!root.dataset.homeCarouselKeydownAttached) {
      root.addEventListener('keydown', (e) => {
        const { slidesPerView } = getViewportState();
        if (e.key === 'ArrowRight') {
          state.index = getNextIndex(state.index, count, slidesPerView);
          render();
          pauseThenResume();
        }
        if (e.key === 'ArrowLeft') {
          state.index = getPrevIndex(state.index, count, slidesPerView);
          render();
          pauseThenResume();
        }
      });
      root.dataset.homeCarouselKeydownAttached = 'true';
    }

    const { slidesPerView } = getViewportState();
    state.index = getInitialCarouselIndex(slideDates, slidesPerView, new Date());

    state.resizeHandler = () => render();
    window.addEventListener('resize', state.resizeHandler);

    render();
    startAuto();
    carouselState.set(root, state);
  }

  async function refreshHomeScores(root) {
    const url = root.getAttribute('data-live-data-url');
    if (!url) return;

    try {
      const [homeResponse, liveResponse] = await Promise.all([
        fetch(url, { cache: 'no-store' }),
        fetch('/live-data/live-scores.json', { cache: 'no-store' }),
      ]);

      if (!homeResponse.ok) return;

      const payload = await homeResponse.json();
      const validation = validateLiveHomeGamesPayload(payload);
      if (!validation.ok) return;

      let liveScores = {};
      if (liveResponse.ok) {
        try {
          liveScores = await liveResponse.json();
        } catch {
          liveScores = {};
        }
      }

      if (liveScores && typeof liveScores === 'object') {
        payload.games = payload.games.map((game) => {
          const live = liveScores[game.gameId];
          if (!live) return game;
          return {
            ...game,
            homeScore: typeof live.homeScore === 'number' ? live.homeScore : game.homeScore,
            awayScore: typeof live.awayScore === 'number' ? live.awayScore : game.awayScore,
            status: 'live',
          };
        });
      }

      const staleThresholdMinutes = Number(root.getAttribute('data-stale-threshold-minutes') ?? '15');
      if (payload.generatedAt && isLiveDataStale(payload.generatedAt, staleThresholdMinutes)) {
        payload.status = payload.status === 'error' ? 'error' : 'stale';
      }

      root.innerHTML = renderHomeGamesStateHtml(payload);
      bootstrapCarousel(root);
    } catch {
      // Keep the last rendered state if refresh fails.
    }
  }

  document.querySelectorAll('[data-home-scores-root]').forEach((root) => {
    bootstrapCarousel(root);

    const refreshMs = Number(root.getAttribute('data-live-refresh-ms') ?? '300000');
    refreshHomeScores(root);
    setInterval(() => refreshHomeScores(root), refreshMs);
  });
</script>
