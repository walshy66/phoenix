---
interface Props {
  id: string
  label: string
  icon: string
  description: string
  ariaLabel: string
}

const { id, label, icon, description, ariaLabel } = Astro.props
---

<button
  type="button"
  data-modal-id={id}
  aria-label={ariaLabel}
  class="rounded-xl border-2 border-gray-200 bg-white p-6 text-center shadow-sm transition-all duration-200 hover:border-brand-purple hover:shadow-md focus-visible:ring-2 focus-visible:ring-brand-purple focus-visible:ring-offset-2 min-h-[120px] md:min-h-[140px]"
>
  <div class="mb-3 text-4xl leading-none" aria-hidden="true">{icon}</div>
  <h3 class="mb-2 text-center text-base font-bold text-gray-900">{label}</h3>
  <p class="text-sm text-gray-600">{description}</p>
</button>
