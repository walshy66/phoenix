---
import type { SeasonInfoCard } from '../data/season-info'
import type { Venue } from '../data/venues'

interface Props {
  card: SeasonInfoCard
  venues: Venue[]
}

const { card, venues } = Astro.props

const getSubCardGridClasses = () => {
  if (card.id === 'training') {
    return 'grid grid-cols-1 gap-6 justify-items-center sm:grid-cols-2'
  }
  if (card.id === 'uniforms' || card.id === 'registration') {
    return 'grid grid-cols-1 gap-8 justify-items-center 2xl:grid-cols-2'
  }
  if (card.id === 'clearances') {
    return 'flex justify-center'
  }
  return 'grid grid-cols-1 gap-6'
}
---

<div
  id={`season-info-modal-${card.id}`}
  class="fixed inset-0 z-[70] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`season-info-modal-title-${card.id}`}
  data-open="false"
>
  <div class="absolute inset-0 bg-black/15" aria-hidden="true" data-modal-backdrop></div>

  <div class="relative z-10 flex h-full w-full items-center justify-center md:p-4">
    <div class={`flex h-full w-full flex-col overflow-hidden bg-brand-offwhite md:h-auto md:max-h-[90vh] md:w-[95vw] md:rounded-xl md:shadow-xl ${card.id === 'training' ? 'md:max-w-3xl' : card.id === 'clearances' ? 'md:max-w-4xl' : 'md:max-w-[1400px]'}`}>
      <header class="flex items-center justify-between gap-3 border-b border-gray-200 bg-white px-4 py-3 md:px-6">
        <h2 id={`season-info-modal-title-${card.id}`} class="text-lg font-black uppercase tracking-tight text-brand-black md:text-xl">
          {card.modalTitle}
        </h2>
        <button
          type="button"
          data-close-btn
          aria-label={`Close ${card.modalTitle}`}
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md text-brand-purple transition-colors hover:bg-purple-50 focus:outline-none focus:ring-2 focus:ring-brand-purple focus:ring-offset-2"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </header>

      <div class={`overflow-y-auto p-4 md:p-6 ${getSubCardGridClasses()}`}>
        {card.id === 'training' &&
          venues.map((venue) => (
            <div class="h-full w-full max-w-[320px] rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
              <h3 class="mb-1 text-lg font-semibold text-brand-purple">{venue.name}</h3>
              <p class="mb-1 font-mono text-sm text-gray-500">
                {venue.shortCode}
                {venue.labelSuffix && <span class="ml-2 font-sans text-xs font-semibold uppercase tracking-wide text-gray-500">({venue.labelSuffix})</span>}
              </p>
              <p class="mb-4 text-sm text-gray-700">{venue.address}</p>

              <div class="mb-4 border-t border-gray-100 pt-4">
                <p class="mb-2 text-xs font-bold uppercase tracking-wide text-gray-500">Who trains when</p>
                {venue.trainingSchedule.map((session) => (
                  <div class="mb-3 rounded-md bg-brand-offwhite/40 p-3">
                    <p class="mb-2 text-sm font-semibold text-brand-purple">{session.day}</p>
                    <ul class="space-y-2">
                      {session.timeSlots.map((slot) => (
                        <li class="grid grid-cols-[88px_1fr] gap-3 text-sm">
                          <p class="font-semibold text-gray-900">{slot.time}</p>
                          <p class="text-gray-700">{slot.ageGroups.join(', ')}</p>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              {venue.mapUrl && (
                venue.mapEmbedSrc ? (
                  <a
                    href={venue.mapUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Open map for ${venue.name} in a new tab`}
                    class="mt-4 block overflow-hidden rounded-lg border border-gray-200 bg-gray-100 shadow-sm transition-opacity hover:opacity-95"
                  >
                    <div class="relative aspect-[4/3] w-full bg-gray-100">
                      <iframe
                        src={venue.mapEmbedSrc}
                        title={`Map preview for ${venue.name}`}
                        loading="lazy"
                        class="pointer-events-none h-full w-full"
                        referrerpolicy="no-referrer-when-downgrade"
                        allowfullscreen
                      ></iframe>
                      <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-2 bg-white/95 px-4 py-3 backdrop-blur-sm">
                        <span class="text-sm font-semibold text-brand-purple">View map</span>
                        <span class="text-xs font-medium text-gray-500">Tap to open</span>
                      </div>
                    </div>
                  </a>
                ) : venue.mapImageSrc ? (
                  <a
                    href={venue.mapUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Open map for ${venue.name} in a new tab`}
                    class="mt-4 block overflow-hidden rounded-lg border border-gray-200 bg-gray-100 shadow-sm transition-opacity hover:opacity-95"
                  >
                    <img
                      src={venue.mapImageSrc}
                      alt={venue.mapImageAlt ?? `Map preview for ${venue.name}`}
                      loading="lazy"
                      width="640"
                      height="360"
                      class="h-auto w-full object-cover"
                    />
                    <div class="flex items-center justify-between gap-2 bg-white px-4 py-3">
                      <span class="text-sm font-semibold text-brand-purple">View map</span>
                      <span class="text-xs font-medium text-gray-500">Tap to open</span>
                    </div>
                  </a>
                ) : (
                  <a
                    href={venue.mapUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex min-h-[44px] items-center py-3 text-sm text-brand-purple underline"
                  >
                    View on map
                  </a>
                )
              )}
            </div>
          ))}

        {card.id === 'uniforms' &&
          card.subCards.map((subCard) => (
            <div class="h-full w-full max-w-[960px] 2xl:max-w-[640px] overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
              <div class="flex min-h-[500px] 2xl:min-h-[360px] items-center justify-center overflow-hidden bg-gray-100">
                {subCard.linkUrl ? (
                  <a
                    href={subCard.linkUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={subCard.linkLabel ?? `Open ${subCard.title} in a new tab`}
                    class="block h-full w-full cursor-pointer transition-opacity hover:opacity-95"
                  >
                    <img
                      src={subCard.imageSrc}
                      alt={subCard.imageAlt}
                      loading="lazy"
                      width="1400"
                      height="780"
                      class="h-full w-full object-cover"
                      onerror="this.classList.add('hidden'); this.parentElement.nextElementSibling?.classList.remove('hidden')"
                    />
                    <div class="hidden p-4 text-center text-xs text-gray-600" aria-live="polite">
                      Image unavailable
                    </div>
                  </a>
                ) : (
                  <button
                    type="button"
                    data-infographic-zoom-trigger
                    data-zoom-src={subCard.imageSrc}
                    data-zoom-alt={subCard.imageAlt}
                    aria-label={`Enlarge ${subCard.title} infographic`}
                    class="h-full w-full cursor-zoom-in"
                  >
                    <img
                      src={subCard.imageSrc}
                      alt={subCard.imageAlt}
                      loading="lazy"
                      width="1400"
                      height="780"
                      class="h-full w-full object-cover"
                      onerror="this.classList.add('hidden'); this.nextElementSibling?.classList.remove('hidden')"
                    />
                    <div class="hidden p-4 text-center text-xs text-gray-600" aria-live="polite">
                      Image unavailable
                    </div>
                  </button>
                )}
              </div>
            </div>
          ))}

        {card.id === 'registration' &&
          card.subCards.map((subCard) => (
            <div class={`h-full w-full max-w-[960px] 2xl:max-w-[640px] overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm ${subCard.id === 'registration-fee-breakdown' ? '2xl:col-span-2 2xl:justify-self-center' : ''}`}>
              <div class="relative flex min-h-[500px] 2xl:min-h-[360px] items-center justify-center overflow-hidden bg-gray-100">
                {subCard.linkUrl ? (
                  <a
                    href={subCard.linkUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={subCard.linkLabel ?? `Open ${subCard.title} in a new tab`}
                    class="block h-full w-full cursor-pointer transition-opacity hover:opacity-95"
                  >
                    <img
                      src={subCard.imageSrc}
                      alt={subCard.imageAlt}
                      loading="lazy"
                      width="1400"
                      height="780"
                      class="h-full w-full object-cover"
                      onerror="this.classList.add('hidden'); this.parentElement.nextElementSibling?.classList.remove('hidden')"
                    />
                    <div class="hidden p-4 text-center text-xs text-gray-600" aria-live="polite">
                      Image unavailable
                    </div>
                  </a>
                ) : (
                  <button
                    type="button"
                    data-infographic-zoom-trigger
                    data-zoom-src={subCard.imageSrc}
                    data-zoom-alt={subCard.imageAlt}
                    aria-label={`Enlarge ${subCard.title} infographic`}
                    class="h-full w-full cursor-zoom-in"
                  >
                    <img
                      src={subCard.imageSrc}
                      alt={subCard.imageAlt}
                      loading="lazy"
                      width="1400"
                      height="780"
                      class="h-full w-full object-cover"
                      onerror="this.classList.add('hidden'); this.nextElementSibling?.classList.remove('hidden')"
                    />
                    <div class="hidden p-4 text-center text-xs text-gray-600" aria-live="polite">
                      Image unavailable
                    </div>
                  </button>
                )}
                <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
                  <span class="-rotate-[24deg] rounded-md border-4 border-red-700/55 bg-white/35 px-8 py-2 text-2xl font-black uppercase tracking-[0.2em] text-red-800/60 sm:text-3xl">
                    Closed
                  </span>
                </div>
              </div>
            </div>
          ))}

        {card.id === 'clearances' &&
          card.subCards.map((subCard) => (
            <div class="w-full max-w-[760px] overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
              <div class="flex items-center justify-center overflow-hidden bg-gray-100">
                {subCard.linkUrl ? (
                  <a
                    href={subCard.linkUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={subCard.linkLabel ?? `Open ${subCard.title} in a new tab`}
                    class="block h-full w-full cursor-pointer transition-opacity hover:opacity-95"
                  >
                    <img
                      src={subCard.imageSrc}
                      alt={subCard.imageAlt}
                      loading="lazy"
                      width="1400"
                      height="780"
                      class="h-full w-full object-cover"
                      onerror="this.classList.add('hidden'); this.parentElement.nextElementSibling?.classList.remove('hidden')"
                    />
                    <div class="hidden p-4 text-center text-xs text-gray-600" aria-live="polite">
                      Image unavailable
                    </div>
                  </a>
                ) : (
                  <button
                    type="button"
                    data-infographic-zoom-trigger
                    data-zoom-src={subCard.imageSrc}
                    data-zoom-alt={subCard.imageAlt}
                    aria-label={`Enlarge ${subCard.title} infographic`}
                    class="h-full w-full cursor-zoom-in"
                  >
                    <img
                      src={subCard.imageSrc}
                      alt={subCard.imageAlt}
                      loading="lazy"
                      width="1400"
                      height="780"
                      class="h-full w-full object-cover"
                      onerror="this.classList.add('hidden'); this.nextElementSibling?.classList.remove('hidden')"
                    />
                    <div class="hidden p-4 text-center text-xs text-gray-600" aria-live="polite">
                      Image unavailable
                    </div>
                  </button>
                )}
              </div>
            </div>
          ))}

        {card.id === 'uniforms' && (
          <div class="col-span-full flex justify-center">
            <a
              href="https://www.stepinsports.com.au/product-category/phoenix-basketball/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-[44px] items-center justify-center rounded-lg bg-brand-purple px-6 py-3 text-sm font-bold text-white transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-brand-purple focus:ring-offset-2"
            >
              Order uniform here with Step In Sports
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</div>
