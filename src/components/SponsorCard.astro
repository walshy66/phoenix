---
interface Sponsor {
  id: string;
  name: string;
  logo: string;
  link?: string | null;
  joinedDate: string;
}

interface Props {
  sponsor: Sponsor;
  layout?: 'grid' | 'carousel';
  isFirstSponsor?: boolean;
}

const { sponsor, layout = 'grid', isFirstSponsor = false } = Astro.props as Props;

function isValidExternalUrl(value: string | null | undefined): boolean {
  if (!value) return false;

  try {
    const url = new URL(value);
    return url.protocol === 'http:' || url.protocol === 'https:';
  } catch {
    return false;
  }
}

const hasLink = isValidExternalUrl(sponsor.link);
const loading = isFirstSponsor ? 'eager' : 'lazy';
const loadingMode = isFirstSponsor ? 'auto' : 'async';
const cardSize = layout === 'carousel'
  ? 'h-36 w-[240px] sm:w-[260px] lg:w-[280px] flex-shrink-0 p-2 sm:p-3'
  : 'h-24 w-full p-1';
const imageSize = layout === 'carousel'
  ? 'h-full w-full'
  : 'h-full w-full p-1';
---

<div
  class={`rounded-lg border border-gray-200 bg-white shadow-sm ${cardSize}`}
  data-testid={`sponsor-card-${sponsor.id}`}
>
  {hasLink ? (
    <a
      href={sponsor.link ?? '#'}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Visit ${sponsor.name} (opens in new tab)`}
      class="group flex h-full w-full items-center justify-center rounded-md outline-none transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-purple"
    >
      <span class="sponsor-fallback hidden text-center text-xs font-semibold text-gray-500">
        {sponsor.name}
      </span>
      <img
        src={sponsor.logo}
        alt={`${sponsor.name} logo`}
        loading={loading}
        decoding={loadingMode}
        class={`block h-auto w-auto object-contain object-center ${imageSize}`}
        onerror="this.hidden=true; this.previousElementSibling?.classList.remove('hidden');"
      />
    </a>
  ) : (
    <div class="flex h-full w-full items-center justify-center rounded-md outline-none">
      <span class="sponsor-fallback hidden text-center text-xs font-semibold text-gray-500">
        {sponsor.name}
      </span>
      <img
        src={sponsor.logo}
        alt={`${sponsor.name} logo`}
        loading={loading}
        decoding={loadingMode}
        class={`block h-auto w-auto object-contain object-center ${imageSize}`}
        onerror="this.hidden=true; this.previousElementSibling?.classList.remove('hidden');"
      />
    </div>
  )}
</div>
