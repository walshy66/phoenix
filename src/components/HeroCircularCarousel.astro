---
/**
 * HeroCircularCarousel — portrait-format circular card carousel.
 *
 * Replaces the old HeroCarousel (landscape X-axis flip).
 * New interaction: Y-axis rotation with opacity fade.
 *   - Next: current card rotates out to the right (rotateY 0→90deg), next card rotates in from the left (rotateY -90→0deg)
 *   - Prev: current card rotates out to the left (rotateY 0→-90deg), prev card rotates in from the right (rotateY 90→0deg)
 *
 * Features:
 *   - Portrait-format slides (3:4 aspect ratio, prominent size)
 *   - CSS 3D Y-axis rotation with opacity fade (simultaneous exit/enter)
 *   - Click queue: clicks during animation are queued, not dropped
 *   - Buttons always enabled (never disabled during animation)
 *   - Touch swipe support (45px minimum threshold)
 *   - Keyboard navigation (arrow keys)
 *   - prefers-reduced-motion fallback (fade-only, 150ms)
 *   - Bendigo Phoenix logo as background decal
 *   - Auto-advance (optional, disabled by default)
 *
 * Slide shape: { image, alt, bgColor? }
 */

interface Slide {
  image: string;       // Image URL (required; portrait infographic)
  alt: string;         // Alt text for accessibility (required)
  bgColor?: string;    // Fallback background color (optional, default: #1a1030)
}

interface Props {
  slides: Slide[];
  autoAdvanceMs?: number;
  autoAdvanceEnabled?: boolean;
}

const {
  slides,
  autoAdvanceMs = 8000,
  autoAdvanceEnabled = false,
} = Astro.props;

const count = slides.length;
const showNav = count >= 2;
---

<div
  class="hero-circular-carousel"
  data-count={count}
  data-interval={autoAdvanceMs}
  data-auto-advance={autoAdvanceEnabled ? 'true' : 'false'}
  aria-label="Bendigo Phoenix highlights"
  aria-roledescription="carousel"
>
  <!-- Background logo decal (static, behind slides) -->
  <div class="logo-decal" aria-hidden="true">
    <img
      src="/images/phoenix-united-logo.png"
      alt=""
      class="logo-decal-img"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Carousel viewport with perspective for 3D transforms -->
  <div class="carousel-container">
    <div class="carousel-viewport" aria-live="polite">

      {slides.map((slide, i) => (
        <div
          class={`carousel-slide${i === 0 ? ' is-active' : ''}`}
          data-slide={i}
          role="group"
          aria-roledescription="slide"
          aria-label={`Slide ${i + 1} of ${count}`}
          aria-hidden={i !== 0 ? 'true' : 'false'}
          style={`background-color: ${slide.bgColor ?? '#1a1030'};`}
        >
          <img
            src={slide.image}
            alt={slide.alt}
            class="slide-img"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))}

    </div>

    <!-- Navigation buttons (only rendered if 2+ slides) -->
    {showNav && (
      <button
        class="carousel-arrow carousel-prev"
        aria-label="Previous slide"
        type="button"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
    )}

    {showNav && (
      <button
        class="carousel-arrow carousel-next"
        aria-label="Next slide"
        type="button"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    )}
  </div>

  <!-- Slide indicators (dots) -->
  {showNav && (
    <div class="carousel-dots" role="tablist" aria-label="Slide indicators">
      {slides.map((_, i) => (
        <button
          class={`carousel-dot${i === 0 ? ' is-active' : ''}`}
          data-dot={i}
          role="tab"
          aria-label={`Go to slide ${i + 1}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          type="button"
        />
      ))}
    </div>
  )}
</div>

<style>
  /* ── Outer container ─────────────────────────────────────── */
  .hero-circular-carousel {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  /* ── Background logo decal ───────────────────────────────── */
  .logo-decal {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .logo-decal-img {
    width: clamp(200px, 60%, 400px);
    height: auto;
    opacity: 0.08;
    filter: grayscale(100%) brightness(2);
    user-select: none;
  }

  /* ── Carousel container — perspective for 3D transforms ──── */
  .carousel-container {
    position: relative;
    width: clamp(280px, 90vw, 420px);
    z-index: 1;
  }

  /* ── Viewport — 3:4 portrait aspect ratio ────────────────── */
  .carousel-viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 16px;
    perspective: 1200px;
    perspective-origin: 50% 50%;
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(139, 117, 54, 0.2);
  }

  /* ── Slides — absolutely stacked ─────────────────────────── */
  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    z-index: 1;
    pointer-events: none;
    backface-visibility: hidden;
    will-change: transform, opacity;
    transform-origin: center center;
    border-radius: 16px;
  }

  .carousel-slide.is-active {
    opacity: 1;
    z-index: 2;
    pointer-events: auto;
    transform: rotateY(0deg);
  }

  /* ── Slide image ──────────────────────────────────────────── */
  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  /* ── CSS 3D Rotation keyframes ───────────────────────────── */

  /* Exit to the right (current slide going out when clicking "next") */
  @keyframes rotateOutRight {
    from { transform: rotateY(0deg);   opacity: 1; }
    to   { transform: rotateY(90deg);  opacity: 0; }
  }

  /* Exit to the left (current slide going out when clicking "prev") */
  @keyframes rotateOutLeft {
    from { transform: rotateY(0deg);   opacity: 1; }
    to   { transform: rotateY(-90deg); opacity: 0; }
  }

  /* Enter from the left (new slide coming in when clicking "next") */
  @keyframes rotateInFromLeft {
    from { transform: rotateY(-90deg); opacity: 0; }
    to   { transform: rotateY(0deg);   opacity: 1; }
  }

  /* Enter from the right (new slide coming in when clicking "prev") */
  @keyframes rotateInFromRight {
    from { transform: rotateY(90deg);  opacity: 0; }
    to   { transform: rotateY(0deg);   opacity: 1; }
  }

  /* Exit animation classes */
  .animate-rotate-out-right {
    animation: rotateOutRight 350ms cubic-bezier(0.55, 0.085, 0.68, 0.53) forwards;
  }
  .animate-rotate-out-left {
    animation: rotateOutLeft 350ms cubic-bezier(0.55, 0.085, 0.68, 0.53) forwards;
  }

  /* Enter animation classes */
  .animate-rotate-in-from-left {
    animation: rotateInFromLeft 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  .animate-rotate-in-from-right {
    animation: rotateInFromRight 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  /* ── Reduced-motion fallback ─────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    @keyframes fadeOut {
      from { opacity: 1; }
      to   { opacity: 0; }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    .animate-rotate-out-right,
    .animate-rotate-out-left {
      animation: fadeOut 150ms ease-in-out forwards;
    }

    .animate-rotate-in-from-left,
    .animate-rotate-in-from-right {
      animation: fadeIn 150ms ease-in-out forwards;
    }
  }

  /* ── Navigation arrows ───────────────────────────────────── */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(139, 117, 54, 0.55);
    background: rgba(26, 16, 48, 0.7);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.15s, opacity 0.15s;
    backdrop-filter: blur(6px);
    outline-offset: 3px;
  }

  .carousel-arrow:hover {
    background: #8B7536;
    border-color: #8B7536;
    transform: translateY(-50%) scale(1.08);
  }

  .carousel-arrow:focus-visible {
    outline: 2px solid #8B7536;
    outline-offset: 3px;
  }

  .carousel-arrow:active {
    opacity: 0.75;
    transform: translateY(-50%) scale(0.96);
  }

  .carousel-prev { left: -22px; }
  .carousel-next { right: -22px; }

  @media (max-width: 520px) {
    .carousel-prev { left: 8px; }
    .carousel-next { right: 8px; }
  }

  /* ── Dot indicators ──────────────────────────────────────── */
  .carousel-dots {
    display: flex;
    gap: 8px;
    align-items: center;
    z-index: 1;
  }

  .carousel-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: rgba(255, 255, 255, 0.25);
    cursor: pointer;
    transition: background 0.25s, transform 0.25s, width 0.25s;
    outline-offset: 3px;
  }

  .carousel-dot:focus-visible {
    outline: 2px solid #8B7536;
  }

  .carousel-dot.is-active {
    background: #8B7536;
    transform: scale(1.3);
    width: 24px;
    border-radius: 5px;
  }
</style>

<script>
  // Animation timing constants (matches CSS keyframe durations)
  // Exit and enter run simultaneously; total window is 600ms per spec AC-3 (600–800ms)
  const EXIT_DURATION    = 350;  // ms — matches rotateOut keyframe duration
  const ENTER_DURATION   = 350;  // ms — simultaneous with exit (same duration)
  const TOTAL_DURATION   = Math.max(EXIT_DURATION, ENTER_DURATION) + 250; // 600ms — within spec 600–800ms window
  const REDUCED_DURATION = 150;  // ms — per-phase for prefers-reduced-motion fade

  document.querySelectorAll<HTMLElement>('.hero-circular-carousel').forEach(carousel => {
    const count    = parseInt(carousel.dataset.count    ?? '1', 10);
    const interval = parseInt(carousel.dataset.interval ?? '8000', 10);
    const autoAdv  = carousel.dataset.autoAdvance === 'true';

    const slides   = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-slide'));
    const dots     = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-dot'));
    const prevBtn  = carousel.querySelector<HTMLButtonElement>('.carousel-prev');
    const nextBtn  = carousel.querySelector<HTMLButtonElement>('.carousel-next');

    // State
    let currentSlide  = 0;
    let isAnimating   = false;
    const queue: string[] = [];
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    // Detect reduced motion preference
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const totalDuration = reducedMotion ? REDUCED_DURATION + 50 : TOTAL_DURATION;

    // ── Slide routing ──────────────────────────────────────────────
    function nextIndex(): number {
      return (currentSlide + 1) % count;
    }

    function prevIndex(): number {
      return ((currentSlide - 1) % count + count) % count;
    }

    // ── DOM updates ────────────────────────────────────────────────
    function updateDots(index: number) {
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === index);
        d.setAttribute('aria-selected', String(i === index));
      });
    }

    // ── Animation execution ────────────────────────────────────────
    function goTo(nextIdx: number, direction: 'next' | 'prev') {
      if (isAnimating || nextIdx === currentSlide) return;
      isAnimating = true;

      const outSlide = slides[currentSlide];
      const inSlide  = slides[nextIdx];

      // Determine animation class names based on direction and reduced-motion
      let outClass: string;
      let inClass: string;

      if (reducedMotion) {
        outClass = direction === 'next' ? 'animate-rotate-out-right' : 'animate-rotate-out-left';
        inClass  = direction === 'next' ? 'animate-rotate-in-from-left' : 'animate-rotate-in-from-right';
        // In reduced-motion mode these map to fadeOut/fadeIn via CSS @media override
      } else {
        outClass = direction === 'next' ? 'animate-rotate-out-right' : 'animate-rotate-out-left';
        inClass  = direction === 'next' ? 'animate-rotate-in-from-left' : 'animate-rotate-in-from-right';
      }

      // Stage incoming slide (visible in DOM, animation handles opacity)
      inSlide.style.zIndex = '3';
      inSlide.style.opacity = '0';
      inSlide.classList.remove('is-active');

      // Apply exit + enter animations simultaneously
      outSlide.classList.add(outClass);
      inSlide.classList.add(inClass);

      // Update dots at animation start
      updateDots(nextIdx);

      // Settle state after animation completes
      setTimeout(() => {
        // Clean up exiting slide
        outSlide.classList.remove('is-active', outClass);
        outSlide.style.zIndex = '';
        outSlide.style.opacity = '';
        outSlide.setAttribute('aria-hidden', 'true');

        // Settle incoming slide as active
        inSlide.classList.remove(inClass);
        inSlide.classList.add('is-active');
        inSlide.style.zIndex = '';
        inSlide.style.opacity = '';
        inSlide.setAttribute('aria-hidden', 'false');

        currentSlide = nextIdx;
        isAnimating = false;

        // Process queue
        processQueue();
      }, totalDuration);
    }

    // ── Queue processing ───────────────────────────────────────────
    function processQueue() {
      if (queue.length === 0) return;
      const action = queue.shift()!;
      if (action === 'next') executeNext();
      else if (action === 'prev') executePrev();
    }

    function executeNext() {
      goTo(nextIndex(), 'next');
    }

    function executePrev() {
      goTo(prevIndex(), 'prev');
    }

    // ── Public handlers (queue-aware) ──────────────────────────────
    function handleNext() {
      if (isAnimating) {
        queue.push('next');
        return;
      }
      executeNext();
      resetAutoTimer();
    }

    function handlePrev() {
      if (isAnimating) {
        queue.push('prev');
        return;
      }
      executePrev();
      resetAutoTimer();
    }

    // ── Auto-advance timer ─────────────────────────────────────────
    function startAutoTimer() {
      if (!autoAdv) return;
      autoTimer = setInterval(() => {
        if (!isAnimating) executeNext();
      }, interval);
    }

    function resetAutoTimer() {
      if (!autoAdv) return;
      if (autoTimer) clearInterval(autoTimer);
      startAutoTimer();
    }

    // ── Event listeners ────────────────────────────────────────────
    if (nextBtn) nextBtn.addEventListener('click', handleNext);
    if (prevBtn) prevBtn.addEventListener('click', handlePrev);

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (isAnimating) return;
        const dir = i > currentSlide ? 'next' : 'prev';
        goTo(i, dir);
        resetAutoTimer();
      });
    });

    // Keyboard navigation
    carousel.setAttribute('tabindex', '0');
    carousel.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowRight') handleNext();
      if (e.key === 'ArrowLeft')  handlePrev();
    });

    // Touch swipe support (45px minimum threshold)
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });

    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) >= 45) {
        if (dx < 0) handleNext(); // swipe left = next
        else        handlePrev(); // swipe right = prev
      }
    }, { passive: true });

    // Pause auto-advance on hover/focus
    carousel.addEventListener('mouseenter', () => {
      if (autoTimer) clearInterval(autoTimer);
    });
    carousel.addEventListener('mouseleave', startAutoTimer);

    // ── Start ──────────────────────────────────────────────────────
    startAutoTimer();
  });
</script>
