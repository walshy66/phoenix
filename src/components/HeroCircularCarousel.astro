---
/**
 * HeroCircularCarousel — landscape-format 3D cylinder card carousel.
 *
 * Architecture: a `.carousel-track` wrapper with `transform-style: preserve-3d`
 * rotates the whole cylinder. Each card is placed on the cylinder surface at
 * its own `--angle` offset. JS updates only the track's `rotateY` on each step.
 *
 *   Step angle: 60° — front=0°, right=−60°, left=+60°, far-right=−120°,
 *               far-left=+120°, back=±180°
 *   Next: trackAngle −= 60° (right card comes to front)
 *   Prev: trackAngle += 60° (left card comes to front)
 *
 * Features:
 *   - Landscape 16:9 slides (640×360px at desktop)
 *   - 3D cylinder with `preserve-3d` — 3 visible cards at once (front + 2 side)
 *   - CSS transition on .carousel-track for smooth cylinder spin
 *   - `transitionend` event drives the click queue (no setTimeout)
 *   - `.is-active` class + `filter: brightness` for active vs side card treatment
 *   - Logo decal: sibling of track (does not rotate), visible in side gaps
 *   - Touch swipe (45px threshold), keyboard (arrow keys)
 *   - prefers-reduced-motion: transition replaced with opacity fade
 *   - Auto-advance (optional, disabled by default)
 *
 * Slide shape: { image, alt, bgColor? }
 */

interface Slide {
  image: string;       // Image URL (required; landscape infographic)
  alt: string;         // Alt text for accessibility (required)
  bgColor?: string;    // Fallback background color (optional, default: #1a1030)
}

interface Props {
  slides: Slide[];
  autoAdvanceMs?: number;
  autoAdvanceEnabled?: boolean;
}

const {
  slides,
  autoAdvanceMs = 8000,
  autoAdvanceEnabled = false,
} = Astro.props;

const count = slides.length;
const showNav = count >= 2;

// Each card sits on the cylinder surface. Its fixed angle offset from the
// "front" position is (index * STEP_DEG). The track's cumulative rotateY
// then brings the desired card to the front.
const STEP_DEG = 60;
---

<div
  class="hero-circular-carousel"
  data-count={count}
  data-interval={autoAdvanceMs}
  data-auto-advance={autoAdvanceEnabled ? 'true' : 'false'}
  aria-label="Bendigo Phoenix highlights"
  aria-roledescription="carousel"
>
  <!-- Carousel container — perspective for 3D transforms -->
  <div class="carousel-container">

    <!-- Background logo decal — sibling of track so it does NOT rotate -->
    <div class="logo-decal" aria-hidden="true">
      <img
        src="/images/phoenix-united-logo.png"
        alt=""
        class="logo-decal-img"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- 3D cylinder track — rotateY drives the whole cylinder spin -->
    <div class="carousel-track" aria-live="polite">
      {slides.map((slide, i) => (
        <div
          class={`carousel-slide${i === 0 ? ' is-active' : ''}`}
          data-slide={i}
          style={`--angle: ${i * STEP_DEG}deg; background-color: ${slide.bgColor ?? '#1a1030'};`}
          role="group"
          aria-roledescription="slide"
          aria-label={`Slide ${i + 1} of ${count}`}
          aria-hidden={i !== 0 ? 'true' : 'false'}
        >
          <img
            src={slide.image}
            alt={slide.alt}
            class="slide-img"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding={i === 0 ? 'auto' : 'async'}
          />
        </div>
      ))}
    </div>

    <!-- Navigation buttons (only rendered if 2+ slides) -->
    {showNav && (
      <button
        class="carousel-arrow carousel-prev"
        aria-label="Previous slide"
        aria-disabled="false"
        type="button"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
    )}

    {showNav && (
      <button
        class="carousel-arrow carousel-next"
        aria-label="Next slide"
        aria-disabled="false"
        type="button"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    )}
  </div>

  <!-- Slide indicators (dots) -->
  {showNav && (
    <div class="carousel-dots" role="tablist" aria-label="Slide indicators">
      {slides.map((_, i) => (
        <button
          class={`carousel-dot${i === 0 ? ' is-active' : ''}`}
          data-dot={i}
          role="tab"
          aria-label={`Go to slide ${i + 1}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          type="button"
        />
      ))}
    </div>
  )}
</div>

<style>
  /* ── Outer container ─────────────────────────────────────── */
  .hero-circular-carousel {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  /* ── Carousel container — perspective context ────────────── */
  /*
   * Responsive width strategy (mirrors containerWidth() in responsive tests):
   *   Mobile  (<768px):  min(90vw, 100vw - 32px) — 16px padding each side
   *   Tablet  (768–1023px): min(80vw, 560px)
   *   Desktop (1024px+): 640px fixed
   * Cards are landscape 16:9, so container width = card width.
   * Overflow is visible so side cards peek out of the viewport area.
   */
  .carousel-container {
    position: relative;
    width: clamp(280px, min(90vw, calc(100vw - 32px)), 560px);
    /* Enough height for the card aspect-ratio (9/16 of width) plus a little */
    aspect-ratio: 16 / 9;
    perspective: 1200px;
    perspective-origin: 50% 50%;
    overflow: visible;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .carousel-container {
      width: min(80vw, 560px);
    }
  }

  @media (min-width: 1024px) {
    .carousel-container {
      width: 640px;
    }
  }

  /* ── Background logo decal — behind track, does not rotate ── */
  .logo-decal {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
  }

  .logo-decal-img {
    width: clamp(200px, 60%, 400px);
    height: auto;
    opacity: 0.15;
    filter: grayscale(100%) brightness(2);
    user-select: none;
  }

  /* ── 3D cylinder track ───────────────────────────────────── */
  /*
   * The track itself is a flat div; transform-style: preserve-3d lets the
   * child cards exist in 3D space. Rotating the track rotates all cards.
   * The translateZ(500px) radius is chosen so cards sit comfortably at 60°
   * steps (circumference ≈ 2π × 500 ≈ 3142px; card width ≈ 640px — fine).
   */
  .carousel-track {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateY(0deg);
    transition: transform 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 1;
  }

  /* ── Individual cards — placed on the cylinder surface ───── */
  .carousel-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 16px;
    backface-visibility: hidden;
    transform: rotateY(var(--angle)) translateZ(500px);
    transition: filter 400ms ease;
    filter: brightness(0.6);
    will-change: transform, filter;
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(139, 117, 54, 0.2);
  }

  /* Active (front-facing) card — full brightness */
  .carousel-slide.is-active {
    filter: brightness(1);
  }

  /* ── Slide image ──────────────────────────────────────────── */
  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  /* ── Reduced-motion fallback ─────────────────────────────── */
  /*
   * When the user prefers reduced motion, suppress the 3D rotation.
   * The track transition is replaced with an opacity fade on the active card.
   * Cards still sit on the cylinder (3D positions preserved) but the cylinder
   * itself no longer spins — only the active slide fades in/out.
   */
  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      transition: none;
    }

    .carousel-slide {
      /* Hide all non-active cards immediately */
      opacity: 0;
      transition: opacity 300ms ease;
    }

    .carousel-slide.is-active {
      opacity: 1;
    }
  }

  /* ── Navigation arrows ───────────────────────────────────── */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgba(139, 117, 54, 0.55);
    background: rgba(26, 16, 48, 0.7);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.15s, opacity 0.15s;
    backdrop-filter: blur(6px);
    outline-offset: 3px;
  }

  .carousel-arrow:hover {
    background: #8B7536;
    border-color: #8B7536;
    transform: translateY(-50%) scale(1.08);
  }

  .carousel-arrow:focus-visible {
    outline: 2px solid #8B7536;
    outline-offset: 3px;
  }

  .carousel-arrow:active {
    opacity: 0.75;
    transform: translateY(-50%) scale(0.96);
  }

  /* During animation: aria-disabled="true" signals to assistive tech
     that the button is temporarily unavailable, without removing it
     from the tab order.  Buttons remain fully clickable — clicks are
     queued by the script, so pointer-events must stay enabled. */
  .carousel-arrow[aria-disabled="true"] {
    opacity: 0.5;
  }

  .carousel-prev { left: -22px; }
  .carousel-next { right: -22px; }

  @media (max-width: 520px) {
    .carousel-prev { left: 8px; }
    .carousel-next { right: 8px; }
  }

  /* ── Dot indicators ──────────────────────────────────────── */
  .carousel-dots {
    display: flex;
    gap: 8px;
    align-items: center;
    z-index: 1;
  }

  .carousel-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: none;
    padding: 0;
    background: rgba(255, 255, 255, 0.25);
    cursor: pointer;
    transition: background 0.25s, transform 0.25s, width 0.25s;
    outline-offset: 3px;
  }

  .carousel-dot:focus-visible {
    outline: 2px solid #8B7536;
  }

  .carousel-dot.is-active {
    background: #8B7536;
    transform: scale(1.3);
    width: 24px;
    border-radius: 5px;
  }
</style>

<script>
  // Step angle between cards on the cylinder (degrees)
  const STEP_DEG = 60;

  document.querySelectorAll<HTMLElement>('.hero-circular-carousel').forEach(carousel => {
    const count    = parseInt(carousel.dataset.count    ?? '1', 10);
    const interval = parseInt(carousel.dataset.interval ?? '8000', 10);
    const autoAdv  = carousel.dataset.autoAdvance === 'true';

    const track    = carousel.querySelector<HTMLElement>('.carousel-track');
    const slides   = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-slide'));
    const dots     = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-dot'));
    const prevBtn  = carousel.querySelector<HTMLButtonElement>('.carousel-prev');
    const nextBtn  = carousel.querySelector<HTMLButtonElement>('.carousel-next');

    if (!track) return;

    // Detect reduced motion preference
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── State ──────────────────────────────────────────────────────────────────
    // currentAngle: cumulative track rotation (never reset/modulo) so CSS
    // transition always interpolates in the correct direction.
    let currentAngle = 0;
    // currentIndex: logical slide index (0..count-1)
    let currentIndex = 0;
    let isAnimating  = false;
    const queue: string[] = [];
    let autoTimer: ReturnType<typeof setInterval> | null = null;
    let lastFocusedButton: HTMLButtonElement | null = null;

    // ── DOM helpers ────────────────────────────────────────────────────────────
    function updateDots(index: number) {
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === index);
        d.setAttribute('aria-selected', String(i === index));
      });
    }

    function updateSlideActiveClass(index: number) {
      slides.forEach((s, i) => {
        s.classList.toggle('is-active', i === index);
        s.setAttribute('aria-hidden', String(i !== index));
      });
    }

    function setButtonsAriaDisabled(disabled: boolean) {
      if (prevBtn) prevBtn.setAttribute('aria-disabled', String(disabled));
      if (nextBtn) nextBtn.setAttribute('aria-disabled', String(disabled));
    }

    // ── Animation completion ───────────────────────────────────────────────────
    // In reduced-motion mode we use a manual 300ms delay (the CSS transition
    // on the active slide opacity) rather than tracking a track transitionend.
    function onAnimationComplete() {
      isAnimating = false;
      setButtonsAriaDisabled(false);

      if (lastFocusedButton && document.activeElement !== lastFocusedButton) {
        lastFocusedButton.focus({ preventScroll: true });
      }
      lastFocusedButton = null;

      processQueue();
    }

    // ── Move cylinder ──────────────────────────────────────────────────────────
    function rotateToIndex(nextIdx: number, direction: 'next' | 'prev') {
      if (isAnimating || nextIdx === currentIndex) return;
      isAnimating = true;
      setButtonsAriaDisabled(true);

      if (direction === 'next') {
        currentAngle -= STEP_DEG;
      } else {
        currentAngle += STEP_DEG;
      }
      currentIndex = nextIdx;

      // Update active visuals at start of transition
      updateSlideActiveClass(currentIndex);
      updateDots(currentIndex);

      if (reducedMotion) {
        // No track rotation: just the active slide fades in (CSS handles opacity).
        // After 300ms (opacity transition duration) settle the state.
        setTimeout(onAnimationComplete, 300);
      } else {
        // Apply rotation; transitionend fires when CSS transition on track finishes.
        track.style.transform = `rotateY(${currentAngle}deg)`;
        // transitionend listener (one-shot)
        track.addEventListener('transitionend', onAnimationComplete, { once: true });
      }
    }

    // ── Queue processing ───────────────────────────────────────────────────────
    function processQueue() {
      if (queue.length === 0) return;
      const action = queue.shift()!;
      if (action === 'next') executeNext();
      else if (action === 'prev') executePrev();
    }

    function nextIndex(): number {
      return (currentIndex + 1) % count;
    }

    function prevIndex(): number {
      return ((currentIndex - 1) % count + count) % count;
    }

    function executeNext() {
      rotateToIndex(nextIndex(), 'next');
    }

    function executePrev() {
      rotateToIndex(prevIndex(), 'prev');
    }

    // ── Public handlers (queue-aware) ──────────────────────────────────────────
    function handleNext() {
      if (isAnimating) {
        queue.push('next');
        return;
      }
      executeNext();
      resetAutoTimer();
    }

    function handlePrev() {
      if (isAnimating) {
        queue.push('prev');
        return;
      }
      executePrev();
      resetAutoTimer();
    }

    function trackButtonFocus(btn: HTMLButtonElement | null) {
      if (btn) lastFocusedButton = btn;
    }

    // ── Auto-advance timer ─────────────────────────────────────────────────────
    function startAutoTimer() {
      if (!autoAdv) return;
      autoTimer = setInterval(() => {
        if (!isAnimating) executeNext();
      }, interval);
    }

    function resetAutoTimer() {
      if (!autoAdv) return;
      if (autoTimer) clearInterval(autoTimer);
      startAutoTimer();
    }

    // ── Event listeners ────────────────────────────────────────────────────────
    if (nextBtn) nextBtn.addEventListener('click', () => {
      trackButtonFocus(nextBtn);
      handleNext();
    });
    if (prevBtn) prevBtn.addEventListener('click', () => {
      trackButtonFocus(prevBtn);
      handlePrev();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (isAnimating) return;
        const dir = i > currentIndex ? 'next' : 'prev';
        rotateToIndex(i, dir);
        resetAutoTimer();
      });
    });

    // Keyboard navigation
    carousel.setAttribute('tabindex', '0');
    carousel.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowRight') handleNext();
      if (e.key === 'ArrowLeft')  handlePrev();
    });

    // Touch swipe support (45px minimum threshold)
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });

    carousel.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) >= 45) {
        if (dx < 0) handleNext(); // swipe left = next
        else        handlePrev(); // swipe right = prev
      }
    }, { passive: true });

    // Pause auto-advance on hover/focus
    carousel.addEventListener('mouseenter', () => {
      if (autoTimer) clearInterval(autoTimer);
    });
    carousel.addEventListener('mouseleave', startAutoTimer);

    // ── Start ──────────────────────────────────────────────────────────────────
    startAutoTimer();
  });
</script>
