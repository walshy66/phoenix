---
import type { SeasonCardConfig } from '../lib/seasons/types'
import { getSeasonAriaLabel } from '../lib/seasons/utils'

interface Props {
  season: SeasonCardConfig
}

const { season } = Astro.props

const baseClasses =
  'group relative flex min-h-[120px] flex-col items-center justify-center rounded-lg border bg-white p-4 transition-all duration-200 md:min-h-40 md:p-6'

const clickableClasses =
  'cursor-pointer hover:border-brand-purple hover:shadow-md focus-visible:ring-2 focus-visible:ring-brand-purple focus-visible:ring-offset-2'

const disabledClasses = 'cursor-not-allowed opacity-80'

const getTileToneClasses = (card: SeasonCardConfig) => {
  if (card.id === 'winter-2026') return 'border-2 border-brand-purple/60 bg-purple-100'
  if (card.id === 'summer-2025-26') return 'border-2 border-emerald-400/70 bg-emerald-100'
  if (card.id === 'summer-2026-27') return 'border-2 border-rose-400/70 bg-rose-100'
  return 'border-2 border-amber-400/70 bg-amber-100'
}

const getBadgeClasses = (card: SeasonCardConfig) => {
  if (card.status === 'active') {
    return 'bg-yellow-100 text-brand-purple border border-brand-gold'
  }

  if (card.status === 'completed') {
    return 'bg-gray-100 text-gray-600 border border-gray-300'
  }

  if (card.status === 'coming_soon' && card.role === 'next') {
    return 'bg-purple-50 text-purple-400 border border-purple-200'
  }

  return 'bg-gray-100 text-gray-400 border border-gray-200'
}

const ariaLabel = getSeasonAriaLabel(season)
const toneClasses = getTileToneClasses(season)
const badgeClasses = `inline-block rounded-full px-3 py-1 text-xs font-bold ${getBadgeClasses(season)}`
---

{season.clickable && season.navigationTarget && !season.navigationExternal ? (
  <a href={season.navigationTarget} aria-label={ariaLabel} class={`${baseClasses} ${toneClasses} ${clickableClasses}`}>
    <div class="mb-3 text-4xl leading-none" aria-hidden="true">{season.icon}</div>
    <h3 class="mb-2 text-center text-base font-bold text-gray-900">{season.name}</h3>
    <div class={badgeClasses}>{season.statusBadgeLabel}</div>
  </a>
) : season.clickable && season.navigationTarget && season.navigationExternal ? (
  <a
    href={season.navigationTarget}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={ariaLabel}
    class={`${baseClasses} ${toneClasses} ${clickableClasses}`}
  >
    <div class="mb-3 text-4xl leading-none" aria-hidden="true">{season.icon}</div>
    <h3 class="mb-2 text-center text-base font-bold text-gray-900">{season.name}</h3>
    <div class={badgeClasses}>{season.statusBadgeLabel}</div>
  </a>
) : (
  <div aria-disabled="true" tabindex="-1" aria-label={ariaLabel} class={`${baseClasses} ${toneClasses} ${disabledClasses}`}>
    <div class="mb-3 text-4xl leading-none" aria-hidden="true">{season.icon}</div>
    <h3 class="mb-2 text-center text-base font-bold text-gray-900">{season.name}</h3>
    <div class={badgeClasses}>{season.statusBadgeLabel}</div>
  </div>
)}
