---
/**
 * T010: KeyDatesSection Component
 *
 * Renders key dates in a responsive grid layout.
 * Each date displayed as a card with icon, label, formatted date, and optional description.
 * Shows empty state message when no dates are available.
 *
 * Features:
 * - Grid layout: 4 columns desktop, 2 columns tablet, 1 column mobile
 * - Emoji icons for date types (📝 Registration, ⚽ Season Start, 🔄 Break, 🏆 Finals)
 * - Formatted dates via formatDate() (e.g., "1 May 2026")
 * - Optional description text below each date
 * - Empty state: "No scheduled dates announced yet"
 * - Responsive padding and font sizes
 *
 * Accessibility (WCAG 2.1 AA):
 * - Semantic HTML with <section> element
 * - Descriptive heading
 * - Emoji icons are decorative (aria-hidden)
 * - Sufficient color contrast
 * - Readable font sizes on all breakpoints
 *
 * Traceability: FR-001 (key dates visible), FR-002 (above tiles),
 *              AC-1.3 (dates in detail view), NFR-012 (empty state)
 */

import type { KeyDate, Season } from '../lib/seasons/types';
import { formatDate } from '../lib/seasons/utils';

interface Props {
  keyDates?: KeyDate[];
  season?: Season;
}

const { keyDates = [], season } = Astro.props;

const hasData = keyDates && keyDates.length > 0;

/**
 * Get emoji icon based on date label
 */
function getIconForLabel(label: string): string {
  const iconMap: Record<string, string> = {
    'Registration Opens': '📝',
    'Registration': '📝',
    'Season Starts': '⚽',
    'Starts': '⚽',
    'Mid-Season Break': '🔄',
    'Break': '🔄',
    'Finals': '🏆',
    'Final': '🏆',
  };

  // Try exact match first
  if (iconMap[label]) return iconMap[label];

  // Try partial match
  for (const [key, icon] of Object.entries(iconMap)) {
    if (label.includes(key)) return icon;
  }

  return '📅'; // Default calendar icon
}
---

<section class="rounded-lg border border-gray-200 bg-white p-6">
  <!-- Section Title -->
  <h2 class="mb-6 text-lg font-semibold text-gray-900">
    Key Dates
  </h2>

  {
    hasData ? (
      <!-- Grid of date cards -->
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
        {keyDates.map((date) => (
          <div key={date.date} class="rounded-lg border border-gray-200 bg-gray-50 p-4">
            <!-- Icon -->
            <div class="mb-3 text-2xl" aria-hidden="true">
              {getIconForLabel(date.label)}
            </div>

            <!-- Date Label -->
            <h3 class="mb-2 text-sm font-semibold text-gray-900">
              {date.label}
            </h3>

            <!-- Formatted Date -->
            <p class="mb-2 text-xs text-gray-600">
              {formatDate(date.date)}
            </p>

            <!-- Optional Description -->
            {date.description && (
              <p class="text-xs text-gray-500">
                {date.description}
              </p>
            )}
          </div>
        ))}
      </div>
    ) : (
      <!-- Empty State -->
      <div class="rounded-lg bg-gray-50 p-4">
        <p class="text-sm text-gray-600">
          No scheduled dates announced yet
        </p>
      </div>
    )
  }
</section>

<style>
  div[class*='grid'] {
    display: grid;
  }
</style>
