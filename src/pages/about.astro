---
import BaseLayout from '../layouts/BaseLayout.astro';

// ClubPolicy interface definition
interface ClubPolicy {
  name: string;
  type: 'pdf' | 'external_link';
  filePath?: string;
  url?: string;
}

// Club Policies data - includes PDFs and external links
const clubPolicies: ClubPolicy[] = [
  {
    name: 'Child Protection Policy',
    type: 'external_link',
    url: 'https://bendigobasketball.com.au/child-protection-policy/',
  },
  {
    name: 'Code of Conduct',
    type: 'pdf',
    filePath: 'resources/club-policies/code-of-conduct.pdf',
  },
  {
    name: 'Gender, Disrespect & Violence',
    type: 'external_link',
    url: 'https://sportsfocus.com.au/issue-gender-disrespect-violence/',
  },
  {
    name: 'Grievance Procedure',
    type: 'pdf',
    filePath: 'resources/club-policies/grievance-procedure.pdf',
  },
  {
    name: 'Photography & Social Media',
    type: 'pdf',
    filePath: 'resources/club-policies/photography-social-media.pdf',
  },
  {
    name: 'Player Welfare',
    type: 'pdf',
    filePath: 'resources/club-policies/player-welfare.pdf',
  },
  {
    name: 'Privacy Policy',
    type: 'pdf',
    filePath: 'resources/club-policies/privacy-policy.pdf',
  },
  {
    name: 'Registration & Eligibility',
    type: 'pdf',
    filePath: 'resources/club-policies/registration-and-eligibility.pdf',
  },
  {
    name: 'Uniform Policy',
    type: 'pdf',
    filePath: 'resources/club-policies/uniform-policy.pdf',
  },
];

// Sort alphabetically by name
const policies = clubPolicies.sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title="About" description="Learn about Bendigo Phoenix Basketball Club, our mission, policies and the Slam Dunk Bridging Fund.">
  <!-- Page Hero -->
  <section class="bg-brand-purple py-16 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-brand-gold font-bold text-sm uppercase tracking-widest mb-3">Our Story</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white uppercase tracking-tight">ABOUT US</h1>
      <div class="h-1 w-16 bg-brand-gold mx-auto mt-4"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Our Mission</h2>
          <div class="h-1 w-12 bg-brand-gold mb-6"></div>
          <p class="text-gray-600 leading-relaxed mb-4">
            Bendigo Phoenix Basketball Club has been a cornerstone of basketball in Central Victoria.
            Our club is committed to developing players of all ages while fostering a strong community spirit.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            We compete in the Bendigo Basketball Association competitions and are passionate about growing the
            sport in our region. From our youngest junior players to our senior competitors, we strive to
            provide pathways for every level of player.
          </p>
          <p class="text-gray-600 leading-relaxed">
            At Bendigo Phoenix, we believe basketball is more than just a game — it's a vehicle for building
            character, friendships and community connections that last a lifetime.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { icon: '🤝', title: 'Community First', desc: 'We put our community at the heart of everything we do.' },
            { icon: '⭐', title: 'Development Focused', desc: 'Helping every player reach their potential, whatever their skill level.' },
            { icon: '🏆', title: 'Competitive Spirit', desc: 'Striving for excellence on and off the court.' },
            { icon: '❤️', title: 'Inclusive Culture', desc: 'Basketball for everyone — no one gets left behind.' },
          ].map(val => (
            <div class="flex items-start gap-4 p-4 rounded-xl bg-brand-offwhite border border-gray-100">
              <span class="text-3xl flex-shrink-0">{val.icon}</span>
              <div>
                <h3 class="font-bold text-brand-black text-sm">{val.title}</h3>
                <p class="text-gray-500 text-sm mt-0.5">{val.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Slam Dunk Bridging Fund -->
  <section id="slam-dunk" class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
    <div class="max-w-7xl mx-auto">
      <div class="rounded-2xl border-2 border-brand-gold bg-white overflow-hidden">
        <div class="bg-brand-gold px-6 py-4">
          <h2 class="text-white font-black text-xl uppercase tracking-wide">🏀 Slam Dunk Bridging Fund</h2>
        </div>
        <div class="p-6 sm:p-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <p class="text-gray-700 leading-relaxed mb-4">
                The Slam Dunk Bridging Fund exists to ensure no player misses out on the opportunity to play
                basketball due to financial hardship.
              </p>
              <p class="text-gray-600 leading-relaxed mb-4">
                If you or your family are experiencing financial difficulty and need assistance with registration
                fees, please contact us confidentially. All applications are handled with complete discretion
                and respect.
              </p>
              <p class="text-gray-600 leading-relaxed">
                We believe every young person deserves the chance to play and benefit from the life lessons
                that sport provides. This fund makes that possible.
              </p>
            </div>
            <div class="bg-brand-offwhite rounded-xl p-6 flex flex-col items-center justify-center text-center gap-4">
              <span class="text-5xl">🤝</span>
              <h3 class="font-bold text-brand-purple text-lg">Apply Confidentially</h3>
              <p class="text-gray-600 text-sm leading-relaxed">
                Contact us at any time — your privacy is completely protected.
              </p>
              <a
                href="mailto:hello@bendigophoenix.org.au?subject=Slam%20Dunk%20Bridging%20Fund%20Enquiry"
                class="inline-flex items-center gap-2 bg-brand-purple text-white px-6 py-3 rounded-lg font-bold text-sm hover:bg-purple-800 transition-colors"
              >
                ✉️ Contact Us
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Club Policies -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Club Policies</h2>
      <div class="h-1 w-12 bg-brand-gold mb-8"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="policies-grid">
        {policies.map((policy, i) => {
          const policyId = `policy-${i}`;
          const embedId = `embed-${i}`;

          return (
            <div class="rounded-xl border border-gray-100 overflow-hidden bg-white hover:shadow-md transition-shadow">
              {policy.type === 'pdf' ? (
                // PDF Policy Item
                <>
                  <button
                    class="policy-expand-btn w-full text-left px-5 py-4 flex items-center justify-between hover:bg-brand-offwhite transition-colors duration-150 group"
                    id={policyId}
                    aria-expanded="false"
                    aria-controls={embedId}
                    data-type="pdf"
                    data-filepath={policy.filePath}
                    data-name={policy.name}
                  >
                    <span class="font-bold text-brand-black text-sm flex-1">{policy.name}</span>
                    <svg
                      class="w-5 h-5 text-brand-purple flex-shrink-0 transition-transform duration-200"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="policy-embed-container hidden px-5 py-4 border-t border-gray-100" id={embedId}>
                    <div class="mb-4 flex gap-2">
                      <a
                        class="policy-download-btn inline-flex items-center gap-2 bg-brand-purple text-white px-4 py-2 rounded-lg font-bold text-xs hover:bg-purple-800 transition-colors"
                        href={`/${policy.filePath}`}
                        download={policy.name}
                        aria-label={`Download ${policy.name}`}
                      >
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19v-7m0 0V5m0 7H5m7 0h7" />
                        </svg>
                        Download
                      </a>
                    </div>
                    <div class="policy-embed-wrapper bg-gray-50 rounded-lg overflow-hidden">
                      <embed
                        class="policy-embed w-full"
                        src={`/${policy.filePath}`}
                        type="application/pdf"
                        title={`${policy.name} PDF`}
                        style="min-height: 400px;"
                      />
                      <div class="policy-error-msg hidden p-4 text-center text-red-600 text-sm bg-red-50">
                        <p>Document temporarily unavailable. <a href={`/${policy.filePath}`} class="underline hover:no-underline">Try downloading instead.</a></p>
                      </div>
                    </div>
                  </div>
                </>
              ) : (
                // External Link Policy Item
                <a
                  class="policy-external-link w-full text-left px-5 py-4 flex items-center justify-between hover:bg-brand-offwhite transition-colors duration-150 group"
                  href={policy.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-type="external"
                  title={policy.name}
                >
                  <span class="font-bold text-brand-black text-sm flex-1">{policy.name}</span>
                  <svg
                    class="w-5 h-5 text-brand-gold flex-shrink-0 group-hover:translate-x-0.5 transition-transform"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-4-6l6-6m0 0l-6 6m6-6v10" />
                  </svg>
                  <span class="sr-only">(opens in new tab)</span>
                </a>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Handle PDF policy expand/collapse accordion
  document.querySelectorAll('.policy-expand-btn').forEach((button) => {
    button.addEventListener('click', (e) => {
      e.preventDefault();
      const button_el = button as HTMLButtonElement;
      const embedId = button_el.getAttribute('aria-controls');
      const embedContainer = embedId ? document.getElementById(embedId) : null;
      const isExpanded = button_el.getAttribute('aria-expanded') === 'true';

      // Close all other PDF embeds
      document.querySelectorAll('.policy-embed-container').forEach((container) => {
        if (container.id !== embedId) {
          container.classList.add('hidden');
        }
      });

      // Close all other buttons
      document.querySelectorAll('.policy-expand-btn').forEach((btn) => {
        if (btn !== button_el) {
          btn.setAttribute('aria-expanded', 'false');
          const icon = btn.querySelector('svg') as HTMLElement;
          if (icon) icon.style.transform = '';
        }
      });

      // Toggle current button
      if (embedContainer) {
        if (isExpanded) {
          embedContainer.classList.add('hidden');
          button_el.setAttribute('aria-expanded', 'false');
          const icon = button_el.querySelector('svg') as HTMLElement;
          if (icon) icon.style.transform = '';
        } else {
          embedContainer.classList.remove('hidden');
          button_el.setAttribute('aria-expanded', 'true');
          const icon = button_el.querySelector('svg') as HTMLElement;
          if (icon) icon.style.transform = 'rotate(180deg)';
        }
      }
    });

    // Keyboard support for Enter/Space
    button.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        (button as HTMLButtonElement).click();
      }
    });
  });

  // Handle PDF embed error fallback
  document.querySelectorAll('.policy-embed').forEach((embed) => {
    const embedEl = embed as HTMLEmbedElement;
    embedEl.addEventListener('error', () => {
      const container = embed.closest('.policy-embed-wrapper') as HTMLElement;
      const errorMsg = container?.querySelector('.policy-error-msg') as HTMLElement;
      if (errorMsg) {
        errorMsg.classList.remove('hidden');
      }
      // Hide the embed on error
      (embed as HTMLElement).style.display = 'none';
    });

    // Check if embed is empty/broken (some browsers don't fire error event)
    setTimeout(() => {
      const embedHeight = (embedEl as any).scrollHeight || 0;
      if (embedHeight === 0) {
        const container = embed.closest('.policy-embed-wrapper') as HTMLElement;
        const errorMsg = container?.querySelector('.policy-error-msg') as HTMLElement;
        if (errorMsg) {
          errorMsg.classList.remove('hidden');
        }
        (embed as HTMLElement).style.display = 'none';
      }
    }, 2000);
  });
</script>
