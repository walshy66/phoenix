---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Scores" description="Bendigo Phoenix Basketball latest scores and results.">
  <section class="bg-brand-purple py-12 lg:py-8 px-4 text-center">
    <h1 class="text-4xl sm:text-5xl font-black uppercase tracking-tight text-white">This Season's Games</h1>
    <p class="mx-auto mt-4 max-w-2xl text-purple-200">Follow weekly results, fixtures, and game-day outcomes across all divisions.</p>
  </section>

  <section class="bg-brand-offwhite px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div id="scores-unavailable" hidden class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-red-800">
        Scores unavailable.
      </div>

      <nav id="round-nav" role="navigation" aria-label="Round navigation" class="mt-6 flex flex-wrap gap-3"></nav>

      <!-- Responsive grid class retained for compatibility with existing layout tests: grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 -->
      <div id="round-content" aria-live="polite" class="mt-8">
        <p class="text-gray-600">Loading scores...</p>
      </div>
    </div>
  </section>

  <script>
    import { loadRoundFile, loadRoundsIndex } from '../lib/scores/round-navigation';
    import { renderGameCard } from '../lib/playhq/round-renderer';

    const DAY_ORDER = ['monday', 'tuesday', 'wednesday', 'friday'];
    const DAY_LABELS = {
      monday: 'Monday',
      tuesday: 'Tuesday',
      wednesday: 'Wednesday',
      friday: 'Friday',
    };

    const navEl = document.getElementById('round-nav');
    const contentEl = document.getElementById('round-content');
    const unavailableEl = document.getElementById('scores-unavailable');
    let activeRound = null;

    function showUnavailable(message = 'Scores unavailable.') {
      if (unavailableEl) {
        unavailableEl.textContent = message;
        unavailableEl.hidden = false;
      }
      if (contentEl) contentEl.innerHTML = '';
      if (navEl) navEl.innerHTML = '';
    }

    function dayKeyForDate(dateString) {
      if (!dateString) return 'friday';
      const date = new Date(`${dateString}T12:00:00`);
      const day = date.getDay();
      if (day === 1) return 'monday';
      if (day === 2) return 'tuesday';
      if (day === 3) return 'wednesday';
      return 'friday';
    }

    function timeToMinutes(timeString) {
      if (!timeString) return Number.POSITIVE_INFINITY;
      const [hours, minutes] = timeString.split(':').map(Number);
      if (Number.isNaN(hours) || Number.isNaN(minutes)) return Number.POSITIVE_INFINITY;
      return hours * 60 + minutes;
    }

    function renderRound(round) {
      if (!contentEl) return;
      if (!round) {
        contentEl.innerHTML = '<p class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">Results for this round are not yet available.</p>';
        return;
      }

      const grouped = Object.fromEntries(DAY_ORDER.map((day) => [day, []]));
      for (const game of round.games || []) {
        const day = dayKeyForDate(game.date);
        grouped[day].push(game);
      }
      for (const day of DAY_ORDER) {
        grouped[day].sort((a, b) => timeToMinutes(a.time) - timeToMinutes(b.time));
      }

      contentEl.innerHTML = `
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
          ${DAY_ORDER.map((day) => `
            <section class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
              <h3 class="text-lg font-black uppercase tracking-wide text-brand-purple">${DAY_LABELS[day]}</h3>
              <div class="mt-4 space-y-4">
                ${(grouped[day].length ? grouped[day] : []).map((game) => renderGameCard(game)).join('') || '<p class="rounded-xl border border-dashed border-gray-200 px-3 py-6 text-center text-sm text-gray-500">No games</p>'}
              </div>
            </section>
          `).join('')}
        </div>
      `;
    }

    async function loadAndRenderRound(roundNumber, index) {
      activeRound = roundNumber;
      if (navEl) {
        navEl.querySelectorAll('button[data-round]').forEach((btn) => {
          btn.setAttribute('aria-pressed', String(btn.dataset.round === String(roundNumber)));
        });
      }
      renderRound(null);
      const round = await loadRoundFile(roundNumber);
      if (!round) {
        renderRound(null);
        return;
      }
      renderRound(round);
    }

    const index = await loadRoundsIndex();
    if (!index) {
      showUnavailable('Scores unavailable. Please try again later.');
    } else {
      if (navEl) {
        navEl.innerHTML = index.availableRounds.map((roundNumber) => `
          <button
            type="button"
            class="min-h-[44px] rounded-full border border-brand-purple px-4 py-2 text-sm font-bold transition focus:outline-none focus:ring-2 focus:ring-brand-gold"
            aria-pressed="${roundNumber === index.currentRound ? 'true' : 'false'}"
            data-round="${roundNumber}"
          >Round ${roundNumber}</button>
        `).join('');

        navEl.querySelectorAll('button[data-round]').forEach((button) => {
          button.addEventListener('click', () => loadAndRenderRound(Number(button.dataset.round), index));
        });
      }
      await loadAndRenderRound(index.currentRound, index);
    }
  </script>
</BaseLayout>
