---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScoreCard from '../components/ScoreCard.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

// Try to load scores data from JSON file, fall back to placeholder
let scoresData = {
  lastUpdated: '2025-01-01T00:00:00.000Z',
  note: "Run 'node scripts/scrape-playhq.js' to update scores",
  scores: [
    {
      id: '1',
      date: '2025-01-01',
      competition: 'Bendigo Basketball Association',
      homeTeam: 'Bendigo Phoenix',
      awayTeam: 'Opponent',
      homeScore: 85,
      awayScore: 72,
      status: 'completed',
    },
  ],
  ladder: [
    { rank: 1, team: 'Bendigo Phoenix', played: 1, won: 1, lost: 0, drawn: 0, points: 2 },
    { rank: 2, team: 'Opponent', played: 1, won: 0, lost: 1, drawn: 0, points: 0 },
  ],
};

try {
  const dataPath = join(process.cwd(), 'scripts', 'scores-data.json');
  if (existsSync(dataPath)) {
    const raw = readFileSync(dataPath, 'utf-8');
    scoresData = JSON.parse(raw);
  }
} catch (e) {
  // Use placeholder data
}

const lastUpdated = scoresData.lastUpdated
  ? new Date(scoresData.lastUpdated).toLocaleString('en-AU', {
      dateStyle: 'long',
      timeStyle: 'short',
    })
  : 'Unknown';
---

<BaseLayout title="Scores & Ladder" description="Bendigo Phoenix Basketball latest scores, results and competition ladder.">
  <!-- Page Hero -->
  <section class="bg-brand-purple py-16 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-brand-gold font-bold text-sm uppercase tracking-widest mb-3">Live Updates</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white uppercase tracking-tight">SCORES &amp; LADDER</h1>
      <div class="h-1 w-16 bg-brand-gold mx-auto mt-4"></div>
    </div>
  </section>

  <!-- Last Updated -->
  <section class="bg-brand-black py-3 px-4">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-gray-400 text-xs flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-brand-gold inline-block animate-pulse"></span>
        Last updated: <span class="text-white font-medium">{lastUpdated}</span>
      </p>
      <div class="text-gray-400 text-xs">
        <span>Run <code class="bg-gray-800 text-brand-gold px-1.5 py-0.5 rounded text-xs">node scripts/scrape-playhq.js</code> to refresh scores</span>
      </div>
    </div>
  </section>

  <!-- Scores Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide">Recent Results</h2>
      </div>
      <div class="h-1 w-12 bg-brand-gold mb-8"></div>

      {scoresData.scores && scoresData.scores.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {scoresData.scores.map((score: any) => (
            <ScoreCard
              homeTeam={score.homeTeam}
              awayTeam={score.awayTeam}
              homeScore={score.homeScore}
              awayScore={score.awayScore}
              date={score.date}
              competition={score.competition}
              status={score.status}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-white rounded-xl border border-dashed border-brand-purple">
          <span class="text-5xl mb-4 block">🏀</span>
          <p class="text-gray-500">No results available yet. Check back after the season begins.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Ladder Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Competition Ladder</h2>
      <div class="h-1 w-12 bg-brand-gold mb-8"></div>

      {scoresData.ladder && scoresData.ladder.length > 0 ? (
        <div class="table-responsive">
          <table class="w-full min-w-[500px] border-collapse rounded-xl overflow-hidden">
            <thead>
              <tr class="bg-brand-purple text-white">
                <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wide w-10">#</th>
                <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wide">Team</th>
                <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide w-14">P</th>
                <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide w-14">W</th>
                <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide w-14">L</th>
                <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide w-14">D</th>
                <th class="px-4 py-3 text-center text-xs font-bold uppercase tracking-wide w-16">Pts</th>
              </tr>
            </thead>
            <tbody>
              {scoresData.ladder.map((row: any, i: number) => (
                <tr class={`border-b border-gray-100 ${row.team.includes('Phoenix') ? 'bg-purple-50 border-l-4 border-l-brand-gold' : i % 2 === 0 ? 'bg-white' : 'bg-brand-offwhite'}`}>
                  <td class="px-4 py-3 text-sm text-gray-500 font-medium">{row.rank}</td>
                  <td class={`px-4 py-3 text-sm font-bold ${row.team.includes('Phoenix') ? 'text-brand-purple' : 'text-brand-black'}`}>
                    {row.team.includes('Phoenix') && <span class="mr-1">🏀</span>}
                    {row.team}
                  </td>
                  <td class="px-4 py-3 text-sm text-center text-gray-600">{row.played}</td>
                  <td class="px-4 py-3 text-sm text-center font-bold text-green-600">{row.won}</td>
                  <td class="px-4 py-3 text-sm text-center font-bold text-red-500">{row.lost}</td>
                  <td class="px-4 py-3 text-sm text-center text-gray-500">{row.drawn}</td>
                  <td class={`px-4 py-3 text-sm text-center font-black ${row.team.includes('Phoenix') ? 'text-brand-purple' : 'text-brand-black'}`}>{row.points}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-12 bg-brand-offwhite rounded-xl border border-dashed border-brand-purple">
          <span class="text-5xl mb-4 block">📊</span>
          <p class="text-gray-500">Ladder not yet available for this season.</p>
        </div>
      )}

      <!-- Info about scraper -->
      <div class="mt-8 p-5 rounded-xl bg-brand-offwhite border border-gray-200">
        <h3 class="font-bold text-brand-black text-sm mb-2">About Scores Data</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Scores and ladder data is fetched from PlayHQ using the scraper script. To update the data,
          run <code class="bg-gray-200 px-1.5 py-0.5 rounded text-xs text-brand-purple">node scripts/scrape-playhq.js</code> from the project root,
          then rebuild the site. See <code class="bg-gray-200 px-1.5 py-0.5 rounded text-xs text-brand-purple">HOWTO.md</code> for detailed instructions.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
