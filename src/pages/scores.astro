---
import BaseLayout from '../layouts/BaseLayout.astro';
import DayColumn from '../components/DayColumn.astro';
import { loadWeeklyArtifact } from '../lib/scores/artifact';
import { getDayColumns, getScoresPageState, getStaleBannerText } from '../lib/scores/rendering';

const artifact = loadWeeklyArtifact();

const pageState = getScoresPageState(artifact);
const dayColumns = getDayColumns(artifact);
const staleBanner = getStaleBannerText(artifact);

const generatedAtText = artifact.generatedAt
  ? new Date(artifact.generatedAt).toLocaleString('en-AU', { dateStyle: 'medium', timeStyle: 'short' })
  : null;
---

<BaseLayout title="This Week's Games" description="Upcoming Bendigo Phoenix fixtures for this week.">
  <section class="bg-brand-purple px-4 py-14 text-center text-white">
    <h1 class="text-4xl font-black tracking-tight">This Week's Games</h1>
    <p class="mt-3 text-sm text-brand-offwhite">
      Monday to Friday fixtures for the current weekly window.
    </p>
  </section>

  <section class="bg-brand-black px-4 py-3 text-xs text-gray-200">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-2">
      <p>
        Window:
        <span class="font-semibold text-white">{artifact.window.startDate || '—'} to {artifact.window.endDate || '—'}</span>
        ({artifact.window.timezone})
      </p>
      {generatedAtText && <p>Updated: <span class="font-semibold text-white">{generatedAtText}</span></p>}
    </div>
  </section>

  {staleBanner && (
    <section class="bg-yellow-100 px-4 py-3 text-sm text-yellow-900" role="status" aria-live="polite">
      <div class="mx-auto max-w-7xl">{staleBanner}</div>
    </section>
  )}

  <section class="bg-brand-offwhite px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      {pageState === 'error' ? (
        <div class="rounded-xl border border-red-200 bg-red-50 p-6" role="alert">
          <h2 class="text-lg font-bold text-red-900">Unable to load this week's games</h2>
          <p class="mt-2 text-sm text-red-800">{artifact.error?.message ?? 'Please try again later.'}</p>
        </div>
      ) : pageState === 'empty' ? (
        <div class="rounded-xl border border-dashed border-brand-purple bg-white p-8 text-center">
          <h2 class="text-xl font-bold text-brand-purple">No games scheduled</h2>
          <p class="mt-2 text-sm text-gray-600">There are no fixtures in the current Mon–Fri window.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4" role="region" aria-label="Weekly game schedule">
          {dayColumns.map((column) => (
            <DayColumn dayId={column.key} dayLabel={column.label} fixtures={column.fixtures} />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
