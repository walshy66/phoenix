---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  existsSync,
  readFileSync,
} from 'node:fs';
import { join } from 'node:path';
import { EMPTY_WEEKLY_ARTIFACT, loadWeeklyArtifact } from '../lib/scores/artifact';
import { validateLiveScoresPayload } from '../lib/playhq/contracts';
import { isLiveDataStale } from '../lib/playhq/live-data';
import { renderScoresPageStateHtml } from '../lib/playhq/renderers';
import { loadLiveJsonSnapshot } from '../lib/playhq/server-live-data';
import type { WeeklyArtifact } from '../lib/scores/rendering';

function loadInitialWeeklyArtifact(): WeeklyArtifact {
  const publicPath = join(process.cwd(), 'public', 'live-data', 'scores.json');
  const scriptPath = join(process.cwd(), 'scripts', 'weekly-games-data.json');

  if (existsSync(publicPath)) {
    try {
      const candidate = JSON.parse(readFileSync(publicPath, 'utf-8'));
      if (validateLiveScoresPayload(candidate).ok) return candidate as WeeklyArtifact;
    } catch {
      // fall through to script snapshot
    }
  }

  if (existsSync(scriptPath)) {
    try {
      const candidate = JSON.parse(readFileSync(scriptPath, 'utf-8'));
      if (validateLiveScoresPayload(candidate).ok) return candidate as WeeklyArtifact;
    } catch {
      // fall through to empty state
    }
  }

  return loadWeeklyArtifact(scriptPath) ?? EMPTY_WEEKLY_ARTIFACT;
}

const scoresData = loadInitialWeeklyArtifact();
const lastUpdated = scoresData.generatedAt
  ? new Date(scoresData.generatedAt).toLocaleString('en-AU', {
      dateStyle: 'long',
      timeStyle: 'short',
    })
  : 'Unknown';
const isInitialStale = scoresData.generatedAt ? isLiveDataStale(scoresData.generatedAt, 15) : false;
---

<BaseLayout title="Scores" description="Bendigo Phoenix Basketball latest scores and results.">
  <!-- Page Hero -->
  <section class="bg-brand-purple py-12 lg:py-8 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-brand-gold font-bold text-sm uppercase tracking-widest mb-3">Live Updates</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white uppercase tracking-tight">THIS WEEK'S GAMES</h1>
      <div class="h-1 w-16 bg-brand-gold mx-auto mt-4"></div>
      <p class="text-purple-200 mt-4 text-base max-w-xl mx-auto">
        Follow weekly results, fixtures, and game-day outcomes across all divisions.
      </p>
    </div>
  </section>

  <!-- Last Updated -->
  <section class="bg-brand-black py-3 px-4">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-gray-400 text-xs flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-brand-gold inline-block animate-pulse"></span>
        Last updated: <span class="text-white font-medium" data-live-last-updated>{lastUpdated}</span>
      </p>
      {isInitialStale ? (
        <p class="text-xs text-amber-200" data-live-stale-banner>
          Showing last known weekly data. Live refresh is temporarily unavailable.
        </p>
      ) : (
        <p class="text-xs text-amber-200" data-live-stale-banner hidden></p>
      )}
    </div>
  </section>

  <!-- Scores Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide">Games by Day</h2>
      </div>
      <div class="h-1 w-12 bg-brand-gold mb-8"></div>

      <!-- Responsive grid class retained for compatibility with existing layout tests: grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 -->
      <div
        class="scores-live-root"
        data-live-scores-root
        data-live-data-url="/live-data/scores.json"
        data-live-refresh-ms="300000"
        data-stale-threshold-minutes="15"
        set:html={renderScoresPageStateHtml(scoresData)}
      ></div>
    </div>
  </section>

  <script>
    import { validateLiveScoresPayload } from '../lib/playhq/contracts';
    import { isLiveDataStale } from '../lib/playhq/live-data';
    import { renderScoresPageStateHtml } from '../lib/playhq/renderers';

    const refreshMs = 300000;

    function formatLastUpdated(iso: string | null | undefined): string {
      if (!iso) return 'Unknown';
      const dt = new Date(iso);
      if (Number.isNaN(dt.valueOf())) return 'Unknown';
      return dt.toLocaleString('en-AU', { dateStyle: 'long', timeStyle: 'short' });
    }

    async function refreshScores(root: HTMLElement) {
      const url = root.getAttribute('data-live-data-url');
      if (!url) return;

      try {
        const response = await fetch(url, { cache: 'no-store' });
        if (!response.ok) return;

        const payload = await response.json();
        const validation = validateLiveScoresPayload(payload);
        if (!validation.ok) return;

        const staleThresholdMinutes = Number(root.getAttribute('data-stale-threshold-minutes') ?? '15');
        if (payload.generatedAt && isLiveDataStale(payload.generatedAt, staleThresholdMinutes)) {
          payload.status = payload.status === 'error' ? 'error' : 'stale';
          payload.staleBanner = payload.staleBanner ?? 'Showing last known weekly data. Live refresh is temporarily unavailable.';
        }

        root.innerHTML = renderScoresPageStateHtml(payload);

        const lastUpdatedEl = document.querySelector('[data-live-last-updated]') as HTMLElement | null;
        if (lastUpdatedEl) lastUpdatedEl.textContent = formatLastUpdated(payload.generatedAt);

        const staleEl = document.querySelector('[data-live-stale-banner]') as HTMLElement | null;
        if (staleEl) {
          if (payload.status === 'stale') {
            staleEl.textContent = payload.staleBanner ?? 'Showing last known weekly data. Live refresh is temporarily unavailable.';
            staleEl.hidden = false;
          } else {
            staleEl.textContent = '';
            staleEl.hidden = true;
          }
        }
      } catch {
        // Keep the last known rendered state if refresh fails.
      }
    }

    document.querySelectorAll('[data-live-scores-root]').forEach((root) => {
      refreshScores(root);
      setInterval(() => refreshScores(root), refreshMs);
    });
  </script>
</BaseLayout>
