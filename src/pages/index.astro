---
import BaseLayout from '../layouts/BaseLayout.astro';
import SponsorStrip from '../components/SponsorStrip.astro';
import HeroCircularCarousel from '../components/HeroCircularCarousel.astro';
import HomeScoresCarousel from '../components/HomeScoresCarousel.astro';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import { validateHomeGamesArtifact } from '../lib/home-scores/contracts';

/**
 * HERO CAROUSEL SLIDES
 * --------------------
 * Add, remove or reorder slides here. Each slide must have:
 *   image    — path to landscape infographic image in /images/hero/
 *   alt      — screen-reader description of the image
 *   bgColor  — background colour shown while image loads (optional, default: #2a1a5e)
 *
 * Images display in 16:9 landscape format (640×360px recommended).
 * Use landscape-orientation infographics for best visual impact.
 */
const heroSlides = [
  { image: '/images/hero/players_needed.png', alt: 'Players needed announcement graphic', bgColor: '#3a2a6e' },
  { image: '/images/hero/training.png', alt: 'Training information graphic', bgColor: '#1a3060' },
  { image: '/images/hero/player_journal.png', alt: 'Player journal feature graphic', bgColor: '#2a1a5e' },
];

const quickLinks = [
  {
    title: 'Seasons',
    href: '/seasons',
    icon: '🗓️',
    desc: 'Current draw, fixtures, registration & more',
  },
  {
    title: 'Team',
    href: '/team',
    icon: '🏀',
    desc: 'Meet our players, coaches and staff',
  },
  {
    title: 'Get Involved',
    href: '/get-involved',
    icon: '🙌',
    desc: 'Volunteer, sponsor or attend our events',
  },
  {
    title: 'Coaching Resources',
    href: '/coaching-resources',
    icon: '📋',
    desc: 'Drills, plays and training materials',
  },
];

const fallbackArtifact = {
  generatedAt: new Date().toISOString(),
  status: 'error',
  window: {
    kind: 'rolling-7-days',
    startDate: '',
    endDate: '',
    timezone: 'Australia/Melbourne',
  },
  staleBanner: null,
  error: {
    code: 'ARTIFACT_MISSING',
    message: 'Scores are temporarily unavailable. Please try again later.',
  },
  games: [],
};

let homeGamesArtifact: any = fallbackArtifact;

try {
  const artifactPath = join(process.cwd(), 'scripts', 'home-games-data.json');
  if (existsSync(artifactPath)) {
    const parsed = JSON.parse(readFileSync(artifactPath, 'utf-8'));
    const valid = validateHomeGamesArtifact(parsed);
    homeGamesArtifact = valid.ok ? parsed : fallbackArtifact;
  }
} catch {
  homeGamesArtifact = fallbackArtifact;
}
---

<BaseLayout title="Home">
  <!-- ═══════════════════════════════════════════════════════
       HERO — 3D cylinder carousel
       ═══════════════════════════════════════════════════════ -->
  <section
    class="hero-section"
    style="background: linear-gradient(160deg, #573F93 0%, #3a2a6e 50%, #111111 100%);"
  >
    <!-- Logo as angled background fill — looks like it's lying flat behind cards -->
    <div class="hero-bg-logo" aria-hidden="true">
      <img
        src="/images/phoenix-united-logo.png"
        alt=""
        class="hero-bg-logo-img"
        loading="eager"
        decoding="auto"
      />
    </div>

    <div class="hero-carousel-wrap">
      <HeroCircularCarousel slides={heroSlides} autoAdvanceEnabled autoAdvanceMs={5000} />
    </div>
  </section>


  <HomeScoresCarousel artifact={homeGamesArtifact} />

  <!-- Quick Link Cards -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Explore</h2>
      <div class="h-1 w-12 bg-brand-gold mb-8"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {quickLinks.map(link => (
          <a
            href={link.href}
            class="card-hover bg-brand-purple rounded-xl p-6 flex flex-col items-start gap-3 group"
          >
            <div class="w-12 h-12 rounded-lg flex items-center justify-center text-2xl" style="background-color: rgba(139,117,54,0.2);">
              {link.icon}
            </div>
            <h3 class="text-white font-bold text-lg group-hover:text-brand-gold transition-colors">
              {link.title}
            </h3>
            <p class="text-purple-200 text-sm leading-relaxed">{link.desc}</p>
            <span class="mt-auto text-brand-gold text-sm font-medium flex items-center gap-1">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sponsor Strip -->
  <SponsorStrip />
</BaseLayout>

<style>
  /* ─── Hero section ───────────────────────────────────── */
  /*
   * No overflow:hidden — any ancestor of a preserve-3d element with
   * non-visible overflow flattens the 3D. Side cards clip at the
   * viewport edge naturally; the body prevents horizontal scroll.
   */
  .hero-section {
    position: relative;
    padding-top: 72px;   /* clear fixed nav */
    padding-bottom: 48px;
  }

  /* ─── Logo background — angled, fills space behind cards ─ */
  /*
   * The logo is positioned at the centre of the hero and tilted with
   * rotateX so it appears to lie flat on a surface behind the cards.
   * perspective() in the transform controls depth of the tilt.
   * scaleY compensates for the vertical foreshortening so the logo
   * still fills the hero height. opacity + filter keep it subtle.
   */
  .hero-bg-logo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg-logo-img {
    /* Anchor to top-left so transform-origin keeps it in that corner */
    position: absolute;
    top: 0;
    left: 0;
    width: 32%;
    max-width: 360px;
    height: auto;
    opacity: 0.16;
    filter: brightness(2.8) grayscale(10%);
    transform: perspective(500px) rotateZ(-30deg) rotateX(55deg) scale(1.2);
    transform-origin: top left;
  }

  /* ─── Carousel wrapper — full width, no side padding ─── */
  /*
   * The carousel stage is already full-width; we don't want extra
   * padding here squeezing the side cards in.
   */
  .hero-carousel-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
  }
</style>
