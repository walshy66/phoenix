---
import BaseLayout from '../layouts/BaseLayout.astro'
import SeasonTile from '../components/SeasonTile.astro'
import { SEASON_CARDS } from '../lib/seasons/constants'
import { VENUES } from '../data/venues'

const isGradingActive = false
---

<BaseLayout title="Seasons" description="Bendigo Phoenix Basketball season draw, costs, registration and grading information.">
  <section class="relative overflow-hidden bg-brand-purple px-4 py-16 text-center">
    <div class="pointer-events-none absolute inset-0 opacity-10">
      <div class="absolute -right-16 -top-16 h-64 w-64 rounded-full" style="background: #8B7536;"></div>
      <div class="absolute -bottom-16 -left-16 h-48 w-48 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-3xl">
      <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand-gold">Bendigo Phoenix</p>
      <h1 class="text-4xl font-black uppercase tracking-tight text-white sm:text-5xl">SEASONS</h1>
      <div class="mx-auto mt-4 h-1 w-16 bg-brand-gold"></div>
      <p class="mx-auto mt-4 max-w-xl text-base text-purple-200">
        Find out everything you need to know about the current season — draw, registration, costs and grading.
      </p>
    </div>
  </section>

  {VENUES.length > 0 && (
    <section aria-labelledby="training-info-heading" class="bg-brand-offwhite px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 id="training-info-heading" class="mb-2 text-2xl font-bold uppercase tracking-wide text-brand-purple">
          Club Training Information
        </h2>
        <div class="mb-8 h-1 w-12 bg-brand-gold"></div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {VENUES.map((venue) => (
            <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
              <h3 class="mb-1 text-lg font-semibold text-brand-purple">{venue.name}</h3>
              <p class="mb-1 font-mono text-sm text-gray-500">{venue.shortCode}</p>
              <p class="mb-4 text-sm text-gray-700">{venue.address}</p>

              <div class="mb-4 border-t border-gray-100 pt-4">
                <p class="mb-2 text-xs font-bold uppercase tracking-wide text-gray-500">Who trains when</p>
                {venue.trainingSchedule.map((session) => (
                  <div class="mb-3 rounded-md bg-brand-offwhite/40 p-3">
                    <p class="mb-2 text-sm font-semibold text-brand-purple">{session.day}</p>
                    <ul class="space-y-2">
                      {session.timeSlots.map((slot) => (
                        <li class="grid grid-cols-[88px_1fr] gap-3 text-sm">
                          <p class="font-semibold text-gray-900">{slot.time}</p>
                          <p class="text-gray-700">{slot.ageGroups.join(', ')}</p>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              {venue.mapUrl && (
                <a
                  href={venue.mapUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-[44px] items-center py-3 text-sm text-brand-purple underline"
                >
                  View on Map
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2" id="seasons-grid">
        {SEASON_CARDS.map((season) => <SeasonTile season={season} />)}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-start gap-4 rounded-xl border-2 border-brand-gold bg-yellow-50 p-5">
        <span class="text-3xl">🤝</span>
        <div>
          <h3 class="mb-1 text-base font-bold text-brand-black">Need Financial Assistance?</h3>
          <p class="text-sm leading-relaxed text-gray-600">
            Our <a href="/about#slam-dunk" class="font-semibold text-brand-purple underline hover:text-brand-gold">Slam Dunk Bridging Fund</a> is here to ensure no player misses out.
            Contact us confidentially at <a href="mailto:hello@bendigophoenix.org.au" class="font-semibold text-brand-purple hover:text-brand-gold">hello@bendigophoenix.org.au</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  {isGradingActive && (
    <section class="bg-brand-offwhite px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 class="mb-2 text-2xl font-bold uppercase tracking-wide text-brand-purple">Grading Information</h2>
        <div class="mb-8 h-1 w-12 bg-brand-gold"></div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <p class="mb-4 leading-relaxed text-gray-600">
              Grading sessions are used to place players in the most appropriate competition grade to ensure
              the best possible experience for all participants.
            </p>
            <p class="mb-4 leading-relaxed text-gray-600">
              All new players are required to attend a grading session. Returning players may be placed in grades
              based on their previous season's performance.
            </p>
            <p class="leading-relaxed text-gray-600">
              Grading dates will be announced closer to the season start. Watch our social media and check back here for updates.
            </p>
          </div>
          <div class="rounded-xl border border-gray-100 bg-white p-6">
            <h3 class="mb-4 text-base font-bold text-brand-purple">What to Bring to Grading</h3>
            <ul class="space-y-3">
              {[
                'Basketball shoes and appropriate sports clothing',
                'Water bottle',
                'Completed registration form',
                'Any previous season stats or team info if available',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <span class="mt-0.5 font-bold text-brand-gold">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

</BaseLayout>
