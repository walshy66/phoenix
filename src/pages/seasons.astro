---
import BaseLayout from '../layouts/BaseLayout.astro'
import SeasonTile from '../components/SeasonTile.astro'
import SeasonInfoCard from '../components/SeasonInfoCard.astro'
import SeasonInfoModal from '../components/SeasonInfoModal.astro'
import { SEASON_CARDS } from '../lib/seasons/constants'
import { VENUES } from '../data/venues'
import { SEASON_INFO_CARDS } from '../data/season-info'

const isGradingActive = false
const seasonInfoCards = Array.isArray(SEASON_INFO_CARDS) ? SEASON_INFO_CARDS : []
---

<BaseLayout title="Seasons" description="Bendigo Phoenix Basketball season draw, costs, registration and grading information.">
  <section class="relative overflow-hidden bg-brand-purple px-4 py-12 lg:py-8 text-center">
    <div class="pointer-events-none absolute inset-0 opacity-10">
      <div class="absolute -right-16 -top-16 h-64 w-64 rounded-full" style="background: #8B7536;"></div>
      <div class="absolute -bottom-16 -left-16 h-48 w-48 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-3xl">
      <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand-gold">Bendigo Phoenix</p>
      <h1 class="text-4xl font-black uppercase tracking-tight text-white sm:text-5xl">SEASONS</h1>
      <div class="mx-auto mt-4 h-1 w-16 bg-brand-gold"></div>
      <p class="mx-auto mt-4 max-w-xl text-base text-purple-200">
        Find out everything you need to know about the current season — draw, registration, costs and grading.
      </p>
    </div>
  </section>

  {seasonInfoCards.length > 0 && (
    <section aria-labelledby="season-info-heading" class="bg-brand-offwhite px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 id="season-info-heading" class="mb-2 text-2xl font-bold uppercase tracking-wide text-brand-purple">
          Season Information
        </h2>
        <div class="mb-8 h-1 w-12 bg-brand-gold"></div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {seasonInfoCards.map((card) => (
            <SeasonInfoCard
              id={card.id}
              label={card.label}
              icon={card.icon}
              description={card.description}
              ariaLabel={`${card.label} — view ${card.label.toLowerCase()} information`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {seasonInfoCards.map((card) => (
    <SeasonInfoModal card={card} venues={card.id === 'training' ? VENUES : []} />
  ))}

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2" id="seasons-grid">
        {SEASON_CARDS.map((season) => <SeasonTile season={season} />)}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-start gap-4 rounded-xl border-2 border-brand-gold bg-yellow-50 p-5">
        <span class="text-3xl">🤝</span>
        <div>
          <h3 class="mb-1 text-base font-bold text-brand-black">Need Financial Assistance?</h3>
          <p class="text-sm leading-relaxed text-gray-600">
            Our <a href="/about#slam-dunk" class="font-semibold text-brand-purple underline hover:text-brand-gold">Slam Dunk Bridging Fund</a> is here to ensure no player misses out.
            Contact us confidentially at <a href="mailto:hello@bendigophoenix.org.au" class="font-semibold text-brand-purple hover:text-brand-gold">hello@bendigophoenix.org.au</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  {isGradingActive && (
    <section class="bg-brand-offwhite px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <h2 class="mb-2 text-2xl font-bold uppercase tracking-wide text-brand-purple">Grading Information</h2>
        <div class="mb-8 h-1 w-12 bg-brand-gold"></div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <p class="mb-4 leading-relaxed text-gray-600">
              Grading sessions are used to place players in the most appropriate competition grade to ensure
              the best possible experience for all participants.
            </p>
            <p class="mb-4 leading-relaxed text-gray-600">
              All new players are required to attend a grading session. Returning players may be placed in grades
              based on their previous season's performance.
            </p>
            <p class="leading-relaxed text-gray-600">
              Grading dates will be announced closer to the season start. Watch our social media and check back here for updates.
            </p>
          </div>
          <div class="rounded-xl border border-gray-100 bg-white p-6">
            <h3 class="mb-4 text-base font-bold text-brand-purple">What to Bring to Grading</h3>
            <ul class="space-y-3">
              {[
                'Basketball shoes and appropriate sports clothing',
                'Water bottle',
                'Completed registration form',
                'Any previous season stats or team info if available',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <span class="mt-0.5 font-bold text-brand-gold">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <div
    id="infographic-zoom-overlay"
    class="fixed inset-0 z-[90] hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Expanded infographic"
    data-open="false"
  >
    <div class="absolute inset-0 bg-black/60" data-infographic-zoom-backdrop></div>
    <div class="relative z-10 flex h-full w-full items-center justify-center p-4">
      <div class="relative max-h-[92vh] max-w-[95vw] overflow-auto rounded-xl bg-white p-2 shadow-2xl">
        <button
          type="button"
          data-infographic-zoom-close
          aria-label="Close expanded infographic"
          class="absolute right-2 top-2 inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md bg-white/90 text-brand-purple shadow hover:bg-white focus:outline-none focus:ring-2 focus:ring-brand-purple"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <img id="infographic-zoom-image" src="" alt="" class="h-auto max-h-[88vh] w-auto max-w-[92vw] object-contain" />
      </div>
    </div>
  </div>

  <script>
    (function () {
      const FOCUSABLE = 'button:not([disabled]), [href], [tabindex]:not([tabindex="-1"])';
      let triggerEl: HTMLElement | null = null;
      let openModalEl: HTMLElement | null = null;
      let zoomTriggerEl: HTMLElement | null = null;

      const zoomOverlayEl = document.getElementById('infographic-zoom-overlay');
      const zoomImageEl = document.getElementById('infographic-zoom-image') as HTMLImageElement | null;

      function getModal(id: string): HTMLElement | null {
        return document.getElementById(`season-info-modal-${id}`);
      }

      function isZoomOpen() {
        return zoomOverlayEl?.getAttribute('data-open') === 'true';
      }

      function openZoom(src: string, alt: string, trigger: HTMLElement) {
        if (!zoomOverlayEl || !zoomImageEl) return;
        zoomTriggerEl = trigger;
        zoomImageEl.src = src;
        zoomImageEl.alt = alt || 'Expanded infographic';
        zoomOverlayEl.classList.remove('hidden');
        zoomOverlayEl.setAttribute('data-open', 'true');
        const closeBtn = zoomOverlayEl.querySelector<HTMLElement>('[data-infographic-zoom-close]');
        requestAnimationFrame(() => closeBtn?.focus());
      }

      function closeZoom(restoreFocus = true) {
        if (!zoomOverlayEl || !zoomImageEl) return;
        zoomOverlayEl.classList.add('hidden');
        zoomOverlayEl.setAttribute('data-open', 'false');
        zoomImageEl.src = '';
        zoomImageEl.alt = '';
        if (restoreFocus && zoomTriggerEl) zoomTriggerEl.focus();
        zoomTriggerEl = null;
      }

      function closeModal(modal: HTMLElement) {
        if (isZoomOpen()) {
          closeZoom(false);
        }
        modal.classList.add('hidden');
        modal.setAttribute('data-open', 'false');
        document.body.classList.remove('overflow-hidden');
        if (triggerEl) triggerEl.focus();
        openModalEl = null;
        triggerEl = null;
      }

      function openModal(modal: HTMLElement, trigger: HTMLElement) {
        if (openModalEl && openModalEl !== modal) {
          closeModal(openModalEl);
        }
        if (modal.dataset.open === 'true') return;

        triggerEl = trigger;
        openModalEl = modal;
        modal.classList.remove('hidden');
        modal.setAttribute('data-open', 'true');
        document.body.classList.add('overflow-hidden');

        const closeBtn = modal.querySelector<HTMLElement>('[data-close-btn]');
        requestAnimationFrame(() => closeBtn?.focus());
      }

      function trapFocus(event: KeyboardEvent, modal: HTMLElement) {
        if (event.key !== 'Tab') return;
        const nodes = Array.from(modal.querySelectorAll<HTMLElement>(FOCUSABLE));
        if (!nodes.length) return;
        const first = nodes[0];
        const last = nodes[nodes.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }

      // Wire each card button
      document.querySelectorAll<HTMLButtonElement>('[data-modal-id]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const modal = getModal(btn.dataset.modalId!);
          if (modal) openModal(modal, btn);
        });
      });

      // Wire close buttons and backdrops
      document.querySelectorAll<HTMLElement>('[data-close-btn]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const modal = btn.closest<HTMLElement>('[role="dialog"]');
          if (modal) closeModal(modal);
        });
      });

      // Zoomable infographic triggers (non-link infographics only)
      document.querySelectorAll<HTMLElement>('[data-infographic-zoom-trigger]').forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const src = trigger.dataset.zoomSrc;
          const alt = trigger.dataset.zoomAlt || 'Expanded infographic';
          if (src) openZoom(src, alt, trigger);
        });
      });

      zoomOverlayEl?.querySelector<HTMLElement>('[data-infographic-zoom-close]')?.addEventListener('click', () => {
        closeZoom();
      });

      zoomOverlayEl?.querySelector<HTMLElement>('[data-infographic-zoom-backdrop]')?.addEventListener('click', () => {
        closeZoom();
      });

      document.querySelectorAll<HTMLElement>('[data-modal-backdrop]').forEach((backdrop) => {
        backdrop.addEventListener('click', () => {
          const modal = backdrop.closest<HTMLElement>('[role="dialog"]');
          if (modal) closeModal(modal);
        });
      });

      // Global keyboard handler
      document.addEventListener('keydown', (event) => {
        if (isZoomOpen() && zoomOverlayEl) {
          if (event.key === 'Escape') {
            event.preventDefault();
            closeZoom();
            return;
          }
          trapFocus(event, zoomOverlayEl);
          return;
        }

        if (!openModalEl) return;
        if (event.key === 'Escape') {
          event.preventDefault();
          closeModal(openModalEl);
          return;
        }
        trapFocus(event, openModalEl);
      });
    })();
  </script>

</BaseLayout>
