---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { join } from 'node:path';
import { buildGameDetailViewModel } from '../../lib/scores/fixtures';
import { findFixtureById, loadWeeklyArtifact } from '../../lib/scores/artifact';
import { validateLiveScoresPayload } from '../../lib/playhq/contracts';
import { loadLiveJsonSnapshot } from '../../lib/playhq/server-live-data';
import { renderGameDetailStateHtml } from '../../lib/playhq/renderers';

export function getStaticPaths() {
  const publicPath = join(process.cwd(), 'public', 'live-data', 'scores.json');
  const scriptPath = join(process.cwd(), 'scripts', 'weekly-games-data.json');
  const artifact = loadLiveJsonSnapshot(publicPath, loadWeeklyArtifact(scriptPath), validateLiveScoresPayload);
  const fixtures = [artifact.days.monday, artifact.days.tuesday, artifact.days.wednesday, artifact.days.friday].flat();

  return fixtures
    .filter((fixture) => fixture?.fixtureId)
    .map((fixture) => ({
      params: { gameId: String(fixture.fixtureId) },
      props: { game: buildGameDetailViewModel(fixture) },
    }));
}

const gameId = Astro.params.gameId ?? '';
const game = (() => {
  const publicPath = join(process.cwd(), 'public', 'live-data', 'scores.json');
  const scriptPath = join(process.cwd(), 'scripts', 'weekly-games-data.json');
  const artifact = loadLiveJsonSnapshot(publicPath, loadWeeklyArtifact(scriptPath), validateLiveScoresPayload);
  const fixture = findFixtureById(artifact, gameId);
  return fixture ? buildGameDetailViewModel(fixture) : null;
})();
---

<BaseLayout title={game ? `${game.homeTeam} vs ${game.awayTeam}` : 'Game Not Found'}>
  <section class="bg-brand-purple py-12 px-4 text-center">
    <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight">Game Details</h1>
  </section>

  <div
    data-live-game-detail-root
    data-game-id={gameId}
    data-live-data-url="/live-data/scores.json"
    data-live-refresh-ms="300000"
    data-stale-threshold-minutes="15"
    set:html={renderGameDetailStateHtml(game)}
  ></div>

  <script>
    import { buildGameDetailViewModel } from '../../lib/scores/fixtures';
    import { validateLiveScoresPayload } from '../../lib/playhq/contracts';
    import { renderGameDetailStateHtml } from '../../lib/playhq/renderers';

    async function refreshGameDetail(root: HTMLElement) {
      const url = root.getAttribute('data-live-data-url');
      const gameId = root.getAttribute('data-game-id');
      if (!url || !gameId) return;

      try {
        const response = await fetch(url, { cache: 'no-store' });
        if (!response.ok) return;

        const payload = await response.json();
        const validation = validateLiveScoresPayload(payload);
        if (!validation.ok) return;

        const fixtures = Object.values(payload.days ?? {}).flat();
        const fixture = fixtures.find((item) => item?.fixtureId === gameId);
        const viewModel = fixture ? buildGameDetailViewModel(fixture) : null;
        root.innerHTML = renderGameDetailStateHtml(viewModel);
        document.title = viewModel ? `${viewModel.homeTeam} vs ${viewModel.awayTeam}` : 'Game Not Found';
      } catch {
        // Keep the last known rendered state if refresh fails.
      }
    }

    document.querySelectorAll('[data-live-game-detail-root]').forEach((root) => {
      refreshGameDetail(root);
      setInterval(() => refreshGameDetail(root), Number(root.getAttribute('data-live-refresh-ms') ?? '300000'));
    });
  </script>
</BaseLayout>
