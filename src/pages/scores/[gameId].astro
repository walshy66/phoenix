---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildGameDetailViewModel } from '../../lib/scores/fixtures';
import { findFixtureById, loadWeeklyArtifact } from '../../lib/scores/artifact';

export function getStaticPaths() {
  const artifact = loadWeeklyArtifact();
  const fixtures = [artifact.days.monday, artifact.days.tuesday, artifact.days.wednesday, artifact.days.friday].flat();

  return fixtures.map((fixture) => ({
    params: { gameId: fixture.fixtureId },
  }));
}

const artifact = loadWeeklyArtifact();
const fixture = findFixtureById(artifact, Astro.params.gameId || '');
const detail = fixture ? buildGameDetailViewModel(fixture) : null;
---

<BaseLayout title="Game Details" description="Fixture detail view">
  <section class="bg-brand-purple px-4 py-12 text-white">
    <div class="mx-auto max-w-4xl">
      <a href="/scores" class="text-sm underline underline-offset-2">← Back to This Week's Games</a>
      <h1 class="mt-3 text-3xl font-black">Game Details</h1>
    </div>
  </section>

  <section class="bg-brand-offwhite px-4 py-10">
    <div class="mx-auto max-w-4xl">
      {detail ? (
        <article class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-bold text-brand-purple">{detail.homeTeam} vs {detail.awayTeam}</h2>
          {detail.grade && <p class="mt-2 text-sm font-semibold uppercase tracking-wide text-gray-700">{detail.grade}</p>}

          <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <dt class="text-xs uppercase tracking-wide text-gray-500">Time</dt>
              <dd class="mt-1 text-sm text-brand-black">{detail.kickoffDisplay ?? 'TBA'}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-gray-500">Venue</dt>
              <dd class="mt-1 text-sm text-brand-black">{detail.venue ?? 'Venue TBA'}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-gray-500">Court</dt>
              <dd class="mt-1 text-sm text-brand-black">{(detail as any).court ?? 'Court TBA'}</dd>
            </div>
          </dl>

          {detail.squads?.length > 0 && (
            <section class="mt-8" aria-label="Visible squad details">
              <h3 class="text-lg font-bold text-brand-purple">Squads</h3>
              <div class="mt-3 space-y-4">
                {detail.squads.map((squad: any) => (
                  <div class="rounded-lg border border-gray-100 bg-gray-50 p-4">
                    <h4 class="text-sm font-semibold text-brand-black">{squad.teamName}</h4>
                    {squad.players?.length > 0 ? (
                      <ul class="mt-2 list-disc pl-5 text-sm text-gray-700">
                        {squad.players.map((player: any) => (
                          <li>{player.name}</li>
                        ))}
                      </ul>
                    ) : (
                      <p class="mt-2 text-sm text-gray-500">No visible player details.</p>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )}
        </article>
      ) : (
        <div class="rounded-xl border border-gray-200 bg-white p-6">
          <h2 class="text-lg font-bold text-brand-purple">Game not found</h2>
          <p class="mt-2 text-sm text-gray-600">This game may no longer be in the current weekly fixture window.</p>
          <a href="/scores" class="mt-4 inline-block text-sm font-semibold text-brand-purple underline">Return to Scores</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
