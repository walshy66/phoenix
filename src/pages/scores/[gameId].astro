---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import { toPublicGameDetail } from '../../lib/home-scores/details';

export function getStaticPaths() {
  const dataPath = join(process.cwd(), 'scripts', 'scores-data.json');
  let payload: any = { scores: [] };

  if (existsSync(dataPath)) {
    try {
      payload = JSON.parse(readFileSync(dataPath, 'utf-8'));
    } catch {
      payload = { scores: [] };
    }
  }

  const scores = Array.isArray(payload.scores) ? payload.scores : [];

  return scores
    .filter((g) => g?.id)
    .map((g) => ({
      params: { gameId: String(g.id) },
      props: { game: toPublicGameDetail(g) },
    }));
}

const { game } = Astro.props;
---

<BaseLayout title={game ? `${game.homeTeam} vs ${game.awayTeam}` : 'Game Not Found'}>
  <section class="bg-brand-purple py-12 px-4 text-center">
    <h1 class="text-3xl sm:text-4xl font-black text-white uppercase tracking-tight">Game Details</h1>
  </section>

  {game ? (
    <section class="py-10 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
      <div class="max-w-3xl mx-auto bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">{game.competition ?? 'Competition'}</p>
        <h2 class="text-2xl font-bold text-brand-purple mb-2">{game.homeTeam} vs {game.awayTeam}</h2>
        <p class="text-gray-600 text-sm mb-4">{game.date ?? 'TBA'} {game.time ? `• ${game.time.slice(0, 5)}` : '• TBA'}</p>

        <div class="grid grid-cols-2 gap-4 mb-4">
          <div class="rounded-lg bg-brand-offwhite p-4 text-center">
            <p class="text-xs text-gray-500 uppercase">Home</p>
            <p class="font-bold text-brand-black">{game.homeTeam}</p>
            <p class="text-2xl font-black text-brand-purple">{game.homeScore ?? '-'}</p>
          </div>
          <div class="rounded-lg bg-brand-offwhite p-4 text-center">
            <p class="text-xs text-gray-500 uppercase">Away</p>
            <p class="font-bold text-brand-black">{game.awayTeam}</p>
            <p class="text-2xl font-black text-brand-purple">{game.awayScore ?? '-'}</p>
          </div>
        </div>

        <p class="text-sm text-gray-600"><strong>Status:</strong> {game.status}</p>
        <p class="text-sm text-gray-600"><strong>Venue:</strong> {game.venue ?? 'TBA'}</p>
        <p class="text-sm text-gray-600"><strong>Court:</strong> {game.court ?? 'TBA'}</p>

        <div class="mt-6">
          <a href="/" class="text-brand-purple font-bold hover:underline focus-visible:outline-2 focus-visible:outline-brand-gold">
            ← Back to Home
          </a>
        </div>
      </div>
    </section>
  ) : (
    <section class="py-12 px-4">
      <div class="max-w-3xl mx-auto rounded-xl border border-gray-200 bg-white p-6 text-center">
        <h2 class="text-xl font-bold text-brand-black mb-2">Game not found</h2>
        <p class="text-gray-600 text-sm mb-4">This game may be unavailable or no longer in the published dataset.</p>
        <a href="/scores" class="text-brand-purple font-bold hover:underline">View all scores</a>
      </div>
    </section>
  )}
</BaseLayout>
