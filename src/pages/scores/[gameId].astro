---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { existsSync, readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import { loadWeeklyArtifact } from '../../lib/scores/artifact';
import { renderGameDetail } from '../../lib/playhq/round-renderer';
import { renderGameDetailStateHtml } from '../../lib/playhq/renderers';

function loadFallbackGame(gameId: string) {
  const teamsDetailsPath = join(process.cwd(), 'scripts', 'teams-details.json');
  if (existsSync(teamsDetailsPath)) {
    try {
      const parsed = JSON.parse(readFileSync(teamsDetailsPath, 'utf8'));
      for (const team of Object.values(parsed.teamDetails ?? {})) {
        const game = (team as any)?.fixture?.find((item: any) => String(item?.id) === gameId);
        if (game) {
          return game;
        }
      }
    } catch {
      // ignore
    }
  }

  const roundsDir = join(process.cwd(), 'public', 'live-data', 'rounds');
  if (existsSync(roundsDir)) {
    for (const file of readdirSync(roundsDir)) {
      if (!/^round-\d+\.json$/.test(file)) continue;
      try {
        const parsed = JSON.parse(readFileSync(join(roundsDir, file), 'utf8'));
        const game = (parsed.games ?? []).find((item: any) => String(item?.id) === gameId);
        if (game) return game;
      } catch {
        // ignore malformed round files during dev
      }
    }
  }

  const artifact = loadWeeklyArtifact();
  const fixtures = [artifact.days.monday, artifact.days.tuesday, artifact.days.wednesday, artifact.days.friday].flat();
  return fixtures.find((fixture) => String(fixture?.fixtureId) === gameId) ?? null;
}

export function getStaticPaths() {
  const ids = new Set<string>();
  const roundsDir = join(process.cwd(), 'public', 'live-data', 'rounds');

  if (existsSync(roundsDir)) {
    for (const file of readdirSync(roundsDir)) {
      if (!/^round-\d+\.json$/.test(file)) continue;
      try {
        const parsed = JSON.parse(readFileSync(join(roundsDir, file), 'utf8'));
        for (const game of parsed.games ?? []) {
          if (game?.id) ids.add(String(game.id));
        }
      } catch {
        // ignore malformed round files during dev
      }
    }
  }

  const artifact = loadWeeklyArtifact();
  const fixtures = [artifact.days.monday, artifact.days.tuesday, artifact.days.wednesday, artifact.days.friday].flat();
  for (const fixture of fixtures) {
    if (fixture?.fixtureId) ids.add(String(fixture.fixtureId));
  }

  const teamsDetailsPath = join(process.cwd(), 'scripts', 'teams-details.json');
  if (existsSync(teamsDetailsPath)) {
    try {
      const parsed = JSON.parse(readFileSync(teamsDetailsPath, 'utf8'));
      for (const team of Object.values(parsed.teamDetails ?? {})) {
        for (const game of (team as any)?.fixture ?? []) {
          if (game?.id) ids.add(String(game.id));
        }
      }
    } catch {
      // ignore
    }
  }

  return [...ids].map((gameId) => ({ params: { gameId } }));
}

const gameId = Astro.params.gameId ?? '';
const initialGame = loadFallbackGame(gameId);
---

<BaseLayout title="Game Details">
  <section class="bg-brand-purple py-12 px-4 text-center">
    <h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tight text-white">Game Details</h1>
  </section>

  <section class="px-4 py-8 sm:px-6 lg:px-8">
    <div id="game-detail-message" class="mx-auto max-w-4xl rounded-2xl border border-gray-200 bg-white px-4 py-3 text-gray-700" hidden>
      Loading game details...
    </div>
    <div id="game-detail-root" class="mt-6" set:html={initialGame ? renderGameDetail(initialGame) : renderGameDetailStateHtml(null)}></div>
  </section>

</BaseLayout>
