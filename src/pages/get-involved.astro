---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventTile from '../components/EventTile.astro';
import EventModal from '../components/EventModal.astro';
import { getUpcomingEvents, getPastEvents } from '../lib/events/filters';

// Read and parse events from events.md
const eventsData = await import('../data/events.md?raw');

// Parse the markdown frontmatter blocks
function parseEvents(raw) {
  const blocks = raw.split(/^---\s*$/m);
  const events = [];

  for (let i = 1; i < blocks.length; i += 2) { // Skip first empty block
    const frontmatter = blocks[i].trim();
    if (!frontmatter) continue;

    try {
      // Parse YAML frontmatter
      const event = {};
      frontmatter.split('\n').forEach(line => {
        const [key, ...valueParts] = line.split(': ');
        if (key && valueParts.length > 0) {
          const value = valueParts.join(': ').trim();
          // Remove quotes if present
          const cleanedValue = value.replace(/^["']|["']$/g, '');
          event[key.trim()] = cleanedValue;
        }
      });

      // Only add events with required fields
      if (event.id && event.title && event.date && event.image && event.status) {
        events.push(event);
      }
    } catch (e) {
      console.warn('Failed to parse event block:', frontmatter.slice(0, 100));
    }
  }

  return events;
}

const allEvents = parseEvents(eventsData.default);
const upcomingEvents = getUpcomingEvents(allEvents);
const pastEvents = getPastEvents(allEvents);

const sponsorTiers = [
  {
    tier: 'Gold Sponsor',
    amount: 'Contact us',
    perks: ['Logo on jerseys', 'Major website presence', 'Social media shoutouts', 'Event recognition'],
    accent: '#8B7536',
  },
  {
    tier: 'Silver Sponsor',
    amount: 'Contact us',
    perks: ['Logo on team banner', 'Website listing', 'Social media mentions'],
    accent: '#573F93',
  },
  {
    tier: 'Bronze Sponsor',
    amount: 'Contact us',
    perks: ['Website listing', 'Acknowledgment in club communications'],
    accent: '#111111',
  },
];
---

<BaseLayout title="Get Involved" description="Get involved with Bendigo Phoenix Basketball — events, sponsorship and volunteering opportunities.">
  <!-- Page Hero -->
  <section class="bg-brand-purple py-16 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-brand-gold font-bold text-sm uppercase tracking-widest mb-3">Community</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white uppercase tracking-tight">GET INVOLVED</h1>
      <div class="h-1 w-16 bg-brand-gold mx-auto mt-4"></div>
      <p class="text-purple-200 mt-4 text-base max-w-xl mx-auto">
        There are many ways to be part of the Phoenix family — play, volunteer, sponsor or support.
      </p>
    </div>
  </section>

  <!-- Events Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      {upcomingEvents.length > 0 ? (
        <>
          <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Upcoming Events</h2>
          <div class="h-1 w-12 bg-brand-gold mb-8"></div>

          <div class="relative">
            <!-- Carousel Container -->
            <div class="overflow-hidden">
              <div class="carousel-upcoming transition-transform duration-300 ease-in-out flex gap-6" style={`transform: translateX(0)`}>
                {upcomingEvents.map(event => (
                  <div class="flex-shrink-0 w-1/4">
                    <EventTile
                      id={event.id}
                      title={event.title}
                      date={event.date}
                      time={event.time || undefined}
                      location={event.location || undefined}
                      description={event.description || undefined}
                      image={event.image}
                      alt={event.alt || undefined}
                      category={event.category}
                    />
                  </div>
                ))}
              </div>
            </div>

            <!-- Navigation Arrows -->
            {upcomingEvents.length > 4 && (
              <>
                <button class="carousel-prev-upcoming absolute left-0 top-1/2 -translate-y-1/2 -translate-x-16 p-2 rounded-full bg-brand-purple text-white hover:bg-brand-purple/80 transition-colors z-10" aria-label="Previous events">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                  </svg>
                </button>
                <button class="carousel-next-upcoming absolute right-0 top-1/2 -translate-y-1/2 translate-x-16 p-2 rounded-full bg-brand-purple text-white hover:bg-brand-purple/80 transition-colors z-10" aria-label="Next events">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
              </>
            )}
          </div>
        </>
      ) : (
        <p class="text-gray-500 text-center py-8">No upcoming events scheduled. Check back soon!</p>
      )}
    </div>
  </section>

  {pastEvents.length > 0 ? (
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Past Events</h2>
        <div class="h-1 w-12 bg-brand-gold mb-8"></div>

        <div class="relative">
          <!-- Carousel Container -->
          <div class="overflow-hidden">
            <div class="carousel-past transition-transform duration-300 ease-in-out flex gap-6" style={`transform: translateX(0)`}>
              {pastEvents.map(event => (
                <div class="flex-shrink-0 w-1/4">
                  <EventTile
                    id={event.id}
                    title={event.title}
                    date={event.date}
                    time={event.time || undefined}
                    location={event.location || undefined}
                    description={event.description || undefined}
                    image={event.image}
                    alt={event.alt || undefined}
                    category={event.category || 'Event'}
                  />
                </div>
              ))}
            </div>
          </div>

          <!-- Navigation Arrows -->
          {pastEvents.length > 4 && (
            <>
              <button class="carousel-prev-past absolute left-0 top-1/2 -translate-y-1/2 -translate-x-16 p-2 rounded-full bg-brand-purple text-white hover:bg-brand-purple/80 transition-colors z-10" aria-label="Previous events">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
              </button>
              <button class="carousel-next-past absolute right-0 top-1/2 -translate-y-1/2 translate-x-16 p-2 rounded-full bg-brand-purple text-white hover:bg-brand-purple/80 transition-colors z-10" aria-label="Next events">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </button>
            </>
          )}
        </div>
      </div>
    </section>
  ) : (
    <p class="text-gray-500 text-center py-8 bg-brand-offwhite">No past events to display.</p>
  )}

  <EventModal />

  <!-- Sponsors Section -->
  <section id="sponsors" class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-purple uppercase tracking-wide mb-2">Sponsorship</h2>
      <div class="h-1 w-12 bg-brand-gold mb-4"></div>
      <p class="text-gray-600 mb-8 max-w-2xl">
        Sponsoring Bendigo Phoenix Basketball Club is a great way to connect with the local community
        while supporting the growth of basketball in Central Victoria.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {sponsorTiers.map(tier => (
          <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 card-hover">
            <div class="h-2" style={`background-color: ${tier.accent};`}></div>
            <div class="p-6">
              <h3 class="font-black text-brand-black text-xl mb-1">{tier.tier}</h3>
              <p class="text-brand-purple font-bold text-sm mb-4">{tier.amount}</p>
              <ul class="space-y-2">
                {tier.perks.map(perk => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <span class="text-brand-gold font-bold">✓</span>
                    {perk}
                  </li>
                ))}
              </ul>
              <a
                href="mailto:hello@bendigophoenix.org.au?subject=Sponsorship%20Enquiry"
                class="mt-6 block text-center py-2.5 rounded-lg text-sm font-bold text-white transition-colors"
                style={`background-color: ${tier.accent};`}
              >
                Get in Touch
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Current Sponsors display -->
      <div class="bg-white rounded-xl p-6 border border-gray-100">
        <h3 class="font-bold text-brand-purple text-sm uppercase tracking-wide mb-4">Current Sponsors</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
          {Array.from({ length: 6 }).map((_, i) => (
            <div class="h-16 bg-gray-100 rounded-lg flex items-center justify-center border border-dashed border-gray-300">
              <span class="text-xs text-gray-400">Sponsor {i + 1}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Volunteers Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl mx-auto bg-brand-purple rounded-2xl p-8 text-center">
        <span class="text-5xl mb-4 block">🙋</span>
        <h2 class="text-2xl font-black text-white uppercase tracking-wide mb-3">Volunteer With Us</h2>
        <div class="h-1 w-12 bg-brand-gold mx-auto mb-5"></div>
        <p class="text-purple-200 leading-relaxed mb-4">
          Our club relies on the generosity of volunteers to operate. Whether you can help with score-keeping,
          canteen duty, event organisation or social media — every contribution makes a difference.
        </p>
        <p class="text-purple-200 leading-relaxed mb-8">
          We welcome parents, community members and basketball enthusiasts of all backgrounds.
          No experience necessary — just a willingness to help!
        </p>
        <a
          href="mailto:hello@bendigophoenix.org.au?subject=Volunteering%20Enquiry"
          class="inline-flex items-center gap-2 bg-brand-gold text-white px-8 py-4 rounded-lg font-bold text-base hover:opacity-90 transition-opacity"
        >
          ✉️ Express Your Interest
        </a>
      </div>
    </div>
  </section>

  <script>
    function setupCarousel(carouselSelector: string, prevBtnSelector: string, nextBtnSelector: string) {
      const carousel = document.querySelector(carouselSelector) as HTMLElement;
      const prevBtn = document.querySelector(prevBtnSelector) as HTMLButtonElement;
      const nextBtn = document.querySelector(nextBtnSelector) as HTMLButtonElement;

      if (!carousel || !prevBtn || !nextBtn) return;

      let position = 0;
      const cardWidth = carousel.children[0]?.getBoundingClientRect().width || 0;
      const gap = 24; // 6 * 4px (gap-6)
      const cardPlusGap = cardWidth + gap;
      const maxPosition = -(carousel.children.length - 4) * cardPlusGap;

      function updateCarousel() {
        carousel.style.transform = `translateX(${position}px)`;
      }

      prevBtn.addEventListener('click', () => {
        if (position < 0) {
          position += cardPlusGap;
          updateCarousel();
        }
      });

      nextBtn.addEventListener('click', () => {
        if (position > maxPosition) {
          position -= cardPlusGap;
          updateCarousel();
        }
      });
    }

    // Setup both carousels
    setupCarousel('.carousel-upcoming', '.carousel-prev-upcoming', '.carousel-next-upcoming');
    setupCarousel('.carousel-past', '.carousel-prev-past', '.carousel-next-past');
  </script>
</BaseLayout>
