---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Court Time Calculator"
  description="Generate an even court time rotation for 7–9 players across 2 × 20 minute halves."
>
  <!-- Page Hero -->
  <section class="bg-brand-purple py-16 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-brand-gold font-bold text-sm uppercase tracking-widest mb-3">Coach Toolkit</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white uppercase tracking-tight">COURT TIME CALCULATOR</h1>
      <div class="h-1 w-16 bg-brand-gold mx-auto mt-4"></div>
      <p class="text-purple-200 mt-4 text-base max-w-xl mx-auto">
        Enter your roster of 7–9 players and generate an even court time rotation across both halves.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">

    <!-- Session Data Notice — always visible -->
    <div class="bg-amber-50 border border-brand-gold rounded-lg p-4 mb-8" role="note" aria-label="Session data notice">
      <div class="flex gap-3">
        <span class="text-brand-gold text-lg flex-shrink-0" aria-hidden="true">&#9888;</span>
        <p class="text-sm text-gray-700">
          <strong class="text-brand-black">Your data is not saved.</strong>
          Player names and the generated plan exist only in this browser tab. If you close or refresh the page, all data will be lost.
        </p>
      </div>
    </div>

    <!-- SECTION: Roster Entry (combined roster + starter/finisher selection) -->
    <section id="section-roster-entry">
      <h2 class="text-xl font-bold text-brand-black mb-1">Enter Roster &amp; Select Starters</h2>
      <p class="text-gray-500 text-sm mb-5">Add 7–9 players, select exactly 5 starters, and optionally pin 3 finishers for the end of the game.</p>

      <!-- Error summary -->
      <div id="form-error-summary" class="hidden bg-red-50 border border-red-300 rounded-lg p-4 mb-5" role="alert">
        <p class="text-red-700 text-sm font-medium" id="form-error-message"></p>
      </div>

      <!-- Roster table -->
      <div class="overflow-x-auto mb-4">
        <table class="w-full border-collapse" aria-label="Player roster with starter and finisher selection">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide py-2 pr-3 w-8">#</th>
              <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide py-2 pr-3">Player Name</th>
              <th class="text-center text-xs font-semibold text-brand-purple uppercase tracking-wide py-2 px-2 w-16">Starter</th>
              <th class="text-center text-xs font-semibold text-gray-500 uppercase tracking-wide py-2 pl-2 w-16">Finisher</th>
            </tr>
          </thead>
          <tbody id="player-tbody">
            <!-- Row 1 -->
            <tr class="player-row border-b border-gray-100" id="row-player-1">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">1</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-1" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="1" aria-label="Starter: Player 1" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="1" aria-label="Finisher: Player 1" />
              </td>
            </tr>
            <!-- Row 2 -->
            <tr class="player-row border-b border-gray-100" id="row-player-2">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">2</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-2" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="2" aria-label="Starter: Player 2" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="2" aria-label="Finisher: Player 2" />
              </td>
            </tr>
            <!-- Row 3 -->
            <tr class="player-row border-b border-gray-100" id="row-player-3">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">3</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-3" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="3" aria-label="Starter: Player 3" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="3" aria-label="Finisher: Player 3" />
              </td>
            </tr>
            <!-- Row 4 -->
            <tr class="player-row border-b border-gray-100" id="row-player-4">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">4</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-4" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="4" aria-label="Starter: Player 4" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="4" aria-label="Finisher: Player 4" />
              </td>
            </tr>
            <!-- Row 5 -->
            <tr class="player-row border-b border-gray-100" id="row-player-5">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">5</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-5" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="5" aria-label="Starter: Player 5" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="5" aria-label="Finisher: Player 5" />
              </td>
            </tr>
            <!-- Row 6 -->
            <tr class="player-row border-b border-gray-100" id="row-player-6">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">6</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-6" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="6" aria-label="Starter: Player 6" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="6" aria-label="Finisher: Player 6" />
              </td>
            </tr>
            <!-- Row 7 -->
            <tr class="player-row border-b border-gray-100" id="row-player-7">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">7</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-7" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="7" aria-label="Starter: Player 7" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="7" aria-label="Finisher: Player 7" />
              </td>
            </tr>
            <!-- Row 8 (hidden by default) -->
            <tr class="player-row hidden border-b border-gray-100" id="row-player-8">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">8</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-8" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="8" aria-label="Starter: Player 8" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="8" aria-label="Finisher: Player 8" />
              </td>
            </tr>
            <!-- Row 9 (hidden by default) -->
            <tr class="player-row hidden border-b border-gray-100" id="row-player-9">
              <td class="py-2 pr-3 text-sm text-gray-400 align-middle">9</td>
              <td class="py-2 pr-3 align-middle">
                <input type="text" id="input-player-9" class="player-input w-full h-9 px-3 rounded border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-brand-purple focus:border-brand-purple" autocomplete="off" placeholder="Enter player name" />
              </td>
              <td class="py-2 px-2 text-center align-middle">
                <input type="checkbox" class="starter-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="9" aria-label="Starter: Player 9" />
              </td>
              <td class="py-2 pl-2 text-center align-middle">
                <input type="checkbox" class="finisher-checkbox w-4 h-4 rounded accent-brand-purple cursor-pointer" data-player-num="9" aria-label="Finisher: Player 9" />
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Selection status counters -->
      <div class="flex gap-4 mb-5 text-sm" aria-live="polite" aria-atomic="true">
        <span id="starter-counter" class="font-semibold text-gray-500">0/5 Starters</span>
        <span id="finisher-counter" class="text-gray-400">0/3 Finishers (optional)</span>
      </div>

      <!-- Add / Remove Player buttons -->
      <div class="flex gap-3 mb-6">
        <button
          type="button"
          id="btn-add-player"
          class="h-9 px-4 rounded border border-brand-purple text-brand-purple text-sm font-medium hover:bg-brand-offwhite transition-colors disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple"
        >
          + Add Player
        </button>
        <button
          type="button"
          id="btn-remove-player"
          class="h-9 px-4 rounded border border-gray-300 text-gray-600 text-sm font-medium hover:bg-gray-50 transition-colors disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple"
          disabled
        >
          − Remove Player
        </button>
      </div>

      <!-- Generate button -->
      <button
        type="button"
        id="btn-generate"
        disabled
        class="w-full h-11 bg-brand-purple text-white font-bold rounded-lg transition-colors text-sm disabled:opacity-40 disabled:cursor-not-allowed hover:bg-purple-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
      >
        Generate Plan
      </button>
      <p id="generate-error" class="hidden text-red-600 text-sm mt-3">Plan generation failed. Please try again.</p>
    </section>

    <!-- SECTION: Plan Display (hidden by default) -->
    <section id="section-plan-display" class="hidden">
      <h2 class="text-xl font-bold text-brand-black mb-4">Rotation Plan</h2>

      <!-- Gantt chart -->
      <div id="gantt-container" class="mb-4">
        <!-- Gantt chart rendered by JavaScript -->
      </div>

      <!-- Accessible text summary -->
      <details id="gantt-summary" class="mt-4 mb-6 border border-gray-200 rounded-lg" aria-label="Court time summary — player-by-player breakdown">
        <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-brand-black hover:bg-gray-50 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple">Court time summary</summary>
        <div id="gantt-summary-content" class="px-4 pb-4 pt-2">
          <!-- Populated by JavaScript -->
        </div>
      </details>

      <!-- Starting lineups -->
      <div id="starting-lineups" class="mt-4 mb-4 border border-gray-200 rounded-lg p-4">
        <h3 class="text-sm font-bold text-brand-black mb-3">Starting Lineups</h3>
        <div id="starting-lineups-content" class="space-y-3">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <!-- Substitution events list -->
      <div id="substitution-events" class="mt-4 mb-6 border border-gray-200 rounded-lg p-4">
        <h3 class="text-sm font-bold text-brand-black mb-3">Substitution Events</h3>
        <div id="substitution-events-content" class="space-y-4">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-3">
        <button
          id="btn-start-over"
          type="button"
          class="h-11 flex-1 bg-brand-purple text-white font-bold rounded-lg hover:bg-purple-800 transition-colors text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-gold focus-visible:ring-offset-2"
        >
          Start Over
        </button>
        <button
          id="btn-export-pdf"
          type="button"
          disabled
          aria-label="Export substitution sheet as PDF"
          class="h-11 flex-1 bg-gray-200 text-gray-500 font-bold rounded-lg text-sm opacity-50 cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple"
        >
          Export PDF
        </button>
      </div>
      <p id="pdf-error" class="hidden text-red-600 text-sm mt-3">PDF export failed. Please try again.</p>
    </section>

  </div>
</BaseLayout>

<script>
  import { generateRotationPlan, derivePlayerSchedules } from '../lib/court-time/algorithm';
  import type { Player, RotationPlan, PlayerSchedule } from '../lib/court-time/types';

  // ---------------------------------------------------------------------------
  // App state
  // ---------------------------------------------------------------------------
  type AppState = 'roster-entry' | 'plan-display';

  let appState: AppState = 'roster-entry';
  let currentPlan: RotationPlan | null = null;
  let currentSchedules: PlayerSchedule[] = [];

  // Sets tracking checked player numbers (1-based)
  const starterNums = new Set<number>();
  const finisherNums = new Set<number>();

  // ---------------------------------------------------------------------------
  // DOM refs
  // ---------------------------------------------------------------------------
  const sectionRosterEntry = document.getElementById('section-roster-entry')!;
  const sectionPlanDisplay = document.getElementById('section-plan-display')!;
  const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
  const btnAddPlayer = document.getElementById('btn-add-player') as HTMLButtonElement;
  const btnRemovePlayer = document.getElementById('btn-remove-player') as HTMLButtonElement;
  const formErrorSummary = document.getElementById('form-error-summary')!;
  const formErrorMessage = document.getElementById('form-error-message')!;
  const starterCounter = document.getElementById('starter-counter')!;
  const finisherCounter = document.getElementById('finisher-counter')!;

  // ---------------------------------------------------------------------------
  // Render dispatch
  // ---------------------------------------------------------------------------
  function render(): void {
    sectionRosterEntry.classList.toggle('hidden', appState !== 'roster-entry');
    sectionPlanDisplay.classList.toggle('hidden', appState !== 'plan-display');
  }

  // ---------------------------------------------------------------------------
  // Row helpers
  // ---------------------------------------------------------------------------
  function getPlayerRows(): HTMLElement[] {
    return Array.from(document.querySelectorAll<HTMLElement>('.player-row'));
  }

  function getVisibleRows(): HTMLElement[] {
    return getPlayerRows().filter(row => !row.classList.contains('hidden'));
  }

  function updateAddRemoveButtons(): void {
    const count = getVisibleRows().length;
    btnAddPlayer.disabled = count >= 9;
    btnRemovePlayer.disabled = count <= 7;
  }

  // ---------------------------------------------------------------------------
  // Status counters and Generate button enable/disable
  // ---------------------------------------------------------------------------
  function updateStatus(): void {
    const sc = starterNums.size;
    const fc = finisherNums.size;

    // Starter counter
    if (sc === 5) {
      starterCounter.textContent = '5/5 Starters ✓';
      starterCounter.className = 'font-semibold text-green-600';
    } else {
      starterCounter.textContent = `${sc}/5 Starters`;
      starterCounter.className = 'font-semibold text-gray-500';
    }

    // Finisher counter
    if (fc === 3) {
      finisherCounter.textContent = '3/3 Finishers ✓';
      finisherCounter.className = 'text-green-600';
    } else if (fc === 0) {
      finisherCounter.textContent = '0/3 Finishers (optional)';
      finisherCounter.className = 'text-gray-400';
    } else {
      finisherCounter.textContent = `${fc}/3 Finishers`;
      finisherCounter.className = 'text-amber-600';
    }

    // Generate: need 5 starters, and finishers must be 0 or 3
    const finishersOk = fc === 0 || fc === 3;
    btnGenerate.disabled = !(sc === 5 && finishersOk);
  }

  // ---------------------------------------------------------------------------
  // Checkbox limit enforcement
  // ---------------------------------------------------------------------------
  function enforceCheckboxLimits(): void {
    const starterCheckboxes = document.querySelectorAll<HTMLInputElement>('.starter-checkbox');
    const finisherCheckboxes = document.querySelectorAll<HTMLInputElement>('.finisher-checkbox');

    starterCheckboxes.forEach(cb => {
      const num = parseInt(cb.dataset.playerNum!, 10);
      const row = document.getElementById(`row-player-${num}`);
      if (row?.classList.contains('hidden')) return;
      if (!starterNums.has(num)) {
        cb.disabled = starterNums.size >= 5;
      }
    });

    finisherCheckboxes.forEach(cb => {
      const num = parseInt(cb.dataset.playerNum!, 10);
      const row = document.getElementById(`row-player-${num}`);
      if (row?.classList.contains('hidden')) return;
      if (!finisherNums.has(num)) {
        cb.disabled = finisherNums.size >= 3;
      }
    });
  }

  // ---------------------------------------------------------------------------
  // Checkbox change handlers
  // ---------------------------------------------------------------------------
  function handleStarterChange(cb: HTMLInputElement): void {
    const num = parseInt(cb.dataset.playerNum!, 10);
    if (cb.checked) {
      starterNums.add(num);
    } else {
      starterNums.delete(num);
    }
    enforceCheckboxLimits();
    updateStatus();
  }

  function handleFinisherChange(cb: HTMLInputElement): void {
    const num = parseInt(cb.dataset.playerNum!, 10);
    if (cb.checked) {
      finisherNums.add(num);
    } else {
      finisherNums.delete(num);
    }
    enforceCheckboxLimits();
    updateStatus();
  }

  // Wire up checkbox listeners
  document.querySelectorAll<HTMLInputElement>('.starter-checkbox').forEach(cb => {
    cb.addEventListener('change', () => handleStarterChange(cb));
  });
  document.querySelectorAll<HTMLInputElement>('.finisher-checkbox').forEach(cb => {
    cb.addEventListener('change', () => handleFinisherChange(cb));
  });

  // ---------------------------------------------------------------------------
  // Add / Remove player
  // ---------------------------------------------------------------------------
  btnAddPlayer.addEventListener('click', () => {
    const rows = getPlayerRows();
    const firstHidden = rows.find(row => row.classList.contains('hidden'));
    if (firstHidden) {
      firstHidden.classList.remove('hidden');
      updateAddRemoveButtons();
      enforceCheckboxLimits();
    }
  });

  btnRemovePlayer.addEventListener('click', () => {
    const visible = getVisibleRows();
    if (visible.length <= 7) return;
    const last = visible[visible.length - 1];
    const num = parseInt(last.id.replace('row-player-', ''), 10);

    // Uncheck and clear checkboxes for this row
    const starterCb = last.querySelector<HTMLInputElement>('.starter-checkbox');
    const finisherCb = last.querySelector<HTMLInputElement>('.finisher-checkbox');
    if (starterCb) { starterCb.checked = false; starterCb.disabled = false; }
    if (finisherCb) { finisherCb.checked = false; finisherCb.disabled = false; }
    starterNums.delete(num);
    finisherNums.delete(num);

    // Clear input
    const input = last.querySelector<HTMLInputElement>('.player-input');
    if (input) input.value = '';

    last.classList.add('hidden');
    updateAddRemoveButtons();
    enforceCheckboxLimits();
    updateStatus();
  });

  // ---------------------------------------------------------------------------
  // Validation helpers
  // ---------------------------------------------------------------------------
  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function showFormError(msg: string): void {
    formErrorSummary.classList.remove('hidden');
    formErrorMessage.textContent = msg;
  }

  function clearFormError(): void {
    formErrorSummary.classList.add('hidden');
    formErrorMessage.textContent = '';
  }

  // ---------------------------------------------------------------------------
  // Generate Plan
  // ---------------------------------------------------------------------------
  btnGenerate.addEventListener('click', () => {
    clearFormError();

    const visible = getVisibleRows();

    // Collect players from visible rows
    const playerList: { num: number; name: string }[] = [];
    let hasBlank = false;
    for (const row of visible) {
      const num = parseInt(row.id.replace('row-player-', ''), 10);
      const input = row.querySelector<HTMLInputElement>('.player-input')!;
      const trimmed = input.value.trim();
      if (!trimmed) {
        input.setAttribute('aria-invalid', 'true');
        input.classList.remove('border-gray-300');
        input.classList.add('border-red-500');
        hasBlank = true;
      } else {
        input.removeAttribute('aria-invalid');
        input.classList.remove('border-red-500');
        input.classList.add('border-gray-300');
        playerList.push({ num, name: trimmed });
      }
    }

    if (hasBlank) {
      showFormError('Please enter a name for each player.');
      return;
    }

    if (playerList.length < 7 || playerList.length > 9) {
      showFormError(`You must have 7–9 players. Currently: ${playerList.length}.`);
      return;
    }

    if (starterNums.size !== 5) {
      showFormError('Please select exactly 5 starters.');
      return;
    }

    const fc = finisherNums.size;
    if (fc !== 0 && fc !== 3) {
      showFormError('Finishers must be 0 or exactly 3. Currently: ' + fc + '.');
      return;
    }

    // Build Player objects indexed by roster order
    const players: Player[] = playerList.map((p, idx) => ({ id: `p${idx}`, name: p.name }));

    // Map player nums → Player objects
    const numToPlayer = new Map(playerList.map((p, idx) => [p.num, players[idx]]));

    // Build startingFive: players whose num is in starterNums, in roster order
    const startingFive: Player[] = players.filter((_, idx) => starterNums.has(playerList[idx].num));
    if (startingFive.length !== 5) {
      showFormError('Could not resolve 5 starters. Please re-select.');
      return;
    }

    // Build finishers array (empty or 3 players, in roster order)
    const finishers: Player[] = fc === 3
      ? players.filter((_, idx) => finisherNums.has(playerList[idx].num))
      : [];

    const generateError = document.getElementById('generate-error')!;
    generateError.classList.add('hidden');

    try {
      currentPlan = generateRotationPlan(players, startingFive, finishers.length > 0 ? finishers : undefined);
      currentSchedules = derivePlayerSchedules(currentPlan);
    } catch (err) {
      console.error('Plan generation failed:', err);
      generateError.classList.remove('hidden');
      return;
    }

    appState = 'plan-display';
    render();
    renderGantt(currentSchedules);
    if (currentPlan) renderSubstitutionEvents(currentPlan);

    // Enable Export PDF button
    const btnExport = document.getElementById('btn-export-pdf') as HTMLButtonElement;
    btnExport.disabled = false;
    btnExport.classList.remove('opacity-50', 'cursor-not-allowed', 'bg-gray-200', 'text-gray-500');
    btnExport.classList.add('bg-brand-purple', 'text-white', 'hover:bg-purple-800');
    btnExport.onclick = () => { if (currentPlan) exportPdf(currentPlan); };
  });

  // ---------------------------------------------------------------------------
  // Gantt chart rendering
  // ---------------------------------------------------------------------------
  function truncateName(name: string, maxLen = 30): string {
    return name.length > maxLen ? name.slice(0, maxLen - 1) + '…' : name;
  }

  function renderGantt(schedules: PlayerSchedule[]): void {
    const container = document.getElementById('gantt-container')!;
    const axisTicks = [0, 5, 10, 15, 20, 25, 30, 35, 40];
    const finisherIds = currentPlan?.finishers ? new Set(currentPlan.finishers.map(p => p.id)) : new Set<string>();

    function getCountdownLabel(minute: number): string {
      const minuteInHalf = minute % 20;
      return `${20 - minuteInHalf}`;
    }

    let html = `<div class="overflow-x-auto">`;
    html += `<div style="min-width:600px; position:relative; padding-left:120px;">`;

    // Time axis
    html += `<div style="position:relative; height:24px; margin-bottom:4px;">`;
    for (const tick of axisTicks) {
      const pct = (tick / 40) * 100;
      const alignStyle = tick === 0
        ? 'transform:none; left:0;'
        : tick === 40
          ? 'transform:translateX(-100%); left:100%;'
          : 'transform:translateX(-50%);';
      html += `<span style="position:absolute; left:${pct}%; ${alignStyle} font-size:11px; color:#6b7280; white-space:nowrap;">${getCountdownLabel(tick)}'</span>`;
    }
    html += `</div>`;

    // Player rows
    for (const schedule of schedules) {
      const label = truncateName(schedule.player.name);
      const isFinisher = finisherIds.has(schedule.player.id);
      const labelSuffix = isFinisher ? ' <span style="font-size:10px; color:#6b7280;">(F)</span>' : '';
      html += `<div style="display:flex; align-items:center; margin-bottom:6px; position:relative;">`;
      html += `<div style="position:absolute; left:-120px; width:116px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:13px; font-weight:500; color:#111;" title="${escapeHtml(schedule.player.name)}">${escapeHtml(label)}${labelSuffix}</div>`;
      html += `<div style="position:relative; flex:1; height:32px;">`;

      for (const stint of schedule.stints) {
        const widthPct = (stint.durationMinutes / 40) * 100;
        const leftPct = (stint.startMinute / 40) * 100;
        const bgStyle = stint.type === 'on-court'
          ? 'background:var(--color-brand-purple, #5b2d8e);'
          : 'background:var(--color-brand-offwhite, #f5f3ee); border:1px solid #d1d5db;';
        const title = `${schedule.player.name}: ${stint.type} min ${stint.startMinute}–${stint.endMinute}`;
        html += `<div style="position:absolute; top:0; bottom:0; left:${leftPct}%; width:${widthPct}%; min-width:8px; ${bgStyle} border-radius:3px;" title="${escapeHtml(title)}"></div>`;
      }

      html += `</div></div>`;
    }

    // Half-time marker — sits at chart 50% = left-padding + (chart-width / 2)
    // = 120px + (100% - 120px) / 2 = 50% + 60px
    html += `<div style="position:absolute; left:calc(50% + 60px); top:24px; bottom:0; width:2px; background:var(--color-brand-gold, #c8a84b); pointer-events:none; z-index:1;" aria-hidden="true"></div>`;

    // Half labels
    html += `<div style="position:relative; height:20px; margin-top:4px;">`;
    html += `<span style="position:absolute; left:25%; transform:translateX(-50%); font-size:11px; color:#6b7280;">Half 1</span>`;
    html += `<span style="position:absolute; left:75%; transform:translateX(-50%); font-size:11px; color:#6b7280;">Half 2</span>`;
    html += `</div>`;

    html += `</div></div>`;
    container.innerHTML = html;

    // Accessible summary
    const summaryContent = document.getElementById('gantt-summary-content')!;
    let summaryHtml = `<ul class="space-y-1">`;
    for (const schedule of schedules) {
      const onCourtMinutes = schedule.stints
        .filter(s => s.type === 'on-court')
        .reduce((sum, s) => sum + s.durationMinutes, 0);
      summaryHtml += `<li class="text-sm text-gray-700"><span class="font-medium">${escapeHtml(schedule.player.name)}</span>: ${onCourtMinutes} min on court</li>`;
    }
    summaryHtml += `</ul>`;
    summaryContent.innerHTML = summaryHtml;
  }

  // ---------------------------------------------------------------------------
  // Substitution events rendering
  // ---------------------------------------------------------------------------
  function renderSubstitutionEvents(plan: RotationPlan): void {
    // Starting lineups
    const lineupsContainer = document.getElementById('starting-lineups-content')!;
    let lineupsHtml = '';
    for (const half of plan.halves) {
      const halfTitle = half.halfNumber === 1 ? 'First Half' : 'Second Half';
      const names = half.startingFive.map(p => escapeHtml(p.name)).join(', ');
      lineupsHtml += `<div><span class="text-xs font-bold text-gray-500 uppercase">${halfTitle}</span><p class="text-sm text-gray-800 mt-0.5">${names}</p></div>`;
    }
    lineupsContainer.innerHTML = lineupsHtml;

    const container = document.getElementById('substitution-events-content')!;
    let html = '';

    for (const half of plan.halves) {
      const halfTitle = half.halfNumber === 1 ? 'First Half' : 'Second Half';
      html += `<div>`;
      html += `<h4 class="text-xs font-bold text-gray-600 uppercase mb-2">${halfTitle}</h4>`;

      if (half.substitutions.length === 0) {
        html += `<p class="text-sm text-gray-500">No substitutions</p>`;
      } else {
        html += `<ul class="space-y-1">`;
        for (const sub of half.substitutions) {
          const countdownMin = 20 - sub.gameClockMinute;
          const timeStr = `${String(countdownMin).padStart(2, '0')}:00`;
          const playersIn = sub.playersComingOn.map(p => escapeHtml(p.name)).join(', ');
          const playersOut = sub.playersSittingDown.map(p => escapeHtml(p.name)).join(', ');
          html += `<li class="text-sm text-gray-700"><span class="font-mono font-medium">${timeStr}</span> — <span class="text-green-700">${playersIn}</span> IN, <span class="text-red-700">${playersOut}</span> OUT</li>`;
        }
        html += `</ul>`;
      }
      html += `</div>`;
    }

    container.innerHTML = html;
  }

  // ---------------------------------------------------------------------------
  // PDF Export
  // ---------------------------------------------------------------------------
  async function exportPdf(plan: RotationPlan): Promise<void> {
    const pdfError = document.getElementById('pdf-error')!;
    try {
      const { jsPDF } = await import('jspdf');
      const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
      const marginLeft = 20;
      const marginRight = 20;
      const pageWidth = doc.internal.pageSize.getWidth();
      const workingWidth = pageWidth - marginLeft - marginRight;
      let y = 20;

      function writeLine(text: string, opts: { bold?: boolean; size?: number; indent?: number } = {}): void {
        const fontSize = opts.size ?? 11;
        const indent = opts.indent ?? 0;
        doc.setFontSize(fontSize);
        doc.setFont('helvetica', opts.bold ? 'bold' : 'normal');
        const lines = doc.splitTextToSize(text, workingWidth - indent);
        doc.text(lines, marginLeft + indent, y);
        y += (fontSize * 0.3528 + 1) * (Array.isArray(lines) ? lines.length : 1);
      }

      function addVerticalSpace(mm: number): void { y += mm; }

      writeLine('Bendigo Phoenix — Court Time Calculator', { bold: true, size: 14 });
      addVerticalSpace(3);
      const dateStr = new Date().toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
      writeLine(`${dateStr} — ${plan.roster.length} players`, { size: 10 });
      addVerticalSpace(6);

      doc.setLineWidth(0.3);
      doc.line(marginLeft, y, pageWidth - marginRight, y);
      addVerticalSpace(5);

      function renderHalf(halfIndex: 0 | 1): void {
        const half = plan.halves[halfIndex];
        const halfLabel = halfIndex === 0 ? 'First Half' : 'Second Half';
        writeLine(halfLabel, { bold: true, size: 13 });
        addVerticalSpace(2);
        const starterNames = half.startingFive.map(p => p.name).join(', ');
        const starterPrefix = halfIndex === 1 ? 'Starting (algorithm selected): ' : 'Starting: ';
        writeLine(starterPrefix + starterNames, { size: 10, indent: 2 });
        addVerticalSpace(4);

        if (half.substitutions.length === 0) {
          writeLine('No substitutions this half.', { size: 10, indent: 2 });
        } else {
          const sorted = [...half.substitutions].sort((a, b) => a.gameClockMinute - b.gameClockMinute);
          for (const event of sorted) {
            const remaining = 20 - event.gameClockMinute;
            const display = String(remaining).padStart(2, '0') + ':00';
            const inNames = event.playersComingOn.map(p => p.name).join(', ');
            const outNames = event.playersSittingDown.map(p => p.name).join(', ');
            writeLine(`${display} — ${inNames} IN, ${outNames} OUT`, { size: 10, indent: 2 });
            addVerticalSpace(1);
            doc.setLineWidth(0.1);
            doc.setDrawColor(200, 200, 200);
            doc.line(marginLeft + 2, y, pageWidth - marginRight, y);
            doc.setDrawColor(0, 0, 0);
            addVerticalSpace(2);
          }
        }
        addVerticalSpace(4);
      }

      renderHalf(0);
      doc.setLineWidth(0.5);
      doc.line(marginLeft, y, pageWidth - marginRight, y);
      addVerticalSpace(5);
      renderHalf(1);

      const footerText = 'Generated by Bendigo Phoenix Coach Toolkit — session data not saved';
      doc.setFontSize(8);
      doc.setFont('helvetica', 'normal');
      doc.setTextColor(150, 150, 150);
      doc.text(footerText, pageWidth / 2, doc.internal.pageSize.getHeight() - 10, { align: 'center' });
      doc.setTextColor(0, 0, 0);

      const isIos = /iP(ad|hone|od)/i.test(navigator.userAgent);
      if (isIos) {
        window.open(doc.output('bloburl') as unknown as string, '_blank');
      } else {
        doc.save('court-time-calculator.pdf');
      }
      pdfError.classList.add('hidden');
    } catch (err) {
      console.error('PDF export error:', err);
      pdfError.classList.remove('hidden');
    }
  }

  // ---------------------------------------------------------------------------
  // Start Over
  // ---------------------------------------------------------------------------
  document.getElementById('btn-start-over')!.addEventListener('click', () => {
    currentPlan = null;
    currentSchedules = [];

    document.getElementById('gantt-container')!.innerHTML = '';
    const summaryContent = document.getElementById('gantt-summary-content');
    if (summaryContent) summaryContent.innerHTML = '';
    const subEventsContent = document.getElementById('substitution-events-content');
    if (subEventsContent) subEventsContent.innerHTML = '';

    // Clear all inputs + checkboxes
    for (let i = 1; i <= 9; i++) {
      const input = document.getElementById(`input-player-${i}`) as HTMLInputElement | null;
      if (input) {
        input.value = '';
        input.removeAttribute('aria-invalid');
        input.classList.remove('border-red-500');
        input.classList.add('border-gray-300');
      }
      const stCb = document.querySelector<HTMLInputElement>(`.starter-checkbox[data-player-num="${i}"]`);
      if (stCb) { stCb.checked = false; stCb.disabled = false; }
      const finCb = document.querySelector<HTMLInputElement>(`.finisher-checkbox[data-player-num="${i}"]`);
      if (finCb) { finCb.checked = false; finCb.disabled = false; }
    }
    starterNums.clear();
    finisherNums.clear();

    // Hide rows 8 & 9
    for (let i = 8; i <= 9; i++) {
      document.getElementById(`row-player-${i}`)?.classList.add('hidden');
    }

    clearFormError();
    document.getElementById('generate-error')?.classList.add('hidden');

    // Re-disable Export PDF
    const btnExport = document.getElementById('btn-export-pdf') as HTMLButtonElement;
    btnExport.disabled = true;
    btnExport.onclick = null;
    btnExport.classList.add('opacity-50', 'cursor-not-allowed', 'bg-gray-200', 'text-gray-500');
    btnExport.classList.remove('bg-brand-purple', 'text-white', 'hover:bg-purple-800');
    document.getElementById('pdf-error')?.classList.add('hidden');

    updateAddRemoveButtons();
    updateStatus();
    appState = 'roster-entry';
    render();
  });

  // ---------------------------------------------------------------------------
  // Initial state
  // ---------------------------------------------------------------------------
  updateAddRemoveButtons();
  updateStatus();
  render();
</script>
