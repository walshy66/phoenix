</BaseLayout>

<style>
  .dropdown-menu {
    display: block;
  }

  .dropdown-menu.hidden {
    display: none;
  }

  .dropdown-item {
    cursor: pointer;
  }

  .dropdown-item:hover {
    background-color: rgba(139, 117, 54, 0.1);
  }
</style>

<script define:vars={{ teamsData, ageGroupOrder }}>
  // Get DOM elements
  const filterBar = document.getElementById('filter-bar');
  const filterButtons = filterBar.querySelectorAll('.filter-btn[data-filter-type][data-filter-value]');
  const ageGroupSections = document.getElementById('age-group-sections');
  const noTeamsMessage = document.getElementById('no-teams-message');
  const clearFilterBtn = document.getElementById('clear-filter-btn');
  const ageGroupBtn = document.getElementById('ageGroupBtn');
  const gameDayBtn = document.getElementById('gameDayBtn');
  const gradeBtn = document.getElementById('gradeBtn');

  const chevronSvg = '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>';

  function setDropdownButtonLabel(button, label) {
    button.innerHTML = `${label} ${chevronSvg}`;
  }

  function resetDropdownButtonLabels() {
    setDropdownButtonLabel(ageGroupBtn, 'Age group');
    setDropdownButtonLabel(gameDayBtn, 'Game Day');
    setDropdownButtonLabel(gradeBtn, 'Grade');
    ageGroupBtn.setAttribute('aria-expanded', 'false');
    gameDayBtn.setAttribute('aria-expanded', 'false');
    gradeBtn.setAttribute('aria-expanded', 'false');
    ageGroupDropdown.classList.add('hidden');
    gameDayDropdown.classList.add('hidden');
    gradeDropdown.classList.add('hidden');
  }

  // Teams data from parsed JSON
  const teams = teamsData.teams || [];

  // Additive filter state
  let currentFilters = {
    gender: null,
    ageGroup: null,
    gameDay: null,
    grade: null,
  };

  function hasAnyActiveFilter() {
    return Boolean(currentFilters.gender || currentFilters.ageGroup || currentFilters.gameDay || currentFilters.grade);
  }

  function setChipActiveState(button, isActive) {
    if (isActive) {
      button.classList.add('bg-brand-purple', 'text-white', 'active');
      button.classList.remove('bg-white', 'text-brand-purple', 'hover:bg-brand-offwhite');
      if (button.hasAttribute('aria-pressed')) button.setAttribute('aria-pressed', 'true');
    } else {
      button.classList.remove('bg-brand-purple', 'text-white', 'active');
      button.classList.add('bg-white', 'text-brand-purple', 'hover:bg-brand-offwhite');
      if (button.hasAttribute('aria-pressed')) button.setAttribute('aria-pressed', 'false');
    }
  }

  // Update chip/dropdown active states
  function updateFilterButtonStates() {
    filterButtons.forEach(btn => {
      const type = btn.getAttribute('data-filter-type');
      const value = btn.getAttribute('data-filter-value');

      let isActive = false;
      if (type === 'all') {
        isActive = !hasAnyActiveFilter();
      } else if (type === 'gender') {
        isActive = currentFilters.gender === value;
      }

      setChipActiveState(btn, isActive);
    });

    setChipActiveState(ageGroupBtn, Boolean(currentFilters.ageGroup));
    setChipActiveState(gameDayBtn, Boolean(currentFilters.gameDay));
    setChipActiveState(gradeBtn, Boolean(currentFilters.grade));
  }

  function applyCurrentFilters() {
    let filteredTeams = teams.map(team => {
      const parsed = parseGradeName(team.gradeName);
      return { ...team, ...parsed };
    });

    if (currentFilters.gender) {
      filteredTeams = filteredTeams.filter(team => team.gender.toLowerCase() === currentFilters.gender);
    }
    if (currentFilters.ageGroup) {
      filteredTeams = filteredTeams.filter(team => team.ageGroup === currentFilters.ageGroup);
    }
    if (currentFilters.gameDay) {
      filteredTeams = filteredTeams.filter(team => team.gameNight.toLowerCase() === currentFilters.gameDay);
    }
    if (currentFilters.grade) {
      filteredTeams = filteredTeams.filter(team => {
        const divisionNum = parseInt(team.division.replace('DIV ', ''));
        return divisionNum === parseInt(currentFilters.grade);
      });
    }

    renderTeams(filteredTeams);
    updateFilterButtonStates();
    sessionStorage.setItem('teams-filter', JSON.stringify(currentFilters));
  }

  function resetAllFilters() {
    currentFilters = {
      gender: null,
      ageGroup: null,
      gameDay: null,
      grade: null,
    };
    resetDropdownButtonLabels();
    applyCurrentFilters();
  }

  function setFilter(type, value) {
    if (type === 'all') {
      resetAllFilters();
      return;
    }

    if (type === 'gender') currentFilters.gender = value;
    if (type === 'ageGroup') currentFilters.ageGroup = value;
    if (type === 'gameDay') currentFilters.gameDay = value.toLowerCase();
    if (type === 'grade') currentFilters.grade = value;

    applyCurrentFilters();
  }

  // Initialize page
  function init() {
    const savedFilter = sessionStorage.getItem('teams-filter');
    if (savedFilter) {
      try {
        const parsed = JSON.parse(savedFilter);

        // backward compatibility: prior single-filter state
        if (parsed && parsed.type && parsed.value) {
          currentFilters = { gender: null, ageGroup: null, gameDay: null, grade: null };
          if (parsed.type !== 'all') {
            if (parsed.type === 'gender') currentFilters.gender = parsed.value;
            if (parsed.type === 'ageGroup') currentFilters.ageGroup = parsed.value;
            if (parsed.type === 'gameDay') currentFilters.gameDay = String(parsed.value).toLowerCase();
            if (parsed.type === 'grade') currentFilters.grade = parsed.value;
          }
        } else {
          currentFilters = {
            gender: parsed?.gender ?? null,
            ageGroup: parsed?.ageGroup ?? null,
            gameDay: parsed?.gameDay ?? null,
            grade: parsed?.grade ?? null,
          };
        }
      } catch (e) {
        console.warn('Failed to parse saved filter state', e);
      }
    }

    if (currentFilters.ageGroup) {
      setDropdownButtonLabel(ageGroupBtn, currentFilters.ageGroup.charAt(0).toUpperCase() + currentFilters.ageGroup.slice(1));
    }
    if (currentFilters.gameDay) {
      setDropdownButtonLabel(gameDayBtn, currentFilters.gameDay.charAt(0).toUpperCase() + currentFilters.gameDay.slice(1));
    }
    if (currentFilters.grade) {
      setDropdownButtonLabel(gradeBtn, String(currentFilters.grade));
    }

    applyCurrentFilters();
  }

  // Parse grade name function (same as in Astro)
  function parseGradeName(gradeName) {
    // Example: "Monday U10 Boys 1" -> { ageGroup: 'u10s', gender: 'Boys', gameNight: 'Monday', division: 'DIV 1' }
    const match = gradeName.match(/^(\w+)\s+(U\d+)\s+(\w+)\s+(\d+)$/);
    if (!match) {
      return {
        ageGroup: 'unknown',
        gender: 'TBC',
        gameNight: 'TBC',
        division: 'TBC',
      };
    }

    const [, gameNight, ageGroupStr, gender, divisionNum] = match;

    // Convert U10 -> u10s
    const ageGroup = ageGroupStr.toLowerCase() + 's';

    // Convert division number to DIV format
    const division = `DIV ${divisionNum}`;

    return {
      ageGroup,
      gender,
      gameNight,
      division,
    };
  }

  // Render teams grouped by age group
  function renderTeams(filteredTeams) {
    // Clear existing content
    ageGroupSections.innerHTML = '';

    if (filteredTeams.length === 0) {
      noTeamsMessage.classList.remove('hidden');
      return;
    } else {
      noTeamsMessage.classList.add('hidden');
    }

    // Group teams by age group
    const teamsByAgeGroup = {};
    filteredTeams.forEach(team => {
      if (!teamsByAgeGroup[team.ageGroup]) {
        teamsByAgeGroup[team.ageGroup] = [];
      }
      teamsByAgeGroup[team.ageGroup].push(team);
    });

    // Create sections for each age group in order
    ageGroupOrder.forEach(ageGroup => {
      const teamsInGroup = teamsByAgeGroup[ageGroup] || [];

      // Skip if no teams in this age group (don't create orphan headers)
      if (teamsInGroup.length === 0) {
        return;
      }

      // Sort teams alphabetically by name
      teamsInGroup.sort((a, b) => a.name.localeCompare(b.name));

      // Create age group section
      const section = document.createElement('div');
      section.className = 'age-group-section';

      const header = document.createElement('h2');
      header.className = 'text-2xl font-bold text-brand-purple mb-4';
      header.textContent = ageGroup.toUpperCase();

      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6';

      // Create team tiles
      teamsInGroup.forEach(team => {
        const tile = document.createElement('a');
        tile.href = `/teams/${team.slug}`;
        tile.className = 'team-tile card-hover block bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 flex flex-col';

        // Determine pill colors based on values
        const getPillClass = (value, type) => {
          if (value === 'TBC') {
            return 'bg-gray-200 text-gray-500 text-xs font-medium px-3 py-1 rounded-full';
          }

          switch (type) {
            case 'division':
              return 'bg-brand-purple text-white text-xs font-medium px-3 py-1 rounded-full';
            case 'gameNight':
              return 'bg-brand-gold text-white text-xs font-medium px-3 py-1 rounded-full';
            case 'gender':
              if (value.toLowerCase() === 'boys') {
                return 'bg-gray-700 text-white text-xs font-medium px-3 py-1 rounded-full';
              } else if (value.toLowerCase() === 'girls') {
                return 'bg-purple-200 text-brand-purple text-xs font-medium px-3 py-1 rounded-full';
              }
              return 'bg-gray-200 text-gray-500 text-xs font-medium px-3 py-1 rounded-full';
            default:
              return 'bg-gray-200 text-gray-500 text-xs font-medium px-3 py-1 rounded-full';
          }
        };

        tile.innerHTML = `
          <div class="bg-brand-black px-4 py-2 flex items-center justify-between">
            <span class="text-gray-400 text-xs font-medium uppercase tracking-wide">Team Profile</span>
            <span class="${getPillClass(team.division, 'division')}">${team.division}</span>
          </div>
          <div class="p-4 flex-1">
            <h3 class="font-bold text-brand-black text-lg mb-3">${team.name}</h3>
            <div class="flex flex-wrap gap-2">
              <span class="${getPillClass(team.gameNight, 'gameNight')}">${team.gameNight}</span>
              <span class="${getPillClass(team.gender, 'gender')}">${team.gender}</span>
            </div>
          </div>
        `;

        grid.appendChild(tile);
      });

      section.appendChild(header);
      section.appendChild(grid);
      ageGroupSections.appendChild(section);
    });
  }

  // Get dropdown elements
  const ageGroupDropdown = document.getElementById('ageGroupDropdown');
  const gameDayDropdown = document.getElementById('gameDayDropdown');
  const gradeDropdown = document.getElementById('gradeDropdown');

  // Event listeners for filter buttons
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.getAttribute('data-filter-type');
      const value = btn.getAttribute('data-filter-value');

      // Apply direct-chip filters (All, Boys, Girls)
      if (!type || !value) return;
      setFilter(type, value);
    });
  });

  // Event listeners for dropdown items
  const dropdownItems = document.querySelectorAll('.dropdown-item');
  dropdownItems.forEach(item => {
    item.addEventListener('click', () => {
      const type = item.getAttribute('data-filter-type');
      const value = item.getAttribute('data-filter-value');
      if (!type || !value) return;

      setFilter(type, value);

      // Close the dropdown
      const dropdown = item.closest('.dropdown-menu');
      dropdown.classList.add('hidden');

      // Update button text and aria-expanded
      const buttonId = dropdown.id.replace('Dropdown', 'Btn');
      const button = document.getElementById(buttonId);
      const label = value.charAt(0).toUpperCase() + value.slice(1);
      setDropdownButtonLabel(button, label);
      button.setAttribute('aria-expanded', 'false');
    });
  });

  // Toggle dropdowns
  document.getElementById('ageGroupBtn').addEventListener('click', () => {
    const isOpen = ageGroupDropdown.classList.toggle('hidden');
    document.getElementById('ageGroupBtn').setAttribute('aria-expanded', String(!isOpen));
    // Close other dropdowns
    gameDayDropdown.classList.add('hidden');
    gradeDropdown.classList.add('hidden');
    document.getElementById('gameDayBtn').setAttribute('aria-expanded', 'false');
    document.getElementById('gradeBtn').setAttribute('aria-expanded', 'false');
  });

  document.getElementById('gameDayBtn').addEventListener('click', () => {
    const isOpen = gameDayDropdown.classList.toggle('hidden');
    document.getElementById('gameDayBtn').setAttribute('aria-expanded', String(!isOpen));
    // Close other dropdowns
    ageGroupDropdown.classList.add('hidden');
    gradeDropdown.classList.add('hidden');
    document.getElementById('ageGroupBtn').setAttribute('aria-expanded', 'false');
    document.getElementById('gradeBtn').setAttribute('aria-expanded', 'false');
  });

  document.getElementById('gradeBtn').addEventListener('click', () => {
    const isOpen = gradeDropdown.classList.toggle('hidden');
    document.getElementById('gradeBtn').setAttribute('aria-expanded', String(!isOpen));
    // Close other dropdowns
    ageGroupDropdown.classList.add('hidden');
    gameDayDropdown.classList.add('hidden');
    document.getElementById('ageGroupBtn').setAttribute('aria-expanded', 'false');
    document.getElementById('gameDayBtn').setAttribute('aria-expanded', 'false');
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', (event) => {
    if (!event.target.closest('.relative')) {
      ageGroupDropdown.classList.add('hidden');
      gameDayDropdown.classList.add('hidden');
      gradeDropdown.classList.add('hidden');
      document.getElementById('ageGroupBtn').setAttribute('aria-expanded', 'false');
      document.getElementById('gameDayBtn').setAttribute('aria-expanded', 'false');
      document.getElementById('gradeBtn').setAttribute('aria-expanded', 'false');
    }
  });

  // Clear filter button
  clearFilterBtn.addEventListener('click', () => {
    resetAllFilters();
  });

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>