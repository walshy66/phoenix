---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

// Try to load teams data from JSON file, fall back to placeholder
let teamsData = {
  lastUpdated: '2026-04-12T00:00:00.000Z',
  note: "Placeholder data for Teams page development",
  teams: [
    {
      id: 'team-001',
      name: 'PHOENIX Mini Mets',
      gradeName: 'Monday U10 Boys 1',
      slug: 'phoenix-mini-mets',
    },
    {
      id: 'team-002',
      name: 'PHOENIX Junior Jets',
      gradeName: 'Wednesday U10 Girls 2',
      slug: 'phoenix-junior-jets',
    },
    {
      id: 'team-003',
      name: 'PHOENIX Rising Stars',
      gradeName: 'Tuesday U12 Boys 1',
      slug: 'phoenix-rising-stars',
    },
    {
      id: 'team-004',
      name: 'PHOENIX Future Flames',
      gradeName: 'Thursday U12 Girls 1',
      slug: 'phoenix-future-flames',
    },
    {
      id: 'team-005',
      name: 'PHOENIX Young Guns',
      gradeName: 'Monday U14 Boys 2',
      slug: 'phoenix-young-guns',
    },
    {
      id: 'team-006',
      name: 'PHOENIX Emerald Emus',
      gradeName: 'Friday U14 Girls 3',
      slug: 'phoenix-emerald-emus',
    },
    {
      id: 'team-007',
      name: 'PHOENIX Teen Titans',
      gradeName: 'Wednesday U16 Boys 1',
      slug: 'phoenix-teen-titans',
    },
    {
      id: 'team-008',
      name: 'PHOENIX Sapphire Seahawks',
      gradeName: 'Thursday U16 Girls 2',
      slug: 'phoenix-sapphire-seahawks',
    },
    {
      id: 'team-009',
      name: 'PHOENIX Senior Squad',
      gradeName: 'Tuesday U18 Boys 1',
      slug: 'phoenix-senior-squad',
    },
    {
      id: 'team-010',
      name: 'PHOENIX Ruby Rockets',
      gradeName: 'Friday U18 Girls 1',
      slug: 'phoenix-ruby-rockets',
    },
  ],
};

try {
  // Try to load from PlayHQ scraper output first
  const playhqPath = join(process.cwd(), 'scripts', 'teams-data.json');
  if (existsSync(playhqPath)) {
    const raw = readFileSync(playhqPath, 'utf-8');
    teamsData = JSON.parse(raw);
  } else {
    // Fall back to placeholder data
    const dataPath = join(process.cwd(), 'src', 'data', 'teams', 'teams.json');
    if (existsSync(dataPath)) {
      const raw = readFileSync(dataPath, 'utf-8');
      teamsData = JSON.parse(raw);
    }
  }
} catch (e) {
  console.warn('Failed to load teams data:', e);
  // Use placeholder data
}

// Helper functions to derive team metadata from gradeName
const parseGradeName = (gradeName) => {
  // Example: "Monday U10 Boys 1" -> { ageGroup: 'u10s', gender: 'Boys', gameNight: 'Monday', division: 'DIV 1' }
  const match = gradeName.match(/^(\w+)\s+(U\d+)\s+(\w+)\s+(\d+)$/);
  if (!match) {
    return {
      ageGroup: 'unknown',
      gender: 'TBC',
      gameNight: 'TBC',
      division: 'TBC',
    };
  }

  const [, gameNight, ageGroupStr, gender, divisionNum] = match;

  // Convert U10 -> u10s
  const ageGroup = ageGroupStr.toLowerCase() + 's';

  // Convert division number to DIV format
  const division = `DIV ${divisionNum}`;

  return {
    ageGroup,
    gender,
    gameNight,
    division,
  };
};

// Order of age groups for display
const ageGroupOrder = ['u10s', 'u12s', 'u14s', 'u16s', 'u18s'];
---

<BaseLayout title="Teams" description="Find your perfect team at Bendigo Phoenix Basketball Club.">
  <!-- Page Hero -->
  <section class="bg-brand-purple py-12 lg:py-8 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full" style="background: #8B7536;"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <p class="text-brand-gold font-bold text-sm uppercase tracking-widest mb-3">Bendigo Phoenix Juniors</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white uppercase tracking-tight">TEAMS</h1>
      <div class="h-1 w-16 bg-brand-gold mx-auto mt-4"></div>
      <p class="text-purple-200 mt-4 text-base max-w-xl mx-auto">
        Explore Phoenix teams by age group, division, and game night.
      </p>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="bg-white border-b border-gray-100 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-2 py-3" id="filter-bar">
        <button
          data-filter-type="all"
          data-filter-value="all"
          class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors duration-150 border bg-brand-purple text-white border-brand-purple active"
          aria-pressed="true"
        >
          All
        </button>
        <button 
          data-filter-type="gender"
          data-filter-value="boys"
          class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors duration-150 border bg-white text-brand-purple border-brand-purple hover:bg-brand-offwhite"
          aria-pressed="false"
        >
          Boys
        </button>
        <button
          data-filter-type="gender"
          data-filter-value="girls"
          class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors duration-150 border bg-white text-brand-purple border-brand-purple hover:bg-brand-offwhite"
          aria-pressed="false"
        >
          Girls
        </button>
        <!-- Age Group Dropdown -->
        <div class="relative">
          <button
            id="ageGroupBtn"
            class="filter-btn flex-shrink-0 inline-flex items-center justify-center gap-1.5 whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors duration-150 border bg-white text-brand-purple border-brand-purple hover:bg-brand-offwhite"
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            Age group
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="ageGroupDropdown" class="dropdown-menu hidden absolute left-0 mt-2 w-56 bg-white border border-gray-200 rounded-md shadow-lg z-20">
            <div class="py-1">
              <button
                type="button"
                data-filter-type="ageGroup"
                data-filter-value="u10s"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                u10s
              </button>
              <button
                type="button"
                data-filter-type="ageGroup"
                data-filter-value="u12s"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                u12s
              </button>
              <button
                type="button"
                data-filter-type="ageGroup"
                data-filter-value="u14s"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                u14s
              </button>
              <button
                type="button"
                data-filter-type="ageGroup"
                data-filter-value="u16s"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                u16s
              </button>
              <button
                type="button"
                data-filter-type="ageGroup"
                data-filter-value="u18s"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                u18s
              </button>
            </div>
          </div>
        </div>
        <!-- Game Day Dropdown -->
        <div class="relative">
          <button
            id="gameDayBtn"
            class="filter-btn flex-shrink-0 inline-flex items-center justify-center gap-1.5 whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors duration-150 border bg-white text-brand-purple border-brand-purple hover:bg-brand-offwhite"
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            Game Day
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="gameDayDropdown" class="dropdown-menu hidden absolute left-0 mt-2 w-56 bg-white border border-gray-200 rounded-md shadow-lg z-20">
            <div class="py-1">
              <button
                type="button"
                data-filter-type="gameDay"
                data-filter-value="monday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                Monday
