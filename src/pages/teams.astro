            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Teams Grid -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-brand-offwhite">
    <div class="max-w-7xl mx-auto" id="teams-container">
      {/* Teams will be grouped by ageGroup and rendered here - populated by JavaScript */}
      <div class="space-y-8" id="age-group-sections">
        {/* Age group sections will be injected here by JavaScript */}
      </div>

      {/* Placeholder message when no teams match filter */}
      <div class="mt-12 text-center bg-white rounded-xl p-8 border border-dashed border-brand-purple hidden" id="no-teams-message">
        <p class="text-brand-purple font-bold text-lg mb-2">No teams match this filter</p>
        <button class="text-sm font-medium text-brand-purple hover:text-brand-purple/80" id="clear-filter-btn">
          Clear filter
        </button>
      </div>
    </div>
