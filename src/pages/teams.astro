                data-filter-value="saturday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                Saturday
              </button>
              <button
                type="button"
                data-filter-type="gameDay"
                data-filter-value="sunday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                Sunday
              </button>
            </div>
          </div>
        </div>
        <!-- Grade Dropdown -->
        <div class="relative">
          <button
            id="gradeBtn"
            class="filter-btn flex-shrink-0 inline-flex items-center justify-center gap-1.5 whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors duration-150 border bg-white text-brand-purple border-brand-purple hover:bg-brand-offwhite"
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            Grade
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="gradeDropdown" class="dropdown-menu hidden absolute left-0 mt-2 w-56 bg-white border border-gray-200 rounded-md shadow-lg z-20">
            <div class="py-1">
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="1"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                1
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="2"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                2
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="3"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                3
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="4"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                4
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="5"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                5
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="6"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                6
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="7"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                7
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="8"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                8
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="9"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                9
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="10"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                10
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="11"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                11
              </button>
              <button
                type="button"
                data-filter-type="grade"
                data-filter-value="12"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                12
