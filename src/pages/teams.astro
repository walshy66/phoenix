              <button
                type="button"
                data-filter-type="gameDay"
                data-filter-value="tuesday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                Tuesday
              </button>
              <button
                type="button"
                data-filter-type="gameDay"
                data-filter-value="wednesday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                Wednesday
              </button>
              <button
                type="button"
                data-filter-type="gameDay"
                data-filter-value="thursday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
              >
                Thursday
              </button>
              <button
                type="button"
                data-filter-type="gameDay"
                data-filter-value="friday"
                class="dropdown-item w-full text-left px-4 py-2 hover:bg-brand-offwhite"
