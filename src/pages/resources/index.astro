---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterBar from '../../components/FilterBar.astro';
import ResourceTabs from '../../components/ResourceTabs.astro';
import ResourceItem from '../../components/ResourceItem.astro';
import PositionResponsibilitiesCarousel from '../../components/PositionResponsibilitiesCarousel.astro';
import ResourceModal from '../../components/ResourceModal.astro';
import coachingResources from '../../data/coaching-resources.json';
import playerResources from '../../data/player-resources.json';
import managerResources from '../../data/manager-resources.json';
import guides from '../../data/guides.json';
import forms from '../../data/forms.json';
import type { ActiveFilters, Resource, ResourceSection } from '../../lib/resources/types';
import {
  filterResources,
  getAvailableAgeGroups,
  getAvailableCategories,
  getFilterSummary,
  getSectionLabel,
} from '../../lib/resources/filters';
import { extractAvailableSkills } from '../../lib/resources/skills';

const createPositionResponsibilitiesResource = (section: ResourceSection, id: string): Resource & { modalTarget: string } => ({
  id,
  title: 'Basketball Positions & Responsibilities',
  description: 'Open a carousel of the role overview and position responsibility images.',
  section,
  type: 'image_jpeg',
  url: '#',
  modalTarget: 'position-responsibilities',
  createdAt: '2026-04-25T00:00:00Z',
  updatedAt: '2026-04-25T00:00:00Z',
  tags: {
    age: ['U8', 'U10', 'U12', 'U14', 'U16+'],
    category: ['Group'],
    skill: ['Positioning', 'Communication'],
  },
});

const coachingResourcesWithPositionResponsibilities: Resource[] = [
  createPositionResponsibilitiesResource('coaching_resources', 'coaching-position-responsibilities'),
  ...coachingResources,
];

const playerResourcesWithPositionResponsibilities: Resource[] = [
  createPositionResponsibilitiesResource('player_resources', 'player-position-responsibilities'),
  ...playerResources,
];

const sectionResources: Record<ResourceSection, Resource[]> = {
  coaching_resources: coachingResourcesWithPositionResponsibilities,
  player_resources: playerResourcesWithPositionResponsibilities,
  manager: managerResources,
  guides,
  forms,
};

const initialFilters: ActiveFilters = { age: [], category: [], skill: [] };

const filteredInitial = {
  coaching_resources: filterResources(sectionResources.coaching_resources, initialFilters, '', 'coaching_resources'),
  player_resources: filterResources(sectionResources.player_resources, initialFilters, '', 'player_resources'),
  manager: filterResources(sectionResources.manager, initialFilters, '', 'manager'),
  guides: filterResources(sectionResources.guides, initialFilters, '', 'guides'),
  forms: filterResources(sectionResources.forms, initialFilters, '', 'forms'),
};

const coachingAvailableSkills = extractAvailableSkills(sectionResources.coaching_resources, 'coaching_resources');
const playerAvailableSkills = extractAvailableSkills(sectionResources.player_resources, 'player_resources');

const requestedTab = Astro.url.searchParams.get('tab');
const activeSection: ResourceSection = requestedTab === 'players'
  ? 'player_resources'
  : requestedTab === 'manager'
    ? 'manager'
    : requestedTab === 'guides'
      ? 'guides'
      : requestedTab === 'forms'
        ? 'forms'
        : 'coaching_resources';

const tabs: Array<{ key: ResourceSection; tabId: string; panelId: string; label: string; active: boolean }> = [
  { key: 'coaching_resources', tabId: 'tab-coaching', panelId: 'panel-coaching', label: 'Coaching Resources', active: activeSection === 'coaching_resources' },
  { key: 'player_resources', tabId: 'tab-players', panelId: 'panel-players', label: 'Player Resources', active: activeSection === 'player_resources' },
  { key: 'manager', tabId: 'tab-managers', panelId: 'panel-managers', label: 'Manager Resources', active: activeSection === 'manager' },
  { key: 'guides', tabId: 'tab-guides', panelId: 'panel-guides', label: 'Guides', active: activeSection === 'guides' },
  { key: 'forms', tabId: 'tab-forms', panelId: 'panel-forms', label: 'Forms', active: activeSection === 'forms' },
];

const submitHref = `mailto:president@bendigophoenix.org.au?subject=Resource%20Submission&body=Resource%20Title%3A%0AResource%20URL%3A%0ADescription%3A%0ACategory%3A%0AAge%20Group%3A`;
---

<BaseLayout title="Resources" description="Access coaching and player resources for Bendigo Phoenix Basketball Club — drills, guides, tools and development materials.">
  <section class="relative overflow-hidden bg-brand-purple px-4 py-12 lg:py-8 text-center">
    <div class="relative z-10 mx-auto max-w-3xl">
      <p class="mb-3 text-sm font-bold uppercase tracking-widest text-brand-gold">Club Hub</p>
      <h1 class="text-4xl font-black uppercase tracking-tight text-white sm:text-5xl">Phoenix Resources</h1>
      <div class="mx-auto mt-4 h-1 w-16 bg-brand-gold"></div>
      <p class="mx-auto mt-4 max-w-xl text-base text-purple-200">
        Coaching drills, player development guides, rules references, club policies, and forms — all in one place.
      </p>
    </div>
  </section>

  <ResourceTabs tabs={tabs} />

  <div class="bg-brand-offwhite min-h-screen px-4 py-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl space-y-10">
      <section id="panel-coaching" role="tabpanel" aria-labelledby="tab-coaching" class={activeSection === 'coaching_resources' ? '' : 'hidden'}>
        <FilterBar
          section="coaching_resources"
          label={getSectionLabel('coaching_resources')}
          availableAges={getAvailableAgeGroups('coaching_resources')}
          availableCategories={getAvailableCategories('coaching_resources')}
          availableSkills={coachingAvailableSkills}
          activeFilters={initialFilters}
          searchKeyword=""
          resultCount={filteredInitial.coaching_resources.length}
          showSearch={true}
        />

        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="coaching-grid">
          {filteredInitial.coaching_resources.map((resource) => (
            <ResourceItem resource={resource} accentColor="#573F93" />
          ))}
        </div>

        <div id="coaching-no-results" class="hidden rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
          <p class="text-lg font-bold text-brand-black" data-no-results-text>No resources found.</p>
          <p class="mt-2 text-sm text-gray-600" data-no-results-summary></p>
          <button
            type="button"
            class="mt-6 inline-flex min-h-[44px] items-center rounded-full bg-brand-purple px-4 py-2 text-sm font-bold text-white transition hover:bg-purple-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple/40"
            data-clear-filters
          >
            Clear all filters and search
          </button>
        </div>
      </section>

      <section id="panel-players" role="tabpanel" aria-labelledby="tab-players" class={activeSection === 'player_resources' ? '' : 'hidden'}>
        <FilterBar
          section="player_resources"
          label={getSectionLabel('player_resources')}
          availableAges={getAvailableAgeGroups('player_resources')}
          availableCategories={getAvailableCategories('player_resources')}
          availableSkills={playerAvailableSkills}
          activeFilters={initialFilters}
          searchKeyword=""
          resultCount={filteredInitial.player_resources.length}
          showSearch={true}
        />

        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="players-grid">
          {filteredInitial.player_resources.map((resource) => (
            <ResourceItem resource={resource} accentColor="#8B7536" />
          ))}
        </div>

        <div id="players-no-results" class="hidden rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
          <p class="text-lg font-bold text-brand-black" data-no-results-text>No resources found.</p>
          <p class="mt-2 text-sm text-gray-600" data-no-results-summary></p>
          <button
            type="button"
            class="mt-6 inline-flex min-h-[44px] items-center rounded-full bg-brand-purple px-4 py-2 text-sm font-bold text-white transition hover:bg-purple-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-purple/40"
            data-clear-filters
          >
            Clear all filters and search
          </button>
        </div>
      </section>

      <section id="panel-managers" role="tabpanel" aria-labelledby="tab-managers" class={activeSection === 'manager' ? '' : 'hidden'}>
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-2xl font-black uppercase tracking-tight text-brand-black">Manager Resources</h2>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="managers-grid">
          {filteredInitial.manager.map((resource) => (
            <ResourceItem resource={resource} accentColor="#573F93" />
          ))}
        </div>
        {filteredInitial.manager.length === 0 && (
          <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
            <p class="text-lg font-bold text-brand-black">No manager resources available.</p>
          </div>
        )}
      </section>

      <section id="panel-guides" role="tabpanel" aria-labelledby="tab-guides" class={activeSection === 'guides' ? '' : 'hidden'}>
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-2xl font-black uppercase tracking-tight text-brand-black">Guides</h2>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="guides-grid">
          {filteredInitial.guides.map((resource) => (
            <ResourceItem resource={resource} accentColor="#573F93" />
          ))}
        </div>
        {filteredInitial.guides.length === 0 && (
          <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
            <p class="text-lg font-bold text-brand-black">No guides available yet — check back soon.</p>
          </div>
        )}
      </section>

      <section id="panel-forms" role="tabpanel" aria-labelledby="tab-forms" class={activeSection === 'forms' ? '' : 'hidden'}>
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-2xl font-black uppercase tracking-tight text-brand-black">Forms</h2>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="forms-grid">
          {filteredInitial.forms.map((resource) => (
            <ResourceItem resource={resource} accentColor="#573F93" />
          ))}
        </div>
        {filteredInitial.forms.length === 0 && (
          <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-16 text-center shadow-sm">
            <p class="text-lg font-bold text-brand-black">No forms available yet — check back soon.</p>
          </div>
        )}
      </section>

      <div class="border-t border-gray-200 pt-12 text-center" data-submit-resource>
        <h2 class="mb-3 text-2xl font-black uppercase tracking-tight text-brand-black">Submit a Resource</h2>
        <p class="mx-auto mb-6 max-w-md text-sm text-gray-600">
          Know of a great drill or play that should be here? Share it with the club.
        </p>
        <a
          href={submitHref}
          class="inline-flex min-h-[44px] items-center gap-2 rounded-lg px-6 py-3 text-sm font-bold text-white transition-opacity hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-purple"
          style="background: #573F93;"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Submit a Resource
        </a>
      </div>
    </div>
  </div>

  <ResourceModal />
  <PositionResponsibilitiesCarousel />
</BaseLayout>

<script id="resources-page-data" type="application/json" set:html={JSON.stringify({ sectionResources })}></script>
<script is:inline src="/scripts/resources-page.js"></script>
