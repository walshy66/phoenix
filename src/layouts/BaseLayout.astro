---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Bendigo Phoenix Basketball Club — Where Community Meets Competition' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#573F93" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Bendigo Phoenix Basketball</title>
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Bendigo Phoenix Basketball`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bendigophoenix.org.au" />
  </head>
  <body class="min-h-screen flex flex-col bg-brand-offwhite">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
